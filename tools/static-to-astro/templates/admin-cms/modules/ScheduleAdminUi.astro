---
/**
 * CMS Kit Schedule admin module UI scaffold (G-5m-a).
 * Static items only — no Supabase query or save.
 */
import AdminPageHeader from "../components/AdminPageHeader.astro";
import AdminCard from "../components/AdminCard.astro";
import AdminDataTable from "../components/AdminDataTable.astro";
import AdminEditForm from "../components/AdminEditForm.astro";
import AdminFormField from "../components/AdminFormField.astro";
import AdminPublishToggle from "../components/AdminPublishToggle.astro";
import AdminSortOrderControl from "../components/AdminSortOrderControl.astro";
import AdminDuplicateButton from "../components/AdminDuplicateButton.astro";
import AdminLogicalDeleteRestore from "../components/AdminLogicalDeleteRestore.astro";
import AdminEmptyState from "../components/AdminEmptyState.astro";
import AdminStatusMessage from "../components/AdminStatusMessage.astro";

export interface ScheduleAdminItem {
  id: string;
  date: string;
  title: string;
  venue?: string;
  published: boolean;
  image_url?: string;
  home_image_url?: string;
  sort_order?: number;
  deleted?: boolean;
  dateConflict?: boolean;
}

interface Props {
  items?: ScheduleAdminItem[];
  siteName?: string;
  readonly?: boolean;
}

const { items = [], siteName = "CMS Kit", readonly = true } = Astro.props;

const hasConflict = items.some((item) => item.dateConflict);

const columns = [
  { key: "date", label: "Date" },
  { key: "title", label: "Title" },
  { key: "venue", label: "Venue" },
  { key: "image", label: "Image" },
  { key: "status", label: "Status" },
];

const rows = items.map((item) => ({
  date: item.date,
  title: item.deleted ? `${item.title} (deleted)` : item.title,
  venue: item.venue ?? "—",
  image: item.image_url || item.home_image_url ? "Attached" : "None",
  status: item.published ? "Published" : "Draft",
}));
---

<section class="admin-module admin-module--schedule" data-module="schedule" data-scaffold="true">
  <AdminPageHeader
    title="Schedule"
    description={`Manage events for ${siteName}. Scaffold only — no DB connection.`}
  >
    <button slot="actions" class="admin-button" type="button" disabled={readonly}>
      Add event
    </button>
  </AdminPageHeader>

  {readonly ? (
    <p class="admin-readonly-notice" role="note">
      Read-only scaffold. No Supabase query or save.
    </p>
  ) : null}

  {
    hasConflict ? (
      <AdminStatusMessage
        type="warning"
        title="Human review suggested"
        message="One or more events have a date conflict. Review before publishing."
      />
    ) : null
  }

  <AdminCard title="Events list" description="Expected table: schedule / events">
    {
      items.length === 0 ? (
        <AdminEmptyState title="No events yet" message="Add your first schedule entry.">
          <button slot="action" class="admin-button" type="button" disabled>
            Add event
          </button>
        </AdminEmptyState>
      ) : (
        <AdminDataTable
          columns={columns}
          rows={rows}
          caption="Schedule items (static example)"
          showActionsColumn={true}
        >
          <div class="admin-table-actions">
            <AdminSortOrderControl value={items[0]?.sort_order ?? 0} disabled={true} />
            <AdminDuplicateButton itemLabel={items[0]?.title ?? ""} disabled={true} />
            <AdminLogicalDeleteRestore
              deleted={items[0]?.deleted ?? false}
              itemLabel={items[0]?.title ?? ""}
              disabled={true}
            />
          </div>
        </AdminDataTable>
      )
    }
  </AdminCard>

  <AdminCard title="Create / edit form" description="Schedule fields scaffold.">
    <AdminEditForm title="Edit event" mode="edit" disabled={true}>
      <AdminFormField label="Date" help="Event date (YYYY-MM-DD).">
        <input type="date" disabled />
      </AdminFormField>
      <AdminFormField label="Title">
        <input type="text" placeholder="Event title" disabled />
      </AdminFormField>
      <AdminFormField label="Venue">
        <input type="text" placeholder="Venue name" disabled />
      </AdminFormField>
      <AdminFormField label="Image URL" help="Storage upload in G-5n — status display only.">
        <input type="text" placeholder="No image attached" disabled />
      </AdminFormField>
      <AdminPublishToggle published={false} disabled={true} />
      <AdminSortOrderControl value={0} disabled={true} />
    </AdminEditForm>
  </AdminCard>
</section>
