---
/**
 * Gosaki staging read-only CMS admin (G-11b / G-20u28 dashboard polish).
 * Static build-time data + YouTube dry-run endpoint wiring (no Save / JSON write).
 */
import "../styles/gosaki-staging-read-only-admin.css";
import youtubeConfig from "../data/gosaki-youtube-embed.json";
import aboutConfig from "../data/gosaki-about-content.json";
import contactConfig from "../data/gosaki-contact-hubspot.json";
import dashboardSnapshot from "../data/gosaki-read-only-admin-dashboard.json";
import discographyEditorSnapshot from "../data/gosaki-read-only-admin-discography-editor.json";
import {
  G11C6A_PHASE,
  G11C4A_STAGING_DRY_RUN_ENDPOINT,
  G11C6A_STAGING_SAVE_ENDPOINT,
  G11C6_APPROVAL_ID,
  G11C6_OPERATION_ID,
  G11C6_SAVE_DISABLED_REASON,
  G11C6_SAVE_ENABLED_DEFAULT,
  G20U28_ADMIN_UI_PHASE,
  G20U29_DISCOGRAPHY_EDITOR_PHASE,
  G20U29_DISCOGRAPHY_EDITOR_SAVE_DISABLED_REASON,
  GOSAKI_STAGING_PREVIEW_URL,
  buildGosakiReadOnlyAdminViewModel,
  isG11c4aSupabaseAuthConfigured,
  isG11c6aSaveEnabled,
  resolveG11c4aDryRunEndpoint,
  resolveG11c4aSupabaseAnonKey,
  resolveG11c4aSupabaseUrl,
  resolveG11c6aSaveEndpoint,
} from "../lib/gosaki-staging-read-only-admin";

const dryRunEndpoint = resolveG11c4aDryRunEndpoint(import.meta.env);
const saveEndpoint = resolveG11c6aSaveEndpoint(import.meta.env);
const supabaseUrl = resolveG11c4aSupabaseUrl(import.meta.env);
const supabaseAnonKey = resolveG11c4aSupabaseAnonKey(import.meta.env);
const supabaseAuthConfigured = isG11c4aSupabaseAuthConfigured(import.meta.env);
const endpointConfigured = Boolean(dryRunEndpoint);
const saveEndpointConfigured = Boolean(saveEndpoint);
const saveEnabled = isG11c6aSaveEnabled(import.meta.env);
const g11c1OperationId = "G-11c1-gosaki-youtube-url-web-save-dry-run-poc";
const g11c1ApprovalId = "G-11c1-youtube-url-dry-run";

const view = buildGosakiReadOnlyAdminViewModel({
  youtube: youtubeConfig,
  about: aboutConfig,
  contact: contactConfig,
});

const dashboard = dashboardSnapshot;
const discographyEditor = discographyEditorSnapshot;
const stagingSiteBase = String(import.meta.env.SITE ?? GOSAKI_STAGING_PREVIEW_URL).replace(/\/?$/, "/");
const adminCanonical = new URL("admin/", stagingSiteBase).href;
const publicHomeUrl = stagingSiteBase;
const publicScheduleUrl = new URL("schedule/", stagingSiteBase).href;
const publicAugustUrl = new URL("schedule/2026-08/", stagingSiteBase).href;
const publicDiscographyUrl = new URL("discography/", stagingSiteBase).href;
const publicContactUrl = new URL("contact/", stagingSiteBase).href;
const publicLinkUrl = new URL("link/", stagingSiteBase).href;
const robotsContent = "noindex,nofollow,noarchive";
const pageTitle = "Gosaki Piano 管理画面（staging · 読み取り専用）";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={robotsContent} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={adminCanonical} />
    <meta property="og:url" content={adminCanonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:type" content="website" />
  </head>
  <body
    class="gosaki-read-only-admin"
    data-gosaki-read-only-admin="true"
    data-phase={G20U28_ADMIN_UI_PHASE}
    data-discography-editor-phase={G20U29_DISCOGRAPHY_EDITOR_PHASE}
    data-g11c6a-phase={G11C6A_PHASE}
    data-gosaki-youtube-dry-run-endpoint={dryRunEndpoint}
    data-gosaki-youtube-save-endpoint={saveEndpoint}
    data-gosaki-supabase-url={supabaseUrl}
    data-gosaki-supabase-anon-key={supabaseAnonKey}
    data-gosaki-supabase-auth-configured={supabaseAuthConfigured ? "true" : "false"}
    data-gosaki-youtube-current-embed={view.youtube.sourceUrl}
    data-gosaki-youtube-current-videoid={view.youtube.videoId ?? ""}
    data-g11c1-operation-id={g11c1OperationId}
    data-g11c1-approval-id={g11c1ApprovalId}
    data-g11c6-operation-id={G11C6_OPERATION_ID}
    data-g11c6-approval-id={G11C6_APPROVAL_ID}
    data-g11c6-save-enabled={saveEnabled ? "true" : "false"}
  >
    <div class="gosaki-read-only-admin__shell">
      <header class="gosaki-read-only-admin__header">
        <a class="gosaki-read-only-admin__brand" href={adminCanonical}>Gosaki Piano CMS</a>
        <div class="gosaki-read-only-admin__badges" aria-label="管理画面モード">
          <span class="gosaki-read-only-admin__badge">READ-ONLY</span>
          <span class="gosaki-read-only-admin__badge gosaki-read-only-admin__badge--staging">STAGING ONLY</span>
          <span class="gosaki-read-only-admin__badge gosaki-read-only-admin__badge--muted">Save disabled</span>
        </div>
      </header>

      <main class="gosaki-read-only-admin__main">
        <div class="gosaki-read-only-admin__banner" role="status">
          <strong>staging 読み取り専用管理画面</strong>
          <p class="gosaki-read-only-admin__meta">
            内容の確認と dry-run プレビューのみ可能です。Save · Publish · Deploy · FTP は実行できません。
          </p>
          <ul class="gosaki-read-only-admin__safety-list">
            <li>本番パッケージには <code>/admin/</code> を含めません（sitemap からも除外）</li>
            <li>staging への反映は <strong>手動 FTP のみ</strong>（自動 deploy なし）</li>
            <li>本番アップロードは <strong>G-20j 承認まで STOP</strong></li>
          </ul>
        </div>

        <section class="gosaki-read-only-admin__section" aria-labelledby="gra-dashboard">
          <h2 id="gra-dashboard">ダッシュボード</h2>
          <p class="gosaki-read-only-admin__meta">
            <strong>siteSlug:</strong> {view.siteSlug} · build 時スナップショット（{dashboard.phase}）
          </p>
          <div class="gosaki-read-only-admin__dashboard-grid">
            <article class="gosaki-read-only-admin__dashboard-card" data-section-card="schedule">
              <h3 class="gosaki-read-only-admin__dashboard-card-title">Schedule</h3>
              <div class="gosaki-read-only-admin__dashboard-badges">
                <span class="gosaki-read-only-admin__pill">read-only</span>
                <span class="gosaki-read-only-admin__pill gosaki-read-only-admin__pill--staging">staging</span>
              </div>
              <p class="gosaki-read-only-admin__dashboard-stat">
                {dashboard.schedule.totalEvents} events · 2026-08: {dashboard.schedule.august2026Events} cards
              </p>
              <p class="gosaki-read-only-admin__meta">source: {dashboard.schedule.dataSource}</p>
              <div class="gosaki-read-only-admin__actions">
                <a class="gosaki-read-only-admin__btn gosaki-read-only-admin__btn--link" href={publicAugustUrl} target="_blank" rel="noopener noreferrer">Read-only preview</a>
                <button type="button" class="gosaki-read-only-admin__btn" disabled title="編集 UI は別フェーズ">編集導線（予定）</button>
              </div>
            </article>

            <article class="gosaki-read-only-admin__dashboard-card" data-section-card="discography">
              <h3 class="gosaki-read-only-admin__dashboard-card-title">Discography</h3>
              <div class="gosaki-read-only-admin__dashboard-badges">
                <span class="gosaki-read-only-admin__pill">read-only</span>
                {dashboard.discography.filteredRead ? (
                  <span class="gosaki-read-only-admin__pill gosaki-read-only-admin__pill--ok">filtered read</span>
                ) : null}
              </div>
              <p class="gosaki-read-only-admin__dashboard-stat">
                {dashboard.discography.releases} releases · {dashboard.discography.tracks} tracks
              </p>
              <p class="gosaki-read-only-admin__meta">source: {dashboard.discography.dataSource}</p>
              <div class="gosaki-read-only-admin__actions">
                <a class="gosaki-read-only-admin__btn gosaki-read-only-admin__btn--link" href={publicDiscographyUrl} target="_blank" rel="noopener noreferrer">Read-only preview</a>
                <a class="gosaki-read-only-admin__btn gosaki-read-only-admin__btn--link" href="#gra-discography-editor">Editor prototype</a>
              </div>
            </article>

            <article class="gosaki-read-only-admin__dashboard-card" data-section-card="youtube">
              <h3 class="gosaki-read-only-admin__dashboard-card-title">YouTube</h3>
              <div class="gosaki-read-only-admin__dashboard-badges">
                <span class="gosaki-read-only-admin__pill">read-only</span>
                <span class="gosaki-read-only-admin__pill">dry-run only</span>
              </div>
              <p class="gosaki-read-only-admin__dashboard-stat">
                videoId: {view.youtube.videoId ?? "—"}
              </p>
              <div class="gosaki-read-only-admin__actions">
                <a class="gosaki-read-only-admin__btn gosaki-read-only-admin__btn--link" href="#gra-youtube">詳細を見る</a>
                <button type="button" class="gosaki-read-only-admin__btn" disabled>Save（無効）</button>
              </div>
            </article>

            <article class="gosaki-read-only-admin__dashboard-card" data-section-card="about">
              <h3 class="gosaki-read-only-admin__dashboard-card-title">About</h3>
              <div class="gosaki-read-only-admin__dashboard-badges">
                <span class="gosaki-read-only-admin__pill">read-only</span>
              </div>
              <p class="gosaki-read-only-admin__dashboard-stat">
                profile {view.about.profileCharCount} chars · bands {view.about.bandImages.length} images
              </p>
              <div class="gosaki-read-only-admin__actions">
                <a class="gosaki-read-only-admin__btn gosaki-read-only-admin__btn--link" href={new URL("about/", stagingSiteBase).href} target="_blank" rel="noopener noreferrer">Read-only preview</a>
                <button type="button" class="gosaki-read-only-admin__btn" disabled>編集導線（予定）</button>
              </div>
            </article>

            <article class="gosaki-read-only-admin__dashboard-card" data-section-card="contact">
              <h3 class="gosaki-read-only-admin__dashboard-card-title">Contact</h3>
              <div class="gosaki-read-only-admin__dashboard-badges">
                <span class="gosaki-read-only-admin__pill">read-only</span>
              </div>
              <p class="gosaki-read-only-admin__dashboard-stat">
                {view.contact.provider} · enabled: {view.contact.enabled ? "yes" : "no"}
              </p>
              <div class="gosaki-read-only-admin__actions">
                <a class="gosaki-read-only-admin__btn gosaki-read-only-admin__btn--link" href={publicContactUrl} target="_blank" rel="noopener noreferrer">Read-only preview</a>
                <button type="button" class="gosaki-read-only-admin__btn" disabled>編集導線（予定）</button>
              </div>
            </article>

            <article class="gosaki-read-only-admin__dashboard-card" data-section-card="link">
              <h3 class="gosaki-read-only-admin__dashboard-card-title">Link</h3>
              <div class="gosaki-read-only-admin__dashboard-badges">
                <span class="gosaki-read-only-admin__pill">static</span>
              </div>
              <p class="gosaki-read-only-admin__dashboard-stat">静的ページ（CMS 編集 UI 未接続）</p>
              <div class="gosaki-read-only-admin__actions">
                <a class="gosaki-read-only-admin__btn gosaki-read-only-admin__btn--link" href={publicLinkUrl} target="_blank" rel="noopener noreferrer">Read-only preview</a>
              </div>
            </article>

            <article class="gosaki-read-only-admin__dashboard-card gosaki-read-only-admin__dashboard-card--safety" data-section-card="upload-safety">
              <h3 class="gosaki-read-only-admin__dashboard-card-title">Production readiness / Upload safety</h3>
              <div class="gosaki-read-only-admin__dashboard-badges">
                <span class="gosaki-read-only-admin__pill gosaki-read-only-admin__pill--warn">production STOP</span>
              </div>
              <ul class="gosaki-read-only-admin__list gosaki-read-only-admin__list--compact">
                <li>本番 upload: G-20j まで STOP</li>
                <li>本番 package: admin 除外</li>
                <li>FTP: 手動のみ（auto deploy なし）</li>
                <li>sitemap: /admin/ 非掲載</li>
              </ul>
            </article>
          </div>
        </section>

        <section
          class="gosaki-read-only-admin__section gosaki-read-only-admin__section--discography-editor"
          id="gra-discography-editor"
          aria-labelledby="gra-discography-editor-heading"
          data-section="discography-editor-prototype"
        >
          <h2 id="gra-discography-editor-heading">Discography Editor Prototype</h2>
          <div class="gosaki-read-only-admin__banner gosaki-read-only-admin__banner--compact" role="status">
            <div class="gosaki-read-only-admin__dashboard-badges">
              <span class="gosaki-read-only-admin__pill">read-only prototype</span>
              <span class="gosaki-read-only-admin__pill gosaki-read-only-admin__pill--staging">STAGING ONLY</span>
              <span class="gosaki-read-only-admin__pill gosaki-read-only-admin__pill--warn">Save disabled</span>
            </div>
            <p class="gosaki-read-only-admin__meta">
              {G20U29_DISCOGRAPHY_EDITOR_SAVE_DISABLED_REASON}
            </p>
            <ul class="gosaki-read-only-admin__safety-list">
              <li>DB write なし · Supabase insert/update/delete なし</li>
              <li>本番 package には <code>/admin/</code> を含めません（sitemap からも除外）</li>
              <li>本番 upload: <strong>G-20j まで STOP</strong></li>
            </ul>
          </div>
          <p class="gosaki-read-only-admin__meta">
            <strong>siteSlug:</strong> {discographyEditor.siteSlug} ·{" "}
            {discographyEditor.releaseCount} releases · {discographyEditor.trackCount} tracks · source:{" "}
            {discographyEditor.dataSource}
            {discographyEditor.filteredRead ? " · filtered read" : ""}
          </p>

          {discographyEditor.albums.length === 0 ? (
            <p class="gosaki-read-only-admin__meta gosaki-read-only-admin__meta--warn">
              Discography データがありません（build 時 Supabase read 未接続または 0 件）。
            </p>
          ) : (
            <div class="gosaki-read-only-admin__discography-editor-grid">
              {discographyEditor.albums.map((album) => (
                <article
                  class="gosaki-read-only-admin__album-card"
                  data-album-legacy-id={album.legacyId}
                  data-section-card="discography-album"
                >
                  <header class="gosaki-read-only-admin__album-card-header">
                    <h3 class="gosaki-read-only-admin__album-card-title">{album.title}</h3>
                    <p class="gosaki-read-only-admin__meta">
                      {album.legacyId} · {album.trackCount} tracks
                    </p>
                  </header>

                  {album.coverImageUrl ? (
                    <div class="gosaki-read-only-admin__cover-preview-wrap">
                      <img
                        class="gosaki-read-only-admin__cover-preview"
                        src={album.coverImageUrl}
                        alt={`${album.title} cover`}
                        loading="lazy"
                      />
                      <p class="gosaki-read-only-admin__meta gosaki-read-only-admin__cover-url">{album.coverImageUrl}</p>
                    </div>
                  ) : (
                    <p class="gosaki-read-only-admin__meta">cover_image_url: —</p>
                  )}

                  <div class="gosaki-read-only-admin__field">
                    <label for={`gra-disc-title-${album.legacyId}`}>title</label>
                    <input id={`gra-disc-title-${album.legacyId}`} type="text" readonly value={album.title} />
                  </div>
                  <div class="gosaki-read-only-admin__field">
                    <label for={`gra-disc-artist-${album.legacyId}`}>artist</label>
                    <input
                      id={`gra-disc-artist-${album.legacyId}`}
                      type="text"
                      readonly
                      value={album.artist ?? "—"}
                    />
                  </div>
                  <div class="gosaki-read-only-admin__field">
                    <label for={`gra-disc-release-date-${album.legacyId}`}>release_date</label>
                    <input
                      id={`gra-disc-release-date-${album.legacyId}`}
                      type="text"
                      readonly
                      value={album.releaseDate ?? "—"}
                    />
                  </div>
                  <div class="gosaki-read-only-admin__field">
                    <label for={`gra-disc-label-${album.legacyId}`}>label / catalog_number</label>
                    <input
                      id={`gra-disc-label-${album.legacyId}`}
                      type="text"
                      readonly
                      value={`${album.label ?? "—"} · ${album.catalogNumber ?? "—"}`}
                    />
                  </div>
                  <div class="gosaki-read-only-admin__field">
                    <label for={`gra-disc-published-${album.legacyId}`}>published</label>
                    <input
                      id={`gra-disc-published-${album.legacyId}`}
                      type="text"
                      readonly
                      value={album.published ? "true" : "false"}
                    />
                  </div>
                  <div class="gosaki-read-only-admin__field">
                    <label for={`gra-disc-purchase-${album.legacyId}`}>purchase_url</label>
                    <input
                      id={`gra-disc-purchase-${album.legacyId}`}
                      type="url"
                      readonly
                      value={album.purchaseUrl ?? "—"}
                    />
                  </div>
                  <div class="gosaki-read-only-admin__field">
                    <label for={`gra-disc-streaming-${album.legacyId}`}>streaming_url</label>
                    <input
                      id={`gra-disc-streaming-${album.legacyId}`}
                      type="url"
                      readonly
                      value={album.streamingUrl ?? "—"}
                    />
                  </div>
                  <div class="gosaki-read-only-admin__field">
                    <label for={`gra-disc-description-${album.legacyId}`}>
                      description / personnel (readonly preview)
                    </label>
                    <textarea
                      id={`gra-disc-description-${album.legacyId}`}
                      class="gosaki-read-only-admin__textarea-readonly"
                      readonly
                      rows={4}
                    >{album.description || "—"}</textarea>
                  </div>
                  <div class="gosaki-read-only-admin__field">
                    <label for={`gra-disc-tracks-${album.legacyId}`}>
                      track list — 1 line = 1 track · Save disabled
                    </label>
                    <textarea
                      id={`gra-disc-tracks-${album.legacyId}`}
                      class="gosaki-read-only-admin__textarea-readonly gosaki-read-only-admin__track-list-textarea"
                      data-track-list-textarea="true"
                      readonly
                      rows={Math.max(4, Math.min(16, album.trackCount + 1))}
                    >{album.trackListText || "—"}</textarea>
                  </div>
                  <div class="gosaki-read-only-admin__actions">
                    <button type="button" class="gosaki-read-only-admin__btn" disabled title={G20U29_DISCOGRAPHY_EDITOR_SAVE_DISABLED_REASON}>
                      Save（無効 — future phase）
                    </button>
                  </div>
                </article>
              ))}
            </div>
          )}

          <div class="gosaki-read-only-admin__actions">
            <button type="button" class="gosaki-read-only-admin__btn" disabled title={G20U29_DISCOGRAPHY_EDITOR_SAVE_DISABLED_REASON}>
              Save Discography（無効 — future phase）
            </button>
          </div>
        </section>

        <section class="gosaki-read-only-admin__section" aria-labelledby="gra-overview">
          <h2 id="gra-overview">サイト概要</h2>
          <p class="gosaki-read-only-admin__meta">
            <strong>staging URL:</strong>{" "}
            <a class="gosaki-read-only-admin__link" href={view.stagingUrl} target="_blank" rel="noopener noreferrer">
              {view.stagingUrl}
            </a>
          </p>
          <p class="gosaki-read-only-admin__meta">
            <strong>公開ページ:</strong>{" "}
            <a class="gosaki-read-only-admin__link" href={publicHomeUrl} target="_blank" rel="noopener noreferrer">トップ</a>
            {" · "}
            <a class="gosaki-read-only-admin__link" href={publicScheduleUrl} target="_blank" rel="noopener noreferrer">Schedule</a>
          </p>
          <p class="gosaki-read-only-admin__meta"><strong>noindex:</strong> {view.noindex ? "yes" : "no"}</p>
          <p class="gosaki-read-only-admin__meta">{view.packageNote}</p>
        </section>

        <section class="gosaki-read-only-admin__section" aria-labelledby="gra-auth">
          <h2 id="gra-auth">Staging Auth（YouTube dry-run 用）</h2>
          <div class="gosaki-read-only-admin__auth" id="gra-auth-panel">
            <p class="gosaki-read-only-admin__meta" id="gra-auth-status" aria-live="polite">
              ログイン状態を確認しています…
            </p>
            {
              supabaseAuthConfigured ? (
                <p class="gosaki-read-only-admin__meta gosaki-read-only-admin__meta--ok" id="gra-auth-config-status">
                  Supabase Auth: configured — ログインして dry-run を実行できます（保存されません）
                </p>
              ) : (
                <p class="gosaki-read-only-admin__meta gosaki-read-only-admin__meta--warn">
                  Supabase Auth 未設定 — build 時に PUBLIC_SUPABASE_URL と PUBLIC_SUPABASE_ANON_KEY（staging anon）が必要です。
                </p>
              )
            }
            <div id="gra-auth-signed-in" class="gosaki-read-only-admin__auth-actions" hidden>
              <button type="button" id="gra-auth-sign-out-btn" class="gosaki-read-only-admin__btn" disabled>
                ログアウト
              </button>
            </div>
            <form
              id="gra-auth-login-form"
              class="gosaki-read-only-admin__auth-form"
              hidden={!supabaseAuthConfigured}
            >
              <div class="gosaki-read-only-admin__field">
                <label for="gra-auth-email">メールアドレス</label>
                <input id="gra-auth-email" type="email" autocomplete="username" />
              </div>
              <div class="gosaki-read-only-admin__field">
                <label for="gra-auth-password">パスワード</label>
                <input id="gra-auth-password" type="password" autocomplete="current-password" />
              </div>
              <div class="gosaki-read-only-admin__auth-actions">
                <button
                  type="submit"
                  id="gra-auth-sign-in-btn"
                  class="gosaki-read-only-admin__btn gosaki-read-only-admin__btn--primary"
                  disabled={!supabaseAuthConfigured}
                >
                  ログイン
                </button>
              </div>
            </form>
          </div>
        </section>

        <section class="gosaki-read-only-admin__section" aria-labelledby="gra-youtube">
          <h2 id="gra-youtube">YouTube Embed</h2>
          <div class="gosaki-read-only-admin__field">
            <label for="gra-youtube-url">YouTube URL / embedCode</label>
            <textarea id="gra-youtube-url" readonly>{view.youtube.sourceUrl}</textarea>
          </div>
          <div class="gosaki-read-only-admin__field">
            <label for="gra-youtube-videoid">videoId</label>
            <input id="gra-youtube-videoid" type="text" readonly value={view.youtube.videoId ?? "—"} />
          </div>
          <p class="gosaki-read-only-admin__meta">
            published: {view.youtube.published ? "true" : "false"}
          </p>

          <div class="gosaki-read-only-admin__dry-run" id="gra-youtube-dry-run" data-section="youtube-dry-run">
            <h3 class="gosaki-read-only-admin__meta">Dry-run（保存前チェック — JSON は書き換えません）</h3>
            <p
              class:list={[
                "gosaki-read-only-admin__meta",
                endpointConfigured
                  ? "gosaki-read-only-admin__meta--ok"
                  : "gosaki-read-only-admin__meta--warn",
              ]}
              id="gra-youtube-endpoint-status"
            >
              {
                endpointConfigured
                  ? `dry-run endpoint: configured (${dryRunEndpoint})`
                  : "dry-run endpoint: not configured"
              }
            </p>
            <div class="gosaki-read-only-admin__field">
              <label for="gra-youtube-next-url">next YouTube URL</label>
              <input
                id="gra-youtube-next-url"
                type="url"
                inputmode="url"
                autocomplete="off"
                placeholder="https://www.youtube.com/watch?v=..."
              />
            </div>
            <div class="gosaki-read-only-admin__actions">
              <button
                type="button"
                id="gra-youtube-dry-run-btn"
                class="gosaki-read-only-admin__btn gosaki-read-only-admin__btn--primary"
                disabled
              >
                Dry-run（保存前チェック）
              </button>
            </div>
            <pre
              id="gra-youtube-dry-run-result"
              class="gosaki-read-only-admin__dry-run-result"
              aria-live="polite"
            >（Dry-run 結果はここに表示されます — ok / dryRun / wouldWrite / changedFields / next.videoId）</pre>
          </div>

          <div class="gosaki-read-only-admin__save" id="gra-youtube-save" data-section="youtube-save">
            <h3 class="gosaki-read-only-admin__meta">Save（G-11c6a — 現在は無効）</h3>
            <p class="gosaki-read-only-admin__meta gosaki-read-only-admin__meta--warn" id="gra-youtube-save-disabled-reason">
              {G11C6_SAVE_DISABLED_REASON}
            </p>
            <div class="gosaki-read-only-admin__actions">
              <button
                type="button"
                id="gra-youtube-save-btn"
                class="gosaki-read-only-admin__btn"
                disabled
                title={G11C6_SAVE_DISABLED_REASON}
              >
                Save（無効 — G-11c6a）
              </button>
            </div>
          </div>
        </section>

        <section class="gosaki-read-only-admin__section" aria-labelledby="gra-about">
          <h2 id="gra-about">About</h2>
          <p class="gosaki-read-only-admin__meta">
            <strong>{view.about.profileLabel}</strong> — {view.about.profileCharCount} chars
          </p>
          <p class="gosaki-read-only-admin__meta">{view.about.profileSummary || "（内容なし）"}</p>
          <p class="gosaki-read-only-admin__meta">
            <strong>{view.about.bandsLabel}</strong> — {view.about.bandsCharCount} chars · {view.about.bandImages.length} images
          </p>
        </section>

        <section class="gosaki-read-only-admin__section" aria-labelledby="gra-contact">
          <h2 id="gra-contact">Contact（HubSpot）</h2>
          <p class="gosaki-read-only-admin__meta"><strong>provider:</strong> {view.contact.provider}</p>
          <p class="gosaki-read-only-admin__meta"><strong>portalId:</strong> {view.contact.portalId}</p>
          <p class="gosaki-read-only-admin__meta"><strong>formId:</strong> {view.contact.formId}</p>
          <p class="gosaki-read-only-admin__meta">enabled: {view.contact.enabled ? "true" : "false"}</p>
        </section>

        <section class="gosaki-read-only-admin__section" aria-labelledby="gra-schedule">
          <h2 id="gra-schedule">Schedule</h2>
          <p class="gosaki-read-only-admin__meta"><strong>status:</strong> {view.schedule.status}</p>
          <p class="gosaki-read-only-admin__meta">{view.schedule.note}</p>
          <p class="gosaki-read-only-admin__meta">
            build snapshot: {dashboard.schedule.totalEvents} events · {dashboard.schedule.monthCount} months · August 2026: {dashboard.schedule.august2026Events} cards
          </p>
        </section>

        <div class="gosaki-read-only-admin__actions" aria-label="グローバル操作（無効）">
          <button type="button" class="gosaki-read-only-admin__btn" disabled>Save（無効）</button>
          <button type="button" class="gosaki-read-only-admin__btn" disabled>Publish（無効）</button>
          <button type="button" class="gosaki-read-only-admin__btn" disabled>Deploy（無効）</button>
          <button type="button" class="gosaki-read-only-admin__btn" disabled>FTP（無効）</button>
        </div>
      </main>

      <footer class="gosaki-read-only-admin__footer">
        Gosaki Piano staging read-only CMS — {G20U28_ADMIN_UI_PHASE} · {G20U29_DISCOGRAPHY_EDITOR_PHASE}
      </footer>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.49.1/dist/umd/supabase.js"></script>
    <script is:inline>
      (function () {
        var btn = document.getElementById("gra-youtube-dry-run-btn");
        var input = document.getElementById("gra-youtube-next-url");
        var result = document.getElementById("gra-youtube-dry-run-result");
        var body = document.body;
        var authStatus = document.getElementById("gra-auth-status");
        var authLoginForm = document.getElementById("gra-auth-login-form");
        var authSignedIn = document.getElementById("gra-auth-signed-in");
        var authSignInBtn = document.getElementById("gra-auth-sign-in-btn");
        var authSignOutBtn = document.getElementById("gra-auth-sign-out-btn");
        var authEmail = document.getElementById("gra-auth-email");
        var authPassword = document.getElementById("gra-auth-password");
        if (!btn || !input || !result || !body) return;

        var supabaseUrl = (body.dataset.gosakiSupabaseUrl || "").trim();
        var supabaseAnonKey = (body.dataset.gosakiSupabaseAnonKey || "").trim();
        var supabaseAuthConfigured = body.dataset.gosakiSupabaseAuthConfigured === "true";
        var supabaseClient = null;
        var signedIn = false;

        function showResult(obj) {
          result.textContent = JSON.stringify(obj, null, 2);
        }

        function resolveCreateClient() {
          var lib = window.supabase;
          if (!lib) return null;
          if (typeof lib.createClient === "function") return lib.createClient;
          if (lib.default && typeof lib.default.createClient === "function") return lib.default.createClient;
          return null;
        }

        function getSupabaseClient() {
          if (!supabaseAuthConfigured || !supabaseUrl || !supabaseAnonKey) return null;
          var createClient = resolveCreateClient();
          if (!createClient) return null;
          if (!supabaseClient) {
            supabaseClient = createClient(supabaseUrl, supabaseAnonKey, {
              auth: {
                persistSession: true,
                autoRefreshToken: true,
                detectSessionInUrl: false,
              },
            });
          }
          return supabaseClient;
        }

        function updateDryRunButton() {
          btn.disabled = !signedIn;
        }

        function updateLoginButton() {
          if (!authSignInBtn) return;
          if (!supabaseAuthConfigured || signedIn) {
            authSignInBtn.disabled = true;
            return;
          }
          authSignInBtn.disabled = false;
        }

        function updateSignOutButton() {
          if (!authSignOutBtn) return;
          authSignOutBtn.disabled = !signedIn;
        }

        function setAuthUiSignedIn(email) {
          signedIn = true;
          if (authStatus) {
            authStatus.textContent = "ログイン済み — " + (email || "（emailなし）") + "（dry-run 可能）";
          }
          if (authLoginForm) authLoginForm.hidden = true;
          if (authSignedIn) authSignedIn.hidden = false;
          updateLoginButton();
          updateSignOutButton();
          updateDryRunButton();
        }

        function setAuthUiSignedOut(message) {
          signedIn = false;
          if (authStatus) {
            if (!supabaseAuthConfigured) {
              authStatus.textContent =
                message ||
                "Supabase Auth 未設定 — PUBLIC_SUPABASE_URL / PUBLIC_SUPABASE_ANON_KEY が build に必要です";
            } else {
              authStatus.textContent =
                message || "未ログイン — staging 管理者でログインしてから dry-run してください";
            }
          }
          if (authLoginForm) authLoginForm.hidden = !supabaseAuthConfigured;
          if (authSignedIn) authSignedIn.hidden = true;
          updateLoginButton();
          updateSignOutButton();
          updateDryRunButton();
        }

        function waitForSupabaseClient(maxAttempts, delayMs) {
          return new Promise(function (resolve) {
            var attempt = 0;
            function tick() {
              if (getSupabaseClient()) {
                resolve(getSupabaseClient());
                return;
              }
              attempt += 1;
              if (attempt >= maxAttempts) {
                resolve(null);
                return;
              }
              setTimeout(tick, delayMs);
            }
            tick();
          });
        }

        function refreshAuthStatus() {
          if (!supabaseAuthConfigured) {
            setAuthUiSignedOut();
            return Promise.resolve();
          }

          if (authStatus) {
            authStatus.textContent = "ログイン状態を確認しています…";
          }
          updateLoginButton();

          return waitForSupabaseClient(40, 100).then(function (client) {
            if (!client) {
              setAuthUiSignedOut("Supabase JS の読み込みに失敗しました — ページを再読み込みしてください");
              return;
            }
            return client.auth.getSession().then(function (sessionRes) {
              var session = sessionRes.data && sessionRes.data.session;
              if (session && session.access_token) {
                setAuthUiSignedIn(session.user && session.user.email);
              } else {
                setAuthUiSignedOut();
              }
            });
          });
        }

        if (authLoginForm && authEmail && authPassword) {
          authEmail.addEventListener("input", updateLoginButton);
          authPassword.addEventListener("input", updateLoginButton);

          authLoginForm.addEventListener("submit", function (ev) {
            ev.preventDefault();
            if (!supabaseAuthConfigured) {
              setAuthUiSignedOut();
              return;
            }
            var email = String(authEmail.value || "").trim();
            var password = String(authPassword.value || "");
            if (!email || !password) {
              setAuthUiSignedOut("メールアドレスとパスワードを入力してください");
              return;
            }
            var client = getSupabaseClient();
            if (!client) {
              setAuthUiSignedOut("Supabase JS の読み込みに失敗しました — ページを再読み込みしてください");
              return;
            }
            if (authSignInBtn) authSignInBtn.disabled = true;
            client.auth
              .signInWithPassword({ email: email, password: password })
              .then(function (res) {
                if (res.error) {
                  setAuthUiSignedOut("ログイン失敗: " + res.error.message);
                  return;
                }
                setAuthUiSignedIn(res.data.user && res.data.user.email);
              })
              .finally(function () {
                updateLoginButton();
              });
          });
        }

        if (authSignOutBtn) {
          authSignOutBtn.addEventListener("click", function () {
            if (!signedIn) return;
            var client = getSupabaseClient();
            if (!client) return;
            authSignOutBtn.disabled = true;
            client.auth.signOut().then(function () {
              setAuthUiSignedOut();
            });
          });
        }

        refreshAuthStatus();

        btn.addEventListener("click", function () {
          if (!signedIn) {
            showResult({
              ok: false,
              error: "auth_required",
              message: "未ログイン — staging 管理者でログインしてから dry-run してください",
            });
            return;
          }

          var endpoint = (body.dataset.gosakiYoutubeDryRunEndpoint || "").trim();
          var nextValue = String(input.value || "").trim();
          if (!endpoint) {
            showResult({
              ok: false,
              error: "dry-run endpoint not configured",
              hint: "PUBLIC_GOSAKI_YOUTUBE_URL_DRY_RUN_ENDPOINT or G-11c4a staging default",
            });
            return;
          }
          if (!nextValue) {
            showResult({ ok: false, error: "next YouTube URL is required" });
            return;
          }

          var payload = {
            siteSlug: "gosaki-piano",
            module: "youtube-embed",
            field: "embedCode",
            nextValue: nextValue,
            dryRun: true,
            operationId: body.dataset.g11c1OperationId || "",
            approvalId: body.dataset.g11c1ApprovalId || "",
          };

          var client = getSupabaseClient();
          if (!client) {
            showResult({
              ok: false,
              error: "auth_client_unavailable",
              message: "Supabase JS の読み込みに失敗しました",
            });
            return;
          }

          btn.disabled = true;
          result.textContent = "Dry-run リクエスト送信中…（保存されません）";

          client.auth.getSession().then(function (sessionRes) {
            var token = sessionRes.data && sessionRes.data.session && sessionRes.data.session.access_token;
            if (!token) {
              showResult({
                ok: false,
                error: "auth_required",
                message: "未ログイン — staging 管理者でログインしてから dry-run してください",
                httpStatus: 401,
              });
              setAuthUiSignedOut();
              btn.disabled = true;
              return;
            }

            var headers = { "Content-Type": "application/json", apikey: supabaseAnonKey };
            headers.Authorization = "Bearer " + token;

            fetch(endpoint, {
              method: "POST",
              headers: headers,
              body: JSON.stringify(payload),
            })
              .then(function (res) {
                return res
                  .json()
                  .then(function (data) {
                    return { status: res.status, data: data };
                  })
                  .catch(function () {
                    return { status: res.status, data: { error: "non-JSON response" } };
                  });
              })
              .then(function (out) {
                var bodyData = out.data || {};
                showResult({
                  httpStatus: out.status,
                  ok: bodyData.ok,
                  dryRun: bodyData.dryRun,
                  wouldWrite: bodyData.wouldWrite,
                  changedFields: bodyData.changedFields,
                  next: bodyData.next,
                  body: bodyData,
                });
              })
              .catch(function (err) {
                showResult({
                  ok: false,
                  error: err && err.message ? err.message : String(err),
                });
              })
              .finally(function () {
                updateDryRunButton();
              });
          });
        });
      })();
    </script>
  </body>
</html>
