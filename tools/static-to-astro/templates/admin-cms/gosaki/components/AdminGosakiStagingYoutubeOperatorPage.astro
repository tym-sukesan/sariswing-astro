---
import type { GosakiYoutubeEmbedAdminBinding } from "../../../../../../src/lib/admin/staging-data/gosaki-youtube-embed-admin-binding";
import {
  GOSAKI_STAGING_ADMIN_BASE,
  GOSAKI_STAGING_PREVIEW_URL,
} from "../gosaki-staging-admin-paths";

interface Props {
  binding: GosakiYoutubeEmbedAdminBinding;
}

const { binding } = Astro.props;
const { config, resolved, published, videoId } = binding;
const previewHomeUrl = GOSAKI_STAGING_PREVIEW_URL;
---

<section
  id="gosaki-youtube-operator"
  class="admin-gosaki-youtube-operator admin-prototype-section"
  data-section="admin-youtube"
  aria-label="YouTube設定"
>
  <header class="admin-gosaki-page-header admin-gosaki-page-header--with-actions">
    <div>
      <a class="admin-gosaki-back-link" href={GOSAKI_STAGING_ADMIN_BASE}>← 管理画面トップへ</a>
      <h1 class="admin-gosaki-page-header__title">YouTube設定</h1>
      <p class="admin-gosaki-page-header__subtitle">
        トップページに表示する YouTube 動画の設定を確認する画面です。
      </p>
    </div>
    <button
      type="button"
      class="admin-button admin-button-secondary admin-gosaki-logout-btn"
      data-staging-sign-out
      hidden
    >
      ログアウト
    </button>
  </header>

  <p class="admin-gosaki-status-bar" role="status">
    現在は確認用です。保存はまだ開放していません（設定は静的 JSON で管理）。
  </p>

  {
    binding.message ? (
      <p class="admin-gosaki-operator-alert" role="alert">{binding.message}</p>
    ) : null
  }

  <section class="admin-card admin-gosaki-card">
    <h2 class="admin-gosaki-card__title">現在の設定</h2>
    <dl class="admin-gosaki-kv-list">
      <div>
        <dt>公開状態</dt>
        <dd>{published ? "公開（設定ON）" : "非表示（未公開または未設定）"}</dd>
      </div>
      <div>
        <dt>見出し</dt>
        <dd>{config.title?.trim() || "—"}</dd>
      </div>
      <div>
        <dt>説明文</dt>
        <dd>{config.caption?.trim() || "—"}</dd>
      </div>
      <div>
        <dt>動画 ID</dt>
        <dd>{videoId || "—"}</dd>
      </div>
      <div>
        <dt>入力 URL</dt>
        <dd>{config.sourceUrl?.trim() || "—"}</dd>
      </div>
    </dl>
    <p class="admin-gosaki-config-path" role="note">
      設定ファイル: <code>{binding.configPath}</code>
    </p>
  </section>

  <section class="admin-card admin-gosaki-card">
    <h2 class="admin-gosaki-card__title">トップページでの表示</h2>
    {
      resolved ? (
        <div class="admin-gosaki-youtube-preview-note">
          <p>トップページに YouTube セクションが表示されます。</p>
          <p>
            <a href={previewHomeUrl} target="_blank" rel="noopener noreferrer">
              公開前のトップページを見る
            </a>
          </p>
        </div>
      ) : (
        <p class="admin-gosaki-operator-empty">
          動画が未設定のため、トップページには YouTube セクションは表示されません。
          <code>published: true</code> と有効な <code>videoId</code> または
          <code>sourceUrl</code> を設定すると表示されます。
        </p>
      )
    }
    <p class="admin-gosaki-save-note" role="note">
      保存はまだ開放していません。変更は設定 JSON の更新とサイト再ビルドが必要です（次フェーズ）。
    </p>
  </section>
</section>
