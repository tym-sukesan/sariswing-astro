---
/**
 * G-5z-c — Read-only data adapter status + mock/Supabase preview (staging shell only).
 */
import {
  getReadOnlyDataConfig,
  G5Z_C_APPROVAL_ID,
  G5Z_C_PHASE,
} from "../../../../../../src/lib/admin/staging-data/read-only-data-config";
import { getReadOnlyDataStatus } from "../../../../../../src/lib/admin/staging-data/read-only-data-status";
import { loadStagingReadOnlyPreview } from "../../../../../../src/lib/admin/staging-data/staging-read-only-data-loader";

interface Props {
  phase?: string;
}

const { phase = G5Z_C_PHASE } = Astro.props;

const dataConfig = getReadOnlyDataConfig();
const status = getReadOnlyDataStatus(dataConfig);
const preview = await loadStagingReadOnlyPreview(dataConfig);

const { profile, schedules, discography, links, news } = preview;

function moduleStatusClass(moduleStatus: string): string {
  if (moduleStatus === "ok") return "is-ok";
  if (moduleStatus === "empty") return "is-empty";
  if (moduleStatus === "rls-denied") return "is-rls-denied";
  if (moduleStatus === "error") return "is-error";
  return "";
}
---

<section
  class="admin-readonly-data-panel"
  id="staging-readonly-data-panel"
  role="status"
  aria-live="polite"
  data-scaffold="true"
  data-phase={phase}
  data-approval-id={G5Z_C_APPROVAL_ID}
  data-provider={status.dataProvider}
  data-ui-state={status.uiState}
>
  <h2 class="admin-readonly-data-panel__title">
    Read-only data adapter status ({phase})
  </h2>

  <p class="admin-readonly-data-panel__note">{status.uiStateNote}</p>

  <dl class="admin-readonly-data-panel__meta">
    <div>
      <dt>Approval ID</dt>
      <dd id="staging-data-approval-id">{G5Z_C_APPROVAL_ID}</dd>
    </div>
    <div>
      <dt>Provider</dt>
      <dd id="staging-data-provider">{status.dataProvider}</dd>
    </div>
    <div>
      <dt>Staging data read enabled</dt>
      <dd>{status.stagingDataReadEnabled ? "true" : "false"}</dd>
    </div>
    <div>
      <dt>Target modules</dt>
      <dd>{status.targetModules.join(" / ")}</dd>
    </div>
    <div>
      <dt>Read-only mode</dt>
      <dd>{status.readOnlyMode ? "true" : "false"}</dd>
    </div>
    <div>
      <dt>canWrite</dt>
      <dd id="staging-data-can-write">false</dd>
    </div>
    <div>
      <dt>Runtime connected</dt>
      <dd>{status.connectedToRuntime ? "true" : "false"}</dd>
    </div>
    <div>
      <dt>Production ready</dt>
      <dd>false</dd>
    </div>
    <div>
      <dt>Supabase DB query</dt>
      <dd>
        {
          status.supabaseDbQueryImplemented
            ? "enabled only in staging read mode"
            : "disabled (mock fallback)"
        }
      </dd>
    </div>
    <div>
      <dt>RLS</dt>
      <dd>reviewed externally / not modified by this kit</dd>
    </div>
    <div>
      <dt>Storage</dt>
      <dd>not connected</dd>
    </div>
    <div>
      <dt>Publish</dt>
      <dd>disabled</dd>
    </div>
    <div>
      <dt>/admin route</dt>
      <dd>not connected</dd>
    </div>
    <div>
      <dt>UI state</dt>
      <dd id="staging-data-ui-state">{status.uiState}</dd>
    </div>
  </dl>

  {
    dataConfig.configMissing ? (
      <p class="admin-readonly-data-panel__config-missing" role="alert">
        Supabase data config missing. Mock fallback active. No write operation was attempted.
      </p>
    ) : null
  }

  <div class="admin-readonly-data-panel__previews">
    <h3 class="admin-readonly-data-panel__subtitle">
      {status.dataProvider === "supabase" ? "Supabase read-only preview" : "Mock data preview"}
    </h3>
    <p class="admin-readonly-data-panel__preview-note">
      {
        status.dataProvider === "supabase"
          ? "Approved fields only. No select *. Save / delete / publish remain disabled."
          : "Fictional fixtures only. No Supabase query. Save / delete / publish remain disabled."
      }
    </p>

    <article class="admin-readonly-data-panel__preview-block">
      <h4>
        Profile preview
        <span class={`admin-readonly-data-panel__module-status ${moduleStatusClass(profile.status)}`}>
          {profile.status}
        </span>
      </h4>
      {
        profile.message ? (
          <p class="admin-readonly-data-panel__module-error">{profile.message}</p>
        ) : null
      }
      {
        profile.data ? (
          <dl>
            <div>
              <dt>Name</dt>
              <dd>{profile.data.displayName}</dd>
            </div>
            <div>
              <dt>Bio</dt>
              <dd>{profile.data.bio ?? "—"}</dd>
            </div>
          </dl>
        ) : profile.status === "empty" ? (
          <p class="admin-readonly-data-panel__empty">Empty state — no profile row</p>
        ) : null
      }
    </article>

    <article class="admin-readonly-data-panel__preview-block">
      <h4>
        Schedule preview ({schedules.data.length})
        <span class={`admin-readonly-data-panel__module-status ${moduleStatusClass(schedules.status)}`}>
          {schedules.status}
        </span>
      </h4>
      {
        schedules.message ? (
          <p class="admin-readonly-data-panel__module-error">{schedules.message}</p>
        ) : null
      }
      {
        schedules.data.length > 0 ? (
          <ul>
            {
              schedules.data.map((row) => (
                <li>
                  <strong>{row.title}</strong> — {row.date ?? "—"}
                  {row.venueName ? ` @ ${row.venueName}` : ""}
                </li>
              ))
            }
          </ul>
        ) : schedules.status === "empty" ? (
          <p class="admin-readonly-data-panel__empty">Empty state — no published schedules</p>
        ) : null
      }
    </article>

    <article class="admin-readonly-data-panel__preview-block">
      <h4>
        Discography preview ({discography.data.length})
        <span
          class={`admin-readonly-data-panel__module-status ${moduleStatusClass(discography.status)}`}
        >
          {discography.status}
        </span>
      </h4>
      {
        discography.message ? (
          <p class="admin-readonly-data-panel__module-error">{discography.message}</p>
        ) : null
      }
      {
        discography.data.length > 0 ? (
          <ul>
            {
              discography.data.map((row) => (
                <li>
                  <strong>{row.title}</strong>
                  {row.releaseDate ? ` (${row.releaseDate})` : ""}
                </li>
              ))
            }
          </ul>
        ) : discography.status === "empty" ? (
          <p class="admin-readonly-data-panel__empty">Empty state — no published discography</p>
        ) : null
      }
    </article>

    <article class="admin-readonly-data-panel__preview-block">
      <h4>
        Links preview ({links.data.length})
        <span class={`admin-readonly-data-panel__module-status ${moduleStatusClass(links.status)}`}>
          {links.status}
        </span>
      </h4>
      {
        links.message ? (
          <p class="admin-readonly-data-panel__module-error">{links.message}</p>
        ) : null
      }
      {
        links.data.length > 0 ? (
          <ul>
            {
              links.data.map((row) => (
                <li>
                  {row.label} — <code>{row.url}</code>
                </li>
              ))
            }
          </ul>
        ) : links.status === "empty" ? (
          <p class="admin-readonly-data-panel__empty">Empty state — no published links</p>
        ) : null
      }
    </article>

    <article class="admin-readonly-data-panel__preview-block">
      <h4>
        News preview ({news.data.length})
        <span class={`admin-readonly-data-panel__module-status ${moduleStatusClass(news.status)}`}>
          {news.status}
        </span>
      </h4>
      {
        news.message ? (
          <p class="admin-readonly-data-panel__module-error">{news.message}</p>
        ) : null
      }
      {
        news.data.length > 0 ? (
          <ul>
            {
              news.data.map((row) => (
                <li>
                  <strong>{row.title}</strong>
                  {row.publishedAt ? ` — ${row.publishedAt}` : ""}
                </li>
              ))
            }
          </ul>
        ) : news.status === "empty" ? (
          <p class="admin-readonly-data-panel__empty">Empty state — no published news</p>
        ) : null
      }
    </article>
  </div>
</section>

<style>
  .admin-readonly-data-panel {
    margin: 0 0 1.25rem;
    padding: 1rem 1.25rem;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    background: #f8fafc;
  }
  .admin-readonly-data-panel__title {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: #0f172a;
  }
  .admin-readonly-data-panel__note {
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
    color: #475569;
  }
  .admin-readonly-data-panel__config-missing {
    margin: 0 0 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    background: #fff7ed;
    border: 1px solid #fed7aa;
    color: #9a3412;
    font-size: 0.8125rem;
  }
  .admin-readonly-data-panel__meta {
    margin: 0 0 1rem;
    display: grid;
    gap: 0.35rem 1rem;
    grid-template-columns: max-content 1fr;
    font-size: 0.875rem;
  }
  .admin-readonly-data-panel__meta dt {
    font-weight: 600;
    color: #334155;
  }
  .admin-readonly-data-panel__meta dd {
    margin: 0;
    color: #1e293b;
  }
  .admin-readonly-data-panel__subtitle {
    margin: 0 0 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .admin-readonly-data-panel__previews {
    display: grid;
    gap: 0.75rem;
  }
  .admin-readonly-data-panel__preview-note {
    margin: 0 0 0.5rem;
    font-size: 0.8125rem;
    color: #64748b;
  }
  .admin-readonly-data-panel__preview-block {
    padding: 0.75rem;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    background: #fff;
  }
  .admin-readonly-data-panel__preview-block h4 {
    margin: 0 0 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .admin-readonly-data-panel__module-status {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    background: #f1f5f9;
    color: #64748b;
    text-transform: lowercase;
  }
  .admin-readonly-data-panel__module-status.is-ok {
    background: #dcfce7;
    color: #166534;
  }
  .admin-readonly-data-panel__module-status.is-empty {
    background: #f1f5f9;
    color: #64748b;
  }
  .admin-readonly-data-panel__module-status.is-error,
  .admin-readonly-data-panel__module-status.is-rls-denied {
    background: #fee2e2;
    color: #991b1b;
  }
  .admin-readonly-data-panel__module-error {
    margin: 0 0 0.5rem;
    font-size: 0.8125rem;
    color: #b45309;
  }
  .admin-readonly-data-panel__preview-block dl {
    margin: 0;
    display: grid;
    gap: 0.25rem 0.75rem;
    grid-template-columns: max-content 1fr;
    font-size: 0.8125rem;
  }
  .admin-readonly-data-panel__preview-block ul {
    margin: 0;
    padding-left: 1.1rem;
    font-size: 0.8125rem;
  }
  .admin-readonly-data-panel__preview-block code {
    font-size: 0.75rem;
    background: #f1f5f9;
    padding: 0.1rem 0.25rem;
    border-radius: 3px;
  }
  .admin-readonly-data-panel__empty {
    margin: 0;
    font-size: 0.8125rem;
    color: #94a3b8;
    font-style: italic;
  }
</style>
