---
/**
 * Gosaki staging read-only CMS admin (G-11b).
 * Static build-time data only — no Save / API / Supabase.
 */
import "../styles/gosaki-staging-read-only-admin.css";
import youtubeConfig from "../data/gosaki-youtube-embed.json";
import aboutConfig from "../data/gosaki-about-content.json";
import contactConfig from "../data/gosaki-contact-hubspot.json";
import {
  GOSAKI_READ_ONLY_ADMIN_MARKER,
  GOSAKI_STAGING_PREVIEW_URL,
  buildGosakiReadOnlyAdminViewModel,
} from "../lib/gosaki-staging-read-only-admin";

const dryRunEndpoint = String(
  import.meta.env.PUBLIC_GOSAKI_YOUTUBE_URL_DRY_RUN_ENDPOINT ?? "",
).trim();
const g11c1OperationId = "G-11c1-gosaki-youtube-url-web-save-dry-run-poc";
const g11c1ApprovalId = "G-11c1-youtube-url-dry-run";

const view = buildGosakiReadOnlyAdminViewModel({
  youtube: youtubeConfig,
  about: aboutConfig,
  contact: contactConfig,
});

const stagingSiteBase = String(import.meta.env.SITE ?? GOSAKI_STAGING_PREVIEW_URL).replace(/\/?$/, "/");
const adminCanonical = new URL("admin/", stagingSiteBase).href;
const robotsContent = "noindex,nofollow,noarchive";
const pageTitle = "Gosaki Piano CMS（確認用・読み取り専用）";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={robotsContent} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={adminCanonical} />
    <meta property="og:url" content={adminCanonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:type" content="website" />
  </head>
  <body
    class="gosaki-read-only-admin"
    data-gosaki-read-only-admin="true"
    data-phase="G-11c1"
    data-gosaki-youtube-dry-run-endpoint={dryRunEndpoint}
    data-gosaki-youtube-current-embed={view.youtube.sourceUrl}
    data-gosaki-youtube-current-videoid={view.youtube.videoId ?? ""}
    data-g11c1-operation-id={g11c1OperationId}
    data-g11c1-approval-id={g11c1ApprovalId}
  >
    <div class="gosaki-read-only-admin__shell">
      <header class="gosaki-read-only-admin__header">
        <a class="gosaki-read-only-admin__brand" href={adminCanonical}>Gosaki Piano CMS</a>
        <span class="gosaki-read-only-admin__badge">READ-ONLY — 保存不可</span>
      </header>

      <main class="gosaki-read-only-admin__main">
        <div class="gosaki-read-only-admin__banner" role="status">
          <strong>読み取り専用管理画面（G-11c1 dry-run 準備）</strong>
          <p class="gosaki-read-only-admin__meta">
            YouTube URL の dry-run 導線を追加しました。Save / Publish / Deploy は無効のままです。
          </p>
        </div>

        <section class="gosaki-read-only-admin__section" aria-labelledby="gra-overview">
          <h2 id="gra-overview">Site Overview</h2>
          <p class="gosaki-read-only-admin__meta"><strong>siteSlug:</strong> {view.siteSlug}</p>
          <p class="gosaki-read-only-admin__meta">
            <strong>staging URL:</strong>{" "}
            <a class="gosaki-read-only-admin__link" href={view.stagingUrl} target="_blank" rel="noopener noreferrer">
              {view.stagingUrl}
            </a>
          </p>
          <p class="gosaki-read-only-admin__meta"><strong>noindex:</strong> {view.noindex ? "yes" : "no"}</p>
          <p class="gosaki-read-only-admin__meta">{view.packageNote}</p>
        </section>

        <section class="gosaki-read-only-admin__section" aria-labelledby="gra-youtube">
          <h2 id="gra-youtube">YouTube Embed</h2>
          <div class="gosaki-read-only-admin__field">
            <label for="gra-youtube-url">YouTube URL / embedCode</label>
            <textarea id="gra-youtube-url" readonly>{view.youtube.sourceUrl}</textarea>
          </div>
          <div class="gosaki-read-only-admin__field">
            <label for="gra-youtube-videoid">videoId</label>
            <input id="gra-youtube-videoid" type="text" readonly value={view.youtube.videoId ?? "—"} />
          </div>
          <p class="gosaki-read-only-admin__meta">
            published: {view.youtube.published ? "true" : "false"}
          </p>

          <div class="gosaki-read-only-admin__dry-run" id="gra-youtube-dry-run" data-section="youtube-dry-run">
            <h3 class="gosaki-read-only-admin__meta">Dry-run（G-11c1）</h3>
            <div class="gosaki-read-only-admin__field">
              <label for="gra-youtube-next-url">next YouTube URL</label>
              <input
                id="gra-youtube-next-url"
                type="url"
                inputmode="url"
                autocomplete="off"
                placeholder="https://www.youtube.com/watch?v=..."
              />
            </div>
            <div class="gosaki-read-only-admin__actions">
              <button
                type="button"
                id="gra-youtube-dry-run-btn"
                class="gosaki-read-only-admin__btn gosaki-read-only-admin__btn--primary"
              >
                Dry-run（保存前チェック）
              </button>
            </div>
            <pre
              id="gra-youtube-dry-run-result"
              class="gosaki-read-only-admin__dry-run-result"
              aria-live="polite"
            >（Dry-run 結果はここに表示されます）</pre>
            {
              !dryRunEndpoint ? (
                <p class="gosaki-read-only-admin__meta gosaki-read-only-admin__meta--warn">
                  dry-run endpoint not configured（Edge Function 未 deploy — G-11c1）
                </p>
              ) : null
            }
          </div>

          <div class="gosaki-read-only-admin__actions">
            <button type="button" class="gosaki-read-only-admin__btn" disabled>Save（無効）</button>
          </div>
        </section>

        <section class="gosaki-read-only-admin__section" aria-labelledby="gra-about">
          <h2 id="gra-about">About</h2>
          <p class="gosaki-read-only-admin__meta">
            <strong>{view.about.profileLabel}</strong> — {view.about.profileCharCount} chars
          </p>
          <p class="gosaki-read-only-admin__meta">{view.about.profileSummary || "（内容なし）"}</p>
          <p class="gosaki-read-only-admin__meta">
            <strong>{view.about.bandsLabel}</strong> — {view.about.bandsCharCount} chars
          </p>
          <p class="gosaki-read-only-admin__meta">{view.about.bandsSummary || "（内容なし）"}</p>
          <h3 class="gosaki-read-only-admin__meta">Bands / Projects 画像（5件）</h3>
          <ul class="gosaki-read-only-admin__list">
            {
              view.about.bandImages.map((img) => (
                <li>
                  <code>{img.fileName}</code>
                  {img.bandName ? ` — ${img.bandName}` : ""}
                </li>
              ))
            }
          </ul>
          <div class="gosaki-read-only-admin__actions">
            <button type="button" class="gosaki-read-only-admin__btn" disabled>Save（無効）</button>
          </div>
        </section>

        <section class="gosaki-read-only-admin__section" aria-labelledby="gra-contact">
          <h2 id="gra-contact">Contact（HubSpot）</h2>
          <p class="gosaki-read-only-admin__meta"><strong>provider:</strong> {view.contact.provider}</p>
          <p class="gosaki-read-only-admin__meta"><strong>portalId:</strong> {view.contact.portalId}</p>
          <p class="gosaki-read-only-admin__meta"><strong>formId:</strong> {view.contact.formId}</p>
          <p class="gosaki-read-only-admin__meta"><strong>region:</strong> {view.contact.region}</p>
          <p class="gosaki-read-only-admin__meta">enabled: {view.contact.enabled ? "true" : "false"}</p>
          <div class="gosaki-read-only-admin__actions">
            <button type="button" class="gosaki-read-only-admin__btn" disabled>Save（無効）</button>
          </div>
        </section>

        <section class="gosaki-read-only-admin__section" aria-labelledby="gra-schedule">
          <h2 id="gra-schedule">Schedule</h2>
          <p class="gosaki-read-only-admin__meta"><strong>status:</strong> {view.schedule.status}</p>
          <p class="gosaki-read-only-admin__meta">{view.schedule.note}</p>
        </section>

        <div class="gosaki-read-only-admin__actions" aria-label="グローバル操作（無効）">
          <button type="button" class="gosaki-read-only-admin__btn" disabled>Save（無効）</button>
          <button type="button" class="gosaki-read-only-admin__btn" disabled>Publish（無効）</button>
          <button type="button" class="gosaki-read-only-admin__btn" disabled>Deploy（無効）</button>
        </div>
      </main>

      <footer class="gosaki-read-only-admin__footer">
        Gosaki Piano staging read-only CMS — G-11c1 YouTube dry-run local prep
      </footer>
    </div>
    <script is:inline>
      (function () {
        var btn = document.getElementById("gra-youtube-dry-run-btn");
        var input = document.getElementById("gra-youtube-next-url");
        var result = document.getElementById("gra-youtube-dry-run-result");
        var body = document.body;
        if (!btn || !input || !result || !body) return;

        function showResult(obj) {
          result.textContent = JSON.stringify(obj, null, 2);
        }

        btn.addEventListener("click", function () {
          var endpoint = (body.dataset.gosakiYoutubeDryRunEndpoint || "").trim();
          var nextValue = String(input.value || "").trim();
          if (!endpoint) {
            showResult({
              ok: false,
              error: "dry-run endpoint not configured",
              hint: "Set PUBLIC_GOSAKI_YOUTUBE_URL_DRY_RUN_ENDPOINT after Edge Function deploy",
            });
            return;
          }
          if (!nextValue) {
            showResult({ ok: false, error: "next YouTube URL is required" });
            return;
          }

          var payload = {
            siteSlug: "gosaki-piano",
            module: "youtube-embed",
            field: "embedCode",
            nextValue: nextValue,
            dryRun: true,
            operationId: body.dataset.g11c1OperationId || "",
            approvalId: body.dataset.g11c1ApprovalId || "",
          };

          btn.disabled = true;
          result.textContent = "Dry-run リクエスト送信中…";

          fetch(endpoint, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          })
            .then(function (res) {
              return res.json().then(function (data) {
                return { status: res.status, data: data };
              });
            })
            .then(function (out) {
              showResult({ httpStatus: out.status, body: out.data });
            })
            .catch(function (err) {
              showResult({
                ok: false,
                error: err && err.message ? err.message : String(err),
              });
            })
            .finally(function () {
              btn.disabled = false;
            });
        });
      })();
    </script>
  </body>
</html>
