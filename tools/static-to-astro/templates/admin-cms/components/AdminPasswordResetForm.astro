---
/**
 * CMS Kit Admin password reset form scaffold (G-5m-b).
 * No Supabase Auth or reset handler.
 */
import AdminFormField from "./AdminFormField.astro";

interface Props {
  mode?: "request" | "reset";
  title?: string;
  description?: string;
  emailLabel?: string;
  passwordLabel?: string;
  submitLabel?: string;
  disabled?: boolean;
}

const {
  mode = "request",
  title = mode === "request" ? "Forgot password" : "Reset password",
  description =
    mode === "request"
      ? "Enter your email to receive a reset link."
      : "Enter a new password for your account.",
  emailLabel = "Email",
  passwordLabel = "New password",
  submitLabel = mode === "request" ? "Send reset link" : "Update password",
  disabled = true,
} = Astro.props;
---

<form
  class="admin-password-reset-form"
  method="dialog"
  action="#"
  data-scaffold="true"
  data-auth="password-reset"
  data-mode={mode}
  onsubmit="return false;"
>
  <h2 class="admin-password-reset-form__title">{title}</h2>
  {description ? <p class="admin-password-reset-form__description">{description}</p> : null}

  {
    mode === "request" ? (
      <AdminFormField label={emailLabel} htmlFor="admin-reset-email">
        <input
          id="admin-reset-email"
          type="email"
          name="email"
          autocomplete="username"
          placeholder="admin@example.com"
          disabled={disabled}
        />
      </AdminFormField>
    ) : (
      <AdminFormField label={passwordLabel} htmlFor="admin-reset-password">
        <input
          id="admin-reset-password"
          type="password"
          name="password"
          autocomplete="new-password"
          placeholder="••••••••"
          disabled={disabled}
        />
      </AdminFormField>
    )
  }

  <div class="admin-password-reset-form__actions">
    <button class="admin-button" type="button" disabled={disabled} title="Scaffold only — no reset">
      {submitLabel}
    </button>
  </div>
</form>
