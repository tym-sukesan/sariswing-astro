---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import aboutMainFallback from "../../data/about-main.html?raw";
import { fetchSitePageBySlug, resolveSitePageHtml } from "../../lib/site-pages";

const { data: aboutPage, error } = await fetchSitePageBySlug("about");

if (error) {
  console.warn("[about] Supabase から site_pages を取得できませんでした。静的 HTML を表示します:", error.message);
}

const mainHtml = resolveSitePageHtml(aboutPage, aboutMainFallback);
---

<BaseLayout title="ABOUT | 紗理 / SARI">
  <Header />

  <main set:html={mainHtml} />

  <Footer />
</BaseLayout>
