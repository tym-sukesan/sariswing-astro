---
import type { GosakiDiscographySupabaseReadBinding } from "../../../../../../src/lib/admin/staging-data/gosaki-discography-supabase-read-binding";
import {
  G15A2_DISCOGRAPHY_PAGE_CONFIG_ELEMENT_ID,
  resolveG15a2DiscographyPageServerConfig,
} from "../../../../../../src/lib/admin/staging-write/gosaki-discography-dry-run-page-config";
import {
  G16A_DISCOGRAPHY_SAVE_PAGE_CONFIG_ELEMENT_ID,
  resolveG16aDiscographySavePageServerConfig,
} from "../../../../../../src/lib/admin/staging-write/gosaki-discography-g16a-artist-save-page-config";
import {
  G15B_DISCOGRAPHY_SAVE_PAGE_CONFIG_ELEMENT_ID,
  resolveG15bDiscographySavePageServerConfig,
} from "../../../../../../src/lib/admin/staging-write/gosaki-discography-save-page-config";
import {
  G15D_DISCOGRAPHY_SAVE_PAGE_CONFIG_ELEMENT_ID,
  resolveG15dDiscographySavePageServerConfig,
} from "../../../../../../src/lib/admin/staging-write/gosaki-discography-artist-save-page-config";
import {
  G17C_DISCOGRAPHY_SAVE_PAGE_CONFIG_ELEMENT_ID,
  resolveG17cDiscographySavePageServerConfig,
} from "../../../../../../src/lib/admin/staging-write/gosaki-discography-g17c-label-save-page-config";
import {
  G15B_DISCOGRAPHY_PURCHASE_URL_NON_DRY_RUN_APPROVAL_ID,
  G15D_DISCOGRAPHY_ARTIST_NON_DRY_RUN_APPROVAL_ID,
  G16A_DISCOGRAPHY_ARTIST_NON_DRY_RUN_APPROVAL_ID,
  G17C_DISCOGRAPHY_LABEL_NON_DRY_RUN_APPROVAL_ID,
} from "../../../../../../src/lib/admin/staging-write/discography-write-types";
import {
  G18F_DISCOGRAPHY_TRACKLIST_PAGE_CONFIG_ELEMENT_ID,
  resolveG18fDiscographyTracklistPageServerConfig,
} from "../../../../../../src/lib/admin/staging-write/gosaki-discography-g18f-tracklist-page-config";
import { G18F_TRACKLIST_DRY_RUN_APPROVAL_ID } from "../../../../../../src/lib/admin/staging-write/gosaki-discography-g18f-tracklist-types";
import {
  G18G2_DISCOGRAPHY_TRACKLIST_PAGE_CONFIG_ELEMENT_ID,
  resolveG18g2DiscographyTracklistPageServerConfig,
} from "../../../../../../src/lib/admin/staging-write/gosaki-discography-g18g2-tracklist-title-save-page-config";
import {
  G19B1_DISCOGRAPHY_TRACKLIST_PAGE_CONFIG_ELEMENT_ID,
  resolveG19b1DiscographyTracklistPageServerConfig,
} from "../../../../../../src/lib/admin/staging-write/gosaki-discography-g19b1-tracklist-generic-single-title-save-page-config";
import {
  G18G2_DISCOGRAPHY_TRACKLIST_SINGLE_TITLE_NON_DRY_RUN_APPROVAL_ID,
  G19B1_DISCOGRAPHY_TRACKLIST_GENERIC_SINGLE_TITLE_NON_DRY_RUN_APPROVAL_ID,
} from "../../../../../../src/lib/admin/staging-write/discography-tracks-write-types";
import { G16A_DRY_RUN_SLICE_APPROVAL_ID } from "../../../../../../src/lib/admin/staging-write/gosaki-discography-g16a-next-field-types";
import { G15D_DRY_RUN_SLICE_APPROVAL_ID } from "../../../../../../src/lib/admin/staging-write/gosaki-discography-next-field-types";
import AdminGosakiStagingNav from "./AdminGosakiStagingNav.astro";
import AdminGosakiStagingSafetyChips from "./AdminGosakiStagingSafetyChips.astro";
import AdminGosakiStagingDiscographyContentPanel from "./AdminGosakiStagingDiscographyContentPanel.astro";
import {
  GOSAKI_STAGING_ADMIN_BASE,
  GOSAKI_STAGING_PREVIEW_URL,
} from "../gosaki-staging-admin-paths";

interface Props {
  binding: GosakiDiscographySupabaseReadBinding;
}

const { binding } = Astro.props;
const pageConfig = resolveG15a2DiscographyPageServerConfig(import.meta.env);
const savePageConfig = resolveG15bDiscographySavePageServerConfig(import.meta.env);
const g15dSavePageConfig = resolveG15dDiscographySavePageServerConfig(import.meta.env);
const g16aSavePageConfig = resolveG16aDiscographySavePageServerConfig(import.meta.env);
const g17cSavePageConfig = resolveG17cDiscographySavePageServerConfig(import.meta.env);
const g18fTracklistPageConfig = resolveG18fDiscographyTracklistPageServerConfig(import.meta.env);
const g18g2TracklistPageConfig = resolveG18g2DiscographyTracklistPageServerConfig(import.meta.env);
const g19b1TracklistPageConfig = resolveG19b1DiscographyTracklistPageServerConfig(import.meta.env);
const saveStatusLabel = g19b1TracklistPageConfig.saveEnabled
  ? "ready_to_save"
  : g18g2TracklistPageConfig.saveEnabled
  ? "ready_to_save"
  : g17cSavePageConfig.saveEnabled
  ? "ready_to_save"
  : g16aSavePageConfig.saveEnabled
    ? "ready_to_save"
    : "disabled";
const dbWriteStatusLabel = g19b1TracklistPageConfig.saveEnabled
  ? "gated"
  : g18g2TracklistPageConfig.saveEnabled
  ? "gated"
  : g17cSavePageConfig.saveEnabled
  ? "gated"
  : g16aSavePageConfig.saveEnabled
    ? "gated"
    : "disabled";
const previewDiscographyUrl = `${GOSAKI_STAGING_PREVIEW_URL}${binding.previewPath}`;
const rowsJson = JSON.stringify(binding.rows);
const selectedRow =
  binding.rows.find((row) => row.legacy_id === "discography-002") ??
  binding.rows.find((row) => row.legacy_id === binding.selectedLegacyId) ??
  binding.rows[0] ??
  null;
const trackLines = selectedRow?.tracks.map((track) => track.title).join("\n") ?? "";
const operationalAlbums = binding.rows.map((row) => ({
  legacyId: row.legacy_id,
  title: row.title,
  artist: row.artist,
  releaseDate: row.release_date,
  label: row.label,
  catalogNumber: row.catalog_number,
  published: row.published !== false,
  coverImageUrl: row.cover_image_url,
  purchaseUrl: row.purchase_url,
  streamingUrl: row.streaming_url,
  description: row.description ?? "",
  trackListText: row.tracks.map((track) => track.title).join("\n"),
  trackCount: row.tracks.length,
  updatedAt: row.updated_at,
}));
---

<section
  id="gosaki-discography-operator"
  class="admin-gosaki-discography-operator admin-page admin-page--wide admin-prototype-section"
  data-section="admin-discography"
  data-gosaki-disc-source={binding.source}
  data-gosaki-disc-read-enabled={binding.supabaseReadEnabled ? "true" : "false"}
  data-gosaki-disc-default-legacy-id="discography-001"
  data-discography-rows={rowsJson}
  aria-label="ディスコグラフィー管理"
>
  <div
    id={G17C_DISCOGRAPHY_SAVE_PAGE_CONFIG_ELEMENT_ID}
    data-g17c-save-enabled={g17cSavePageConfig.saveEnabled ? "true" : "false"}
    data-g17c-staging-shell-enabled={g17cSavePageConfig.stagingShellEnabled ? "true" : "false"}
    data-g17c-staging-data-read-enabled={g17cSavePageConfig.stagingDataReadEnabled ? "true" : "false"}
    data-g17c-staging-write-enabled={g17cSavePageConfig.stagingWriteEnabled ? "true" : "false"}
    data-g17c-env-arm-armed={g17cSavePageConfig.envArmArmed ? "true" : "false"}
    data-g17c-optimistic-lock-enabled={g17cSavePageConfig.optimisticLockEnabled ? "true" : "false"}
    data-g17c-write-dry-run-disabled={g17cSavePageConfig.writeDryRunDisabled ? "true" : "false"}
    data-g17c-write-provider={g17cSavePageConfig.writeProvider}
    data-g17c-write-module={g17cSavePageConfig.writeModule}
    data-g17c-write-approval-id={g17cSavePageConfig.writeApprovalId || G17C_DISCOGRAPHY_LABEL_NON_DRY_RUN_APPROVAL_ID}
    hidden
  />
  <div
    id={G16A_DISCOGRAPHY_SAVE_PAGE_CONFIG_ELEMENT_ID}
    data-g16a-save-enabled={g16aSavePageConfig.saveEnabled ? "true" : "false"}
    data-g16a-staging-shell-enabled={g16aSavePageConfig.stagingShellEnabled ? "true" : "false"}
    data-g16a-staging-data-read-enabled={g16aSavePageConfig.stagingDataReadEnabled ? "true" : "false"}
    data-g16a-staging-write-enabled={g16aSavePageConfig.stagingWriteEnabled ? "true" : "false"}
    data-g16a-env-arm-armed={g16aSavePageConfig.envArmArmed ? "true" : "false"}
    data-g16a-optimistic-lock-enabled={g16aSavePageConfig.optimisticLockEnabled ? "true" : "false"}
    data-g16a-write-dry-run-disabled={g16aSavePageConfig.writeDryRunDisabled ? "true" : "false"}
    data-g16a-write-provider={g16aSavePageConfig.writeProvider}
    data-g16a-write-module={g16aSavePageConfig.writeModule}
    data-g16a-write-approval-id={g16aSavePageConfig.writeApprovalId || G16A_DISCOGRAPHY_ARTIST_NON_DRY_RUN_APPROVAL_ID}
    hidden
  />
  <div
    id={G15D_DISCOGRAPHY_SAVE_PAGE_CONFIG_ELEMENT_ID}
    data-g15d-save-enabled={g15dSavePageConfig.saveEnabled ? "true" : "false"}
    data-g15d-staging-shell-enabled={g15dSavePageConfig.stagingShellEnabled ? "true" : "false"}
    data-g15d-staging-data-read-enabled={g15dSavePageConfig.stagingDataReadEnabled ? "true" : "false"}
    data-g15d-staging-write-enabled={g15dSavePageConfig.stagingWriteEnabled ? "true" : "false"}
    data-g15d-env-arm-armed={g15dSavePageConfig.envArmArmed ? "true" : "false"}
    data-g15d-optimistic-lock-enabled={g15dSavePageConfig.optimisticLockEnabled ? "true" : "false"}
    data-g15d-write-dry-run-disabled={g15dSavePageConfig.writeDryRunDisabled ? "true" : "false"}
    data-g15d-write-provider={g15dSavePageConfig.writeProvider}
    data-g15d-write-module={g15dSavePageConfig.writeModule}
    data-g15d-write-approval-id={g15dSavePageConfig.writeApprovalId || G15D_DISCOGRAPHY_ARTIST_NON_DRY_RUN_APPROVAL_ID}
    hidden
  />
  <div
    id={G15B_DISCOGRAPHY_SAVE_PAGE_CONFIG_ELEMENT_ID}
    data-g15b-save-enabled={savePageConfig.saveEnabled ? "true" : "false"}
    data-g15b-staging-shell-enabled={savePageConfig.stagingShellEnabled ? "true" : "false"}
    data-g15b-staging-data-read-enabled={savePageConfig.stagingDataReadEnabled ? "true" : "false"}
    data-g15b-staging-write-enabled={savePageConfig.stagingWriteEnabled ? "true" : "false"}
    data-g15b-env-arm-armed={savePageConfig.envArmArmed ? "true" : "false"}
    data-g15b-optimistic-lock-enabled={savePageConfig.optimisticLockEnabled ? "true" : "false"}
    data-g15b-write-dry-run-disabled={savePageConfig.writeDryRunDisabled ? "true" : "false"}
    data-g15b-write-provider={savePageConfig.writeProvider}
    data-g15b-write-module={savePageConfig.writeModule}
    data-g15b-write-approval-id={savePageConfig.writeApprovalId || G15B_DISCOGRAPHY_PURCHASE_URL_NON_DRY_RUN_APPROVAL_ID}
    hidden
  />
  <div
    id={G19B1_DISCOGRAPHY_TRACKLIST_PAGE_CONFIG_ELEMENT_ID}
    data-g19b1-save-enabled={g19b1TracklistPageConfig.saveEnabled ? "true" : "false"}
    data-g19b1-db-write-enabled={g19b1TracklistPageConfig.dbWriteEnabled ? "true" : "false"}
    data-g19b1-dry-run-required={g19b1TracklistPageConfig.dryRunRequired ? "true" : "false"}
    data-g19b1-env-arm-armed={g19b1TracklistPageConfig.envArmArmed ? "true" : "false"}
    data-g19b1-write-approval-id={g19b1TracklistPageConfig.writeApprovalId || G19B1_DISCOGRAPHY_TRACKLIST_GENERIC_SINGLE_TITLE_NON_DRY_RUN_APPROVAL_ID}
    hidden
  />
  <div
    id={G18G2_DISCOGRAPHY_TRACKLIST_PAGE_CONFIG_ELEMENT_ID}
    data-g18g2-save-enabled={g18g2TracklistPageConfig.saveEnabled ? "true" : "false"}
    data-g18g2-db-write-enabled={g18g2TracklistPageConfig.dbWriteEnabled ? "true" : "false"}
    data-g18g2-dry-run-required={g18g2TracklistPageConfig.dryRunRequired ? "true" : "false"}
    data-g18g2-env-arm-armed={g18g2TracklistPageConfig.envArmArmed ? "true" : "false"}
    data-g18g2-write-approval-id={g18g2TracklistPageConfig.writeApprovalId || G18G2_DISCOGRAPHY_TRACKLIST_SINGLE_TITLE_NON_DRY_RUN_APPROVAL_ID}
    hidden
  />
  <div
    id={G18F_DISCOGRAPHY_TRACKLIST_PAGE_CONFIG_ELEMENT_ID}
    data-g18f-tracklist-preview-enabled={g18fTracklistPageConfig.tracklistPreviewEnabled ? "true" : "false"}
    data-g18f-save-enabled="false"
    data-g18f-db-write-enabled="false"
    data-g18f-dry-run-required={g18fTracklistPageConfig.dryRunRequired ? "true" : "false"}
    data-g18f-write-approval-id={g18fTracklistPageConfig.writeApprovalId || G18F_TRACKLIST_DRY_RUN_APPROVAL_ID}
    hidden
  />
  <div
    id={G15A2_DISCOGRAPHY_PAGE_CONFIG_ELEMENT_ID}
    data-g15a2-dry-run-preview-enabled={pageConfig.dryRunPreviewEnabled ? "true" : "false"}
    data-g15a2-save-enabled="false"
    data-g15a2-db-write-enabled="false"
    hidden
  />
  <header class="admin-gosaki-page-header admin-gosaki-page-header--with-actions">
    <div>
      <a class="admin-gosaki-back-link" href={GOSAKI_STAGING_ADMIN_BASE}>← 管理トップへ</a>
      <h1 class="admin-gosaki-page-header__title">ディスコグラフィ</h1>
      <p class="admin-gosaki-page-header__subtitle">
        作品情報の確認・編集を行う画面です。
      </p>
      <AdminGosakiStagingSafetyChips />
    </div>
    <button
      type="button"
      class="admin-button admin-button-secondary admin-gosaki-logout-btn"
      data-staging-sign-out
      hidden
    >
      ログアウト
    </button>
  </header>

  <AdminGosakiStagingNav current="discography" />

  <AdminGosakiStagingDiscographyContentPanel
    albums={operationalAlbums}
    dataSource={binding.source}
    releaseCount={binding.releaseCount}
    trackCount={binding.rows.reduce((n, row) => n + row.tracks.length, 0)}
    publicDiscographyUrl={previewDiscographyUrl}
    dryRunEndpointConfigured={false}
  />

  <details class="admin-gosaki-dev-tools" data-gosaki-admin-dev-details="true">
    <summary>開発者情報（レガシー slice dry-run / Save configs）</summary>

  <p class="admin-gosaki-status-bar admin-gosaki-status-bar--soft" role="status">
    作品情報の確認・入力ができます。「変更を確認」で内容をプレビューできます。保存が必要な場合は管理者が行います。
  </p>

  <details class="admin-gosaki-dev-tools">
    <summary>開発者向け詳細 — 読み取り・Save 状態（通常は開かないでください）</summary>
    <section class="admin-card admin-gosaki-card admin-gosaki-card--status" aria-label="読み取り状態">
    <ul class="admin-gosaki-status-list" role="list">
      <li>
        Discography Supabase read:
        <strong>{binding.supabaseReadEnabled ? "enabled" : "unavailable"}</strong>
      </li>
      <li>
        Discography dry-run Preview:
        <strong>{pageConfig.dryRunPreviewEnabled ? "enabled" : "disabled"}</strong>
      </li>
      <li>
        Save: <strong id="gosaki-disc-status-save">{saveStatusLabel}</strong>
      </li>
      <li>
        DB write: <strong id="gosaki-disc-status-db-write">{dbWriteStatusLabel}</strong>
      </li>
      <li>
        Tracklist Save adapter (G-19b1):
        <strong>{g19b1TracklistPageConfig.saveEnabled ? "armed" : "disabled"}</strong>
      </li>
      <li>
        Tracklist Save adapter (G-18g2):
        <strong>{g18g2TracklistPageConfig.saveEnabled ? "armed" : "disabled"}</strong>
      </li>
      <li>
        dry-run approvalId: <code id="gosaki-disc-status-dry-run-approval">{G19B1_DISCOGRAPHY_TRACKLIST_GENERIC_SINGLE_TITLE_NON_DRY_RUN_APPROVAL_ID}</code>
      </li>
      <li>
        Save approvalId: <code id="gosaki-disc-status-save-approval">{G19B1_DISCOGRAPHY_TRACKLIST_GENERIC_SINGLE_TITLE_NON_DRY_RUN_APPROVAL_ID}</code>
      </li>
      <li>
        target legacy_id: <code id="gosaki-disc-status-target-legacy-id">discography-004</code>
      </li>
      <li>
        changedFields: <code id="gosaki-disc-status-changed-fields">—</code>
      </li>
      <li>
        payload keys: <code id="gosaki-disc-status-payload-keys">—</code>
      </li>
      <li>
        expectedBeforeUpdatedAt: <code id="gosaki-disc-status-expected-updated-at">{selectedRow?.updated_at ?? "—"}</code>
      </li>
      <li>
        stale: <strong id="gosaki-disc-status-stale">—</strong>
      </li>
      <li>
        hostGatePassed: <strong id="gosaki-disc-status-host-gate">{binding.hostGatePassed ? "true" : "false"}</strong>
      </li>
      <li>
        saveReadiness: <strong id="gosaki-disc-status-save-readiness">—</strong>
      </li>
      <li>
        Source: <strong>{binding.source}</strong>
        {binding.supabaseHost ? ` (${binding.supabaseHost})` : ""}
      </li>
    </ul>
    {
      binding.message ? (
        <p class="admin-gosaki-operator-alert" role="status">{binding.message}</p>
      ) : null
    }
    {
      binding.hostGateWarning && !binding.hostGatePassed ? (
        <p class="admin-gosaki-operator-alert" role="alert">{binding.hostGateWarning}</p>
      ) : null
    }
  </section>
  </details>

  <section class="admin-card admin-gosaki-card">
    <h2 class="admin-gosaki-card__title">公開前ページ</h2>
    <a
      class="admin-button admin-button--menu admin-button--menu-secondary"
      href={previewDiscographyUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      Discographyページを見る
    </a>
  </section>

  <section class="admin-card admin-gosaki-card">
    <h2 class="admin-gosaki-card__title">作品を編集</h2>
    <p class="admin-gosaki-card__lead">
      選択中の作品: <code id="gosaki-disc-selected-legacy-id">{selectedRow?.legacy_id ?? "—"}</code>
      / updated_at: <code id="gosaki-disc-form-updated-at">{selectedRow?.updated_at ?? "—"}</code>
    </p>

    <form id="gosaki-disc-edit-form" class="admin-form gosaki-discography-admin-form">
      <fieldset class="admin-gosaki-form-section">
        <legend class="admin-gosaki-form-section__title">基本情報（Supabase）</legend>
        <div class="admin-form admin-form--grid">
          <label class="admin-form__field">
            <span class="admin-form__label">legacy_id</span>
            <input type="text" name="legacy_id" value={selectedRow?.legacy_id ?? ""} readonly />
          </label>
          <label class="admin-form__field">
            <span class="admin-form__label">sort_order</span>
            <input
              type="number"
              name="sort_order"
              value={selectedRow?.sort_order ?? ""}
            />
          </label>
          <label class="admin-form__field">
            <span class="admin-form__label">タイトル</span>
            <input type="text" name="title" value={selectedRow?.title ?? ""} />
          </label>
          <label class="admin-form__field">
            <span class="admin-form__label">アーティスト名</span>
            <input type="text" name="artist" value={selectedRow?.artist ?? ""} />
          </label>
          <label class="admin-form__field">
            <span class="admin-form__label">発売日 (ISO)</span>
            <input type="text" name="release_date" value={selectedRow?.release_date ?? ""} />
          </label>
          <label class="admin-form__field">
            <span class="admin-form__label">年</span>
            <input type="number" name="year" value={selectedRow?.year ?? ""} />
          </label>
          <label class="admin-form__field">
            <span class="admin-form__label">カタログ番号</span>
            <input type="text" name="catalog_number" value={selectedRow?.catalog_number ?? ""} />
          </label>
          <label class="admin-form__field">
            <span class="admin-form__label">レーベル</span>
            <input type="text" name="label" value={selectedRow?.label ?? ""} />
          </label>
          <label class="admin-form__field admin-form__field--checkbox admin-form__field--full">
            <input
              type="checkbox"
              name="published"
              checked={selectedRow?.published !== false}
            />
            <span>公開する</span>
          </label>
        </div>
      </fieldset>

      <fieldset class="admin-gosaki-form-section">
        <legend class="admin-gosaki-form-section__title">説明・リンク</legend>
        <label class="admin-form__field admin-form__field--full">
          <span class="admin-form__label">description</span>
          <textarea class="gosaki-discography-admin-textarea" name="description" rows="5"
            >{selectedRow?.description ?? ""}</textarea
          >
        </label>
        <div class="admin-form admin-form--grid">
          <label class="admin-form__field admin-form__field--full">
            <span class="admin-form__label">購入ページ URL (purchase_url)</span>
            <input type="url" name="purchase_url" value={selectedRow?.purchase_url ?? ""} />
          </label>
          <label class="admin-form__field admin-form__field--full">
            <span class="admin-form__label">ストリーミング URL (streaming_url)</span>
            <input type="url" name="streaming_url" value={selectedRow?.streaming_url ?? ""} />
          </label>
        </div>
      </fieldset>

      <fieldset class="admin-gosaki-form-section">
        <legend class="admin-gosaki-form-section__title">ジャケット画像（read-only）</legend>
        <label class="admin-form__field admin-form__field--full">
          <span class="admin-form__label">cover_image_url</span>
          <input
            type="url"
            name="cover_image_url"
            value={selectedRow?.cover_image_url ?? ""}
            readonly
          />
          <p class="admin-gosaki-field-hint" role="note">
            画像の編集は次フェーズです。今回は Supabase の URL を表示のみ。
          </p>
        </label>
      </fieldset>

      <fieldset class="admin-gosaki-form-section">
        <legend class="admin-gosaki-form-section__title">Track List</legend>
        <label class="admin-form__field admin-form__field--full">
          <span class="admin-form__label">曲名（1行 = 1曲）</span>
          <textarea
            class="gosaki-discography-admin-textarea"
            name="tracks"
            rows={selectedRow?.legacy_id === "discography-002" ? 8 : 6}
            readonly={selectedRow?.legacy_id !== "discography-002"}
          >{trackLines}</textarea>
          <p class="admin-gosaki-field-hint" role="note">
            一部の作品のみ曲リストの編集が可能です。変更後は「変更を確認」で差分を確認できます。
          </p>
        </label>
      </fieldset>
    </form>

    <div class="admin-actions">
      <button type="button" class="admin-button admin-button-secondary" id="gosaki-disc-dry-run-preview-btn">
        変更を確認
      </button>
      <button type="button" class="admin-button" id="gosaki-disc-update-btn" disabled>
        更新する（準備中）
      </button>
      <button type="button" class="admin-button admin-button-danger" data-gosaki-disc-action-disabled disabled>
        削除
      </button>
    </div>
    <p class="admin-gosaki-save-note" role="note">
      ※ 保存が必要な場合は戸山が確認して反映します。
    </p>
    <p class="admin-gosaki-save-note admin-gosaki-save-note--operator" role="note">
      現在、公開サイトへの反映は戸山が確認して行います。
    </p>

    <div id="gosaki-disc-dry-run-result" class="gosaki-disc-dry-run-result" hidden></div>
    <div id="gosaki-disc-save-result" class="gosaki-disc-save-result" hidden></div>
  </section>

  <section class="admin-card admin-gosaki-card">
    <h2 class="admin-gosaki-card__title">登録作品一覧（Supabase）</h2>
    <p class="admin-gosaki-schedule-count" role="status">{binding.releaseCount} 件</p>

    {
      binding.releaseCount === 0 ? (
        <p class="admin-gosaki-operator-empty">Supabase から作品情報を読み込めませんでした。</p>
      ) : (
        <ul id="gosaki-disc-item-list" class="admin-list gosaki-discography-admin-list">
          {
            binding.rows.map((release) => {
              const isSelected = release.legacy_id === selectedRow?.legacy_id;
              const trackText = release.tracks.map((track) => track.title).join("\n");
              return (
                <li
                  class:list={[
                    "admin-list__item",
                    "gosaki-discography-admin-item",
                    { "gosaki-discography-admin-item--selected": isSelected },
                  ]}
                  data-legacy-id={release.legacy_id}
                  data-id={release.id}
                  data-title={release.title}
                  data-artist={release.artist ?? ""}
                  data-release-date={release.release_date ?? ""}
                  data-year={release.year ?? ""}
                  data-catalog-number={release.catalog_number ?? ""}
                  data-label={release.label ?? ""}
                  data-description={release.description ?? ""}
                  data-cover-image-url={release.cover_image_url ?? ""}
                  data-purchase-url={release.purchase_url ?? ""}
                  data-streaming-url={release.streaming_url ?? ""}
                  data-sort-order={release.sort_order ?? ""}
                  data-published={release.published !== false ? "true" : "false"}
                  data-updated-at={release.updated_at ?? ""}
                  data-tracks={trackText}
                >
                  <div class="gosaki-discography-admin-item__toolbar">
                    <span class="gosaki-discography-admin-item__legacy-id">
                      <code>{release.legacy_id}</code>
                    </span>
                    <span
                      class={`gosaki-discography-admin-item__status gosaki-discography-admin-item__status--${release.published === false ? "draft" : "published"}`}
                    >
                      {release.published === false ? "非公開" : "公開"}
                    </span>
                    <span class="gosaki-discography-admin-item__sort">sort: {release.sort_order ?? "—"}</span>
                    <div class="gosaki-discography-admin-item__move-controls">
                      <button
                        type="button"
                        class="admin-button admin-button--small"
                        data-gosaki-disc-select
                      >
                        選択
                      </button>
                      <button
                        type="button"
                        class="admin-button admin-button--small"
                        data-gosaki-disc-move="up"
                        aria-label="上へ"
                        disabled
                        title="並び替え保存は次フェーズ"
                      >
                        ↑
                      </button>
                      <button
                        type="button"
                        class="admin-button admin-button--small"
                        data-gosaki-disc-move="down"
                        aria-label="下へ"
                        disabled
                        title="並び替え保存は次フェーズ"
                      >
                        ↓
                      </button>
                      <button
                        type="button"
                        class="admin-button admin-button--small"
                        data-gosaki-disc-action-disabled
                        disabled
                      >
                        更新
                      </button>
                    </div>
                  </div>

                  <article class="gosaki-discography-admin-card">
                    <div class="gosaki-discography-admin-card__media">
                      {
                        release.cover_image_url ? (
                          <img src={release.cover_image_url} alt={release.title} loading="lazy" />
                        ) : (
                          <div class="gosaki-discography-admin-card__placeholder" aria-hidden="true">
                            <span class="gosaki-discography-admin-card__placeholder-label">ジャケット画像</span>
                            <span class="gosaki-discography-admin-card__placeholder-note">なし</span>
                          </div>
                        )
                      }
                    </div>
                    <div class="gosaki-discography-admin-card__body">
                      <h3 class="gosaki-discography-admin-card__title">
                        「{release.title}」/ {release.artist ?? "—"}
                      </h3>
                      <p class="gosaki-discography-admin-card__meta">
                        {release.release_date ?? "—"}
                        {release.catalog_number ? ` / ${release.catalog_number}` : ""}
                        {release.year ? ` / ${release.year}` : ""}
                      </p>
                      {
                        release.label ? (
                          <p class="gosaki-discography-admin-card__label">{release.label}</p>
                        ) : null
                      }
                      {
                        release.description ? (
                          <p class="gosaki-discography-admin-card__notes">{release.description}</p>
                        ) : null
                      }
                      <div class="gosaki-discography-admin-card__columns">
                        <div>
                          <h4>Track List ({release.tracks.length})</h4>
                          <ul>
                            {release.tracks.map((track) => (
                              <li>
                                {track.track_number}. {track.title}
                              </li>
                            ))}
                          </ul>
                        </div>
                      </div>
                      {
                        release.purchase_url || release.streaming_url ? (
                          <div class="gosaki-discography-admin-card__purchase">
                            {
                              release.purchase_url ? (
                                <a
                                  class="gosaki-discography-admin-card__purchase-link"
                                  href={release.purchase_url}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                >
                                  purchase_url
                                </a>
                              ) : null
                            }
                            {
                              release.streaming_url ? (
                                <a
                                  class="gosaki-discography-admin-card__purchase-link"
                                  href={release.streaming_url}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                >
                                  streaming_url
                                </a>
                              ) : null
                            }
                          </div>
                        ) : null
                      }
                    </div>
                  </article>
                </li>
              );
            })
          }
        </ul>
      )
    }
  </section>
  </details>
</section>

<script>
  import "../../../../../../src/lib/admin/staging-data/gosaki-staging-discography-admin-ui.ts";
  import {
    validateDiscographyTrackListDryRun,
    buildDiscographyDryRunEndpointRequest,
    buildDiscographySaveEndpointRequest,
    sanitizeDiscographyDryRunEndpointDisplay,
    assertG20u36cDiscographyDryRunEndpointSafe,
    assertG20u41DiscographySaveEndpointSafe,
    evaluateDiscographyOperationalSaveGate,
    isDiscographySaveConflictResponse,
    G20U36C_DISCOGRAPHY_DRY_RUN_OPERATION,
    G20U41_DISCOGRAPHY_SAVE_OPERATION,
    G20U41_DISCOGRAPHY_SAVE_APPROVAL_ID,
    G20U41_DISCOGRAPHY_CONFLICT_MESSAGE,
    G20U36C_PRODUCTION_PROJECT_REF_STOP,
  } from "../../../../site-extensions/gosaki-piano/gosaki-staging-read-only-admin";
  import { initGosakiDiscographyOperationalEdit } from "../../../../site-extensions/gosaki-piano/gosaki-staging-discography-operational-edit";

  const discRoot = document.getElementById("gosaki-discography-content");
  if (discRoot instanceof HTMLElement) {
    initGosakiDiscographyOperationalEdit(discRoot, {
      validateTrackListDryRun: validateDiscographyTrackListDryRun,
      buildDryRunEndpointRequest: buildDiscographyDryRunEndpointRequest,
      buildSaveEndpointRequest: buildDiscographySaveEndpointRequest,
      sanitizeEndpointDisplay: sanitizeDiscographyDryRunEndpointDisplay,
      isSaveConflictResponse: isDiscographySaveConflictResponse,
      evaluateSaveGate: evaluateDiscographyOperationalSaveGate,
      assertDryRunEndpointSafe: assertG20u36cDiscographyDryRunEndpointSafe,
      assertSaveEndpointSafe: assertG20u41DiscographySaveEndpointSafe,
      dryRunOperation: G20U36C_DISCOGRAPHY_DRY_RUN_OPERATION,
      saveOperation: G20U41_DISCOGRAPHY_SAVE_OPERATION,
      expectedSaveApprovalId: G20U41_DISCOGRAPHY_SAVE_APPROVAL_ID,
      saveArmed: false,
      conflictMessage: G20U41_DISCOGRAPHY_CONFLICT_MESSAGE,
      productionProjectRefStop: G20U36C_PRODUCTION_PROJECT_REF_STOP,
    });
  }
</script>

