---
import type { GosakiYoutubeEmbedAdminBinding } from "../../../../../../src/lib/admin/staging-data/gosaki-youtube-embed-admin-binding";
import { GOSAKI_YOUTUBE_DEFAULT_IFRAME_TITLE } from "../../../../../../tools/static-to-astro/templates/site-extensions/gosaki-piano/gosaki-youtube-embed";
import { GOSAKI_STAGING_ADMIN_BASE } from "../gosaki-staging-admin-paths";

interface Props {
  binding: GosakiYoutubeEmbedAdminBinding;
}

const { binding } = Astro.props;
const defaultIframeTitle = GOSAKI_YOUTUBE_DEFAULT_IFRAME_TITLE;
---

<section
  id="gosaki-youtube-operator"
  class="admin-gosaki-youtube-operator admin-page admin-page--wide admin-prototype-section"
  data-section="admin-youtube"
  aria-label="YouTube設定"
>
  <header class="admin-gosaki-page-header admin-gosaki-page-header--with-actions">
    <div>
      <a class="admin-gosaki-back-link" href={GOSAKI_STAGING_ADMIN_BASE}>← 管理画面トップへ</a>
      <h1 class="admin-gosaki-page-header__title">YouTube設定</h1>
      <p class="admin-gosaki-page-header__subtitle">
        トップページに表示する YouTube 動画を管理します。
      </p>
    </div>
    <button
      type="button"
      class="admin-button admin-button-secondary admin-gosaki-logout-btn"
      data-staging-sign-out
      hidden
    >
      ログアウト
    </button>
  </header>

  <p class="admin-form__hint admin-static-notice">
    YouTube の埋め込みコードを貼り付けるだけで、トップページに動画を表示できます。
  </p>

  <p class="admin-gosaki-status-bar admin-gosaki-status-bar--soft" role="status">
    保存機能は準備中です。
  </p>

  {
    binding.message ? (
      <p class="admin-gosaki-operator-alert" role="alert">{binding.message}</p>
    ) : null
  }

  <section class="admin-card admin-gosaki-card gosaki-youtube-admin-add-card">
    <h2 class="admin-gosaki-card__title">動画を追加</h2>
    <p class="admin-gosaki-card__lead">
      YouTube の「共有」→「埋め込み」からコピーしたコードを貼り付けてください。
    </p>

    <div class="admin-form gosaki-youtube-admin-form">
      <label class="admin-form__field admin-form__field--full">
        <span class="admin-form__label">埋め込みコード</span>
        <textarea
          id="gosaki-yt-add-embed-code"
          class="gosaki-youtube-admin-embed-code gosaki-youtube-admin-embed-code--large"
          rows="10"
          placeholder="ここに埋め込みコードを貼り付け"
        ></textarea>
      </label>
      <div class="gosaki-youtube-admin-form__row">
        <label class="admin-form__field gosaki-youtube-admin-item__sort-field">
          <span class="admin-form__label">表示順</span>
          <input id="gosaki-yt-add-sort-order" type="number" value="10" step="1" />
        </label>
        <label class="admin-form__field admin-form__field--checkbox">
          <input id="gosaki-yt-add-published" type="checkbox" />
          <span>公開する</span>
        </label>
      </div>
    </div>

    <div class="gosaki-youtube-admin-preview-card">
      <h3 class="admin-gosaki-card__subtitle">プレビュー</h3>
      <div id="gosaki-yt-add-preview" class="gosaki-youtube-admin-preview">
        <p class="admin-gosaki-operator-empty">
          埋め込みコードを貼り付けると、ここに動画が表示されます。
        </p>
      </div>
    </div>

    <div class="admin-actions">
      <button type="button" class="admin-button" data-gosaki-yt-action-disabled disabled>
        追加
      </button>
    </div>
    <p class="admin-gosaki-save-note" role="note">※ 保存は準備中です</p>
  </section>

  <section class="admin-card admin-gosaki-card">
    <h2 class="admin-gosaki-card__title">登録済みの動画</h2>
    <p class="admin-gosaki-card__lead">
      数字が小さいほど上に表示されます。↑ ↓ で並び替えの見た目を確認できます。
    </p>

    <div class="admin-actions admin-actions--compact">
      <button
        type="button"
        class="admin-button admin-button-secondary"
        data-gosaki-yt-action-disabled
        disabled
      >
        並び順を保存
      </button>
    </div>
    <p class="admin-gosaki-save-note admin-gosaki-save-note--tight" role="note">
      ※ 並び順・更新・削除は準備中です
    </p>

    {
      binding.items.length === 0 ? (
        <p class="admin-gosaki-operator-empty">登録されている動画はありません。</p>
      ) : (
        <ul id="gosaki-yt-item-list" class="admin-list gosaki-youtube-admin-list">
          {
            binding.items.map((view) => (
              <li class="admin-list__item gosaki-youtube-admin-item" data-item-id={view.item.id}>
                <div class="gosaki-youtube-admin-item__sort-bar">
                  <div class="gosaki-youtube-admin-item__sort-bar-start">
                    <button type="button" class="gosaki-sort-handle" disabled aria-label="並び替え">
                      ☰
                    </button>
                    <span class="gosaki-youtube-admin-item__order">
                      表示順 {view.item.sortOrder ?? 0}
                    </span>
                    <span
                      class={`gosaki-youtube-admin-item__status gosaki-youtube-admin-item__status--${view.item.published === true ? "published" : "draft"}`}
                    >
                      {view.item.published === true ? "公開" : "非公開"}
                    </span>
                  </div>
                  <div class="gosaki-youtube-admin-item__move-controls">
                    <button
                      type="button"
                      class="admin-button admin-button--small"
                      data-gosaki-yt-move="up"
                      aria-label="上へ"
                    >
                      ↑
                    </button>
                    <button
                      type="button"
                      class="admin-button admin-button--small"
                      data-gosaki-yt-move="down"
                      aria-label="下へ"
                    >
                      ↓
                    </button>
                  </div>
                </div>

                <div class="gosaki-youtube-admin-item__preview">
                  {
                    view.resolved ? (
                      <div class="gosaki-youtube-admin-preview gosaki-youtube-admin-preview-card">
                        <div class="gosaki-youtube-admin-preview__media">
                          <iframe
                            src={view.resolved.embedUrl}
                            title={defaultIframeTitle}
                            loading="lazy"
                            allowfullscreen
                          />
                        </div>
                      </div>
                    ) : (
                      <p class="admin-gosaki-operator-empty">
                        {view.item.published
                          ? "埋め込みコードが未設定のためプレビューできません。"
                          : "非公開のためトップには表示されません。"}
                      </p>
                    )
                  }
                </div>

                <div class="gosaki-youtube-admin-item__editor">
                  <div class="admin-form gosaki-youtube-admin-form">
                    <label class="admin-form__field admin-form__field--full">
                      <span class="admin-form__label">埋め込みコード</span>
                      <textarea class="edit-embed-code gosaki-youtube-admin-embed-code" rows="8" readonly>
                        {view.item.embedCode ?? ""}
                      </textarea>
                    </label>
                    <div class="gosaki-youtube-admin-form__row">
                      <label class="admin-form__field gosaki-youtube-admin-item__sort-field">
                        <span class="admin-form__label">表示順</span>
                        <input
                          type="number"
                          class="edit-sort-order"
                          value={view.item.sortOrder ?? 0}
                          readonly
                        />
                      </label>
                      <label class="admin-form__field admin-form__field--checkbox">
                        <input type="checkbox" checked={view.item.published === true} disabled />
                        <span>公開する</span>
                      </label>
                    </div>
                  </div>
                  <div class="admin-actions">
                    <button type="button" class="admin-button" data-gosaki-yt-action-disabled disabled>
                      更新
                    </button>
                    <button
                      type="button"
                      class="admin-button admin-button-danger"
                      data-gosaki-yt-action-disabled
                      disabled
                    >
                      削除
                    </button>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>
      )
    }
  </section>
</section>

<script>
  import "../../../../../../src/lib/admin/staging-data/gosaki-staging-youtube-admin-ui.ts";
</script>
