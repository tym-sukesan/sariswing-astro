---
import { supabase } from "../lib/supabase";
import { formatNewsDate, getNewsListLink } from "../lib/news";

const { data: news, error } = await supabase
  .from("news")
  .select("date, title, slug, url, content, is_published")
  .eq("is_published", true)
  .is("deleted_at", null)
  .order("date", { ascending: false })
  .limit(3);
---

<section class="news-list">
  <h2>NEWS</h2>

  {error && <p class="news-list__error">NEWSを取得できませんでした。</p>}

  {!error && news && news.length > 0 ? (
    <ul>
      {news.map((item) => {
        const link = getNewsListLink(item);

        return (
          <li>
            {link ? (
              <a
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noopener noreferrer" : undefined}
              >
                <span>{formatNewsDate(item.date)}</span>
                <p>{item.title}</p>
              </a>
            ) : (
              <div class="news-list__static">
                <span>{formatNewsDate(item.date)}</span>
                <p>{item.title}</p>
              </div>
            )}
          </li>
        );
      })}
    </ul>
  ) : (
    !error && <p class="news-list__empty">NEWSは準備中です</p>
  )}

  <div class="top-news-more">
    <a href="/news/">VIEW ALL NEWS →</a>
  </div>
</section>

<style>
  .news-list__error,
  .news-list__empty {
    margin: 0 0 24px;
    font-size: 1.5rem;
    line-height: 1.8;
    letter-spacing: 0.08em;
    color: #666;
  }

  .top-news-more {
    margin-top: 28px;
    margin-bottom: 0;
    padding-top: 0;
    text-align: center;
  }

  .top-news-more a {
    display: inline-block;
    font-size: 1.3rem;
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #555;
    text-decoration: none;
    transition: opacity 0.25s ease;
  }

  .top-news-more a:hover {
    opacity: 0.55;
    color: #555;
  }

  @media screen and (max-width: 768px) {
    .top-news-more {
      margin-top: 24px;
    }

    .top-news-more a {
      font-size: 1.2rem;
      letter-spacing: 0.18em;
    }
  }

  .news-list__static {
    display: block;
    padding: 18px 0;
    font-size: 1.6rem;
    letter-spacing: 0.12em;
    color: #333;
  }

  .news-list__static span {
    display: inline-block;
    margin-right: 24px;
    opacity: 0.7;
  }

  .news-list__static p {
    display: inline;
    margin: 0;
    font-weight: normal;
  }
</style>
