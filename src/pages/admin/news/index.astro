---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import NewsAdminItem from "../../../components/admin/NewsAdminItem.astro";
import { fetchAllNews } from "../../../lib/news";

const { data: news, error } = await fetchAllNews();
const newsItems = news ?? [];
---

<BaseLayout title="NEWS Admin | SARI" admin>
  <main class="admin-page admin-page--wide">
    <div class="admin-page-header">
      <a class="admin-back-link" href="/admin/">← 管理画面トップ</a>
      <h1>NEWS管理</h1>
    </div>

    {error && (
      <section class="admin-card">
        <p class="admin-message">NEWS を取得できませんでした: {error.message}</p>
        <p>
          <code>scripts/supabase/news-migration.sql</code> を実行し、slug / excerpt / content などのカラムを追加してください。
        </p>
      </section>
    )}

    <section class="admin-card">
      <h2>NEWS追加</h2>

      <form id="addNewsForm" class="admin-form admin-form--grid news-admin-form">
        <div class="admin-form__row">
          <label class="admin-form__field">
            <span class="admin-form__label">日付</span>
            <input data-field="date" name="date" type="date" required />
          </label>

          <label class="admin-form__field">
            <span class="admin-form__label">カテゴリ</span>
            <input data-field="category" name="category" type="text" placeholder="TOUR / RELEASE / LIVE など" />
          </label>
        </div>

        <div class="admin-form__row">
          <label class="admin-form__field">
            <span class="admin-form__label">タイトル</span>
            <input data-field="title" name="title" type="text" required />
          </label>

          <label class="admin-form__field">
            <span class="admin-form__label">slug（詳細ページ用）</span>
            <input data-field="slug" name="slug" type="text" placeholder="例: picevo-tour-2026-summer" />
            <span class="admin-form__hint">未入力時はタイトルから自動生成（日本語のみの場合は日付ベース）</span>
          </label>
        </div>

        <div class="admin-form__row">
          <label class="admin-form__field">
            <span class="admin-form__label">リンクURL（任意）</span>
            <input data-field="url" name="url" type="text" placeholder="/discography/... または https://..." />
            <span class="admin-form__hint">
              URL を設定すると詳細ページは作らず、このリンク先へ遷移します（一覧・トップのNEWSから直接リンク）。
            </span>
          </label>

          <label class="admin-form__field">
            <span class="admin-form__label">アイキャッチ画像URL</span>
            <input data-field="image_url" name="image_url" type="text" placeholder="https://..." />
          </label>
        </div>

        <label class="admin-form__field">
          <span class="admin-form__label">抜粋</span>
          <textarea data-field="excerpt" name="excerpt" rows="2" placeholder="一覧に表示する短い文"></textarea>
        </label>

        <label class="admin-form__field admin-form__field--content">
          <span class="admin-form__label">本文（HTML可）</span>
          <textarea data-field="content" name="content" rows="12" placeholder="<p>本文</p>"></textarea>
        </label>

        <label class="admin-form__checkbox">
          <input data-field="is_published" name="is_published" type="checkbox" value="true" checked />
          <span>公開する（is_published）</span>
        </label>
      </form>

      <div class="admin-actions">
        <button id="add" class="admin-button" type="button">追加</button>
      </div>
      <p id="message" class="admin-message"></p>
    </section>

    <section class="admin-card">
      <h2>現在のNEWS</h2>

      <label class="news-admin-search">
        <span class="news-admin-search__label">検索</span>
        <input
          id="newsSearch"
          class="news-admin-search__input"
          type="search"
          placeholder="タイトル・カテゴリ・本文で検索"
          autocomplete="off"
        />
      </label>
      <p id="newsSearchStatus" class="news-admin-search__status is-hidden" aria-live="polite"></p>

      {newsItems.length > 0 ? (
        <>
          <p id="newsSearchEmpty" class="news-admin-empty is-hidden">該当するNEWSはありません。</p>
          <ul id="newsList" class="admin-list news-admin-list" data-page-size="10">
            {newsItems.map((item, index) => (
              <NewsAdminItem item={item} listIndex={index} />
            ))}
          </ul>
          {newsItems.length > 10 && (
            <button
              type="button"
              id="loadMoreNews"
              class="admin-button admin-button-secondary news-admin-load-more"
            >
              さらに表示
            </button>
          )}
        </>
      ) : (
        !error && <p class="news-admin-empty">登録されているNEWSはありません。</p>
      )}
    </section>
  </main>

  <script>
    import "../../../scripts/admin/news.ts";
  </script>
</BaseLayout>
