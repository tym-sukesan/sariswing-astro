---
/**
 * CMS Kit Admin login form scaffold (G-5m-b).
 * No Supabase Auth, fetch, or submit handler.
 */
import AdminFormField from "./AdminFormField.astro";

interface Props {
  title?: string;
  description?: string;
  emailLabel?: string;
  passwordLabel?: string;
  submitLabel?: string;
  forgotPasswordHref?: string;
  disabled?: boolean;
  interactive?: boolean;
  formId?: string;
  submitId?: string;
  readonlyNotice?: string;
}

const {
  title = "Admin login",
  description = "Sign in to manage site content.",
  emailLabel = "Email",
  passwordLabel = "Password",
  submitLabel = "Sign in",
  forgotPasswordHref = "#forgot-password",
  disabled = true,
  interactive = false,
  formId = "staging-admin-login-form",
  submitId = "staging-login-submit",
  readonlyNotice = "Scaffold only — no Supabase Auth connection.",
} = Astro.props;

const fieldsDisabled = disabled && !interactive;
const buttonDisabled = disabled && !interactive;
---

<form
  class="admin-login-form"
  id={formId}
  method="dialog"
  action="#"
  data-scaffold="true"
  data-auth="login"
  data-interactive={interactive ? "true" : "false"}
  onsubmit="return false;"
>
  <h2 class="admin-login-form__title">{title}</h2>
  {description ? <p class="admin-login-form__description">{description}</p> : null}

  {readonlyNotice ? (
    <p class="admin-readonly-notice admin-login-form__notice" role="note">
      {readonlyNotice}
    </p>
  ) : null}

  <AdminFormField label={emailLabel} htmlFor="admin-login-email">
    <input
      id="admin-login-email"
      type="email"
      name="email"
      autocomplete="username"
      placeholder="admin@example.com"
      disabled={fieldsDisabled}
    />
  </AdminFormField>

  <AdminFormField label={passwordLabel} htmlFor="admin-login-password">
    <input
      id="admin-login-password"
      type="password"
      name="password"
      autocomplete="current-password"
      placeholder="••••••••"
      disabled={fieldsDisabled}
    />
  </AdminFormField>

  <div class="admin-login-form__actions">
    <button
      class="admin-button"
      id={submitId}
      type="button"
      disabled={buttonDisabled}
      title={interactive ? "Staging Supabase Auth sign in" : "Scaffold only — no login"}
    >
      {submitLabel}
    </button>
    <a class="admin-login-form__forgot" href={forgotPasswordHref}>
      Forgot password?
    </a>
  </div>
</form>
