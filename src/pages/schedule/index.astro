---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { supabase } from "../../lib/supabase";
import { getPublishedMonthsFromSchedules } from "../../lib/schedule";

const PUBLIC_SCHEDULE_START_DATE = "2026-06-01";
const LEGACY_WP_SCHEDULE_URL = "https://sariswing.com/live-schedule/";

const { data: schedules, error } = await supabase
  .from("schedules")
  .select("date")
  .eq("is_published", true)
  .gte("date", PUBLIC_SCHEDULE_START_DATE)
  .order("date", { ascending: false });

const monthKeys = getPublishedMonthsFromSchedules(schedules);

const monthsByYear = new Map<string, string[]>();
for (const yearMonth of monthKeys) {
  const year = yearMonth.slice(0, 4);
  const months = monthsByYear.get(year) ?? [];
  months.push(yearMonth);
  monthsByYear.set(year, months);
}

const years = [...monthsByYear.keys()].sort((a, b) => b.localeCompare(a));

function monthHref(yearMonth: string) {
  return `/schedule/${yearMonth}/`;
}

function parseYearMonth(yearMonth: string) {
  const [year, month] = yearMonth.split("-");
  return { year, month: Number(month) };
}

const MONTH_NAMES_EN = [
  "JANUARY",
  "FEBRUARY",
  "MARCH",
  "APRIL",
  "MAY",
  "JUNE",
  "JULY",
  "AUGUST",
  "SEPTEMBER",
  "OCTOBER",
  "NOVEMBER",
  "DECEMBER",
] as const;

function formatMonthNameEn(month: number) {
  return MONTH_NAMES_EN[month - 1] ?? "";
}
---

<BaseLayout
  title="LIVE SCHEDULE | 紗理 / SARI"
  description="ジャズシンガー紗理（SARI）のライブ・コンサート・イベントスケジュール（年・月別）。"
  canonical="/schedule/"
>
  <Header />

  <main>
    <div id="lowerWrap">
      <h1 class="postList_title">LIVE SCHEDULE</h1>

      <div class="entry-content schedule-index">
        <p class="schedule-index__notice">
          2026年6月以降のライブスケジュールを掲載しています。2026年5月以前の過去スケジュールは旧サイトのアーカイブをご覧ください。
          <br />
          <a href={LEGACY_WP_SCHEDULE_URL} target="_blank" rel="noopener noreferrer">
            旧サイトの過去スケジュール（Live Schedule アーカイブ）
          </a>
        </p>

        {error && <p>スケジュールを取得できませんでした。</p>}

        {years.length > 0 ? (
          <div class="schedule-index__years">
            {years.map((year) => (
              <section class="schedule-index__year" aria-labelledby={`schedule-year-${year}`}>
                <h2 id={`schedule-year-${year}`} class="schedule-index__year-title">
                  {year}年
                </h2>

                <ul class="schedule-index__grid">
                  {(monthsByYear.get(year) ?? []).map((yearMonth) => {
                    const { year: cardYear, month } = parseYearMonth(yearMonth);
                    return (
                      <li class="schedule-index__item">
                        <a class="schedule-index__card" href={monthHref(yearMonth)}>
                          <span class="schedule-index__month-en" aria-hidden="true">
                            {formatMonthNameEn(month)}
                          </span>
                          <span class="schedule-index__month">{month}月</span>
                          <span class="schedule-index__detail">
                            <span class="schedule-index__label">LIVE SCHEDULE</span>
                            <span class="schedule-index__year-label">{cardYear}</span>
                          </span>
                          <span class="schedule-index__arrow" aria-hidden="true">→</span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </section>
            ))}
          </div>
        ) : (
          !error && <p>現在、公開中のスケジュールはありません。</p>
        )}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
