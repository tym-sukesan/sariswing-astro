{
  "name": "static-to-astro-tooling",
  "private": true,
  "type": "module",
  "description": "CLI tooling for static-to-astro (convert, analyze, visual-diff). Not the production Sariswing site.",
  "scripts": {
    "crawl:site": "node scripts/crawl-static-site.mjs",
    "url:staging": "node scripts/url-to-staging-pipeline.mjs",
    "visual-diff": "node scripts/visual-diff.mjs",
    "analyze-visual-diff": "node scripts/analyze-visual-diff.mjs",
    "verify:crawl": "node scripts/verify-crawl-static-site.mjs",
    "verify:url-staging": "node scripts/verify-url-to-staging-pipeline.mjs",
    "verify:gosaki-schedule-seed": "node scripts/verify-gosaki-schedule-seed-extractor.mjs",
    "verify:gosaki-font-safety": "node scripts/verify-gosaki-font-safety.mjs",
    "extract:gosaki-schedule-seed": "node scripts/extract-gosaki-schedule-seed.mjs",
    "generate:gosaki-schedule-seed-sql": "node scripts/generate-gosaki-schedules-seed-sql.mjs --out scripts/supabase/gosaki-schedules-seed.template.sql",
    "verify:ftp-deployer-safety": "node scripts/verify-public-dist-ftp-deployer-safety.mjs",
    "manual-upload:package": "node scripts/create-manual-upload-package.mjs --public-dir output/static-public/gosaki-piano/public-dist --out output/manual-upload/gosaki-piano",
    "verify:manual-upload": "node scripts/verify-manual-upload-package.mjs"
  },
  "devDependencies": {
    "pixelmatch": "^7.1.0",
    "playwright": "^1.55.0",
    "pngjs": "^7.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "cheerio": "^1.2.0"
  }
}
