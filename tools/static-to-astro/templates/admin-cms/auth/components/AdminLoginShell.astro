---
/**
 * G-5y-c / G-5y-d — Staging login UI shell.
 * G-5y-d: real Supabase Auth when env gate passes.
 */
import AdminLoginForm from "../../components/AdminLoginForm.astro";
import AdminPermissionBadge from "../../components/AdminPermissionBadge.astro";
import type { StagingAuthConfig } from "../../../../../../src/lib/admin/staging-auth/staging-auth-config";

interface Props {
  phase?: string;
  authConfig?: StagingAuthConfig | null;
  operatorMode?: boolean;
  forgotPasswordHref?: string;
  forgotPasswordLabel?: string;
}

const {
  phase = "G-5y-d",
  authConfig = null,
  operatorMode = false,
  forgotPasswordHref = "#password-reset-shell",
  forgotPasswordLabel = operatorMode ? "パスワードをお忘れですか？" : "Forgot password?",
} = Astro.props;

const interactive =
  Boolean(authConfig?.stagingAuthEnabled && authConfig?.supabaseConfigured);
const configMissing = authConfig?.configMissing ?? false;
const authMode = authConfig?.authMode ?? "mock";

const readonlyNotice = interactive
  ? `Staging Supabase Auth enabled (${authConfig?.approvalId}). Auth only — no DB, Storage, or Publish. Production Auth not touched.`
  : configMissing
    ? "Supabase Auth config missing. Login remains disabled. Set PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY locally."
    : "This login UI is staging shell only. Real Supabase Auth is disabled. Set ENABLE_ADMIN_STAGING_AUTH=true and PUBLIC_ADMIN_AUTH_PROVIDER=supabase to enable (G-5y-d).";

const readonlyNoticeJa = interactive
  ? "ステージング用 Supabase Auth が有効です。DB・Storage・Publish には接続しません。"
  : operatorMode
    ? "ログインはステージング検証用です。環境変数で Auth が無効の場合、入力しても送信されません。オペレータが ENABLE_ADMIN_STAGING_AUTH を有効にした場合のみ実ログインできます。"
    : "このログイン画面はステージング確認用です。実Authが無効な場合、入力内容は送信されません。";

const subtitle = operatorMode
  ? interactive
    ? "Gosaki Piano 管理画面 — ステージングログイン"
    : configMissing
      ? "設定不足 — ログイン無効"
      : "ステージング検証用 — 実ログインは環境設定が必要です"
  : interactive
    ? "Supabase staging Auth · G-5y-d · shell-only route"
    : configMissing
      ? "Config missing · Auth disabled"
      : "Real auth disabled · Mock auth only · Supabase Auth not connected";

const shellTitle = operatorMode ? "管理ログイン" : `Login UI shell (${phase})`;
const formTitle = operatorMode ? "Gosaki Piano 管理ログイン" : "Admin login (staging shell)";
const formDescription = operatorMode
  ? interactive
    ? "ステージング用のメールアドレスとパスワードでログインしてください。"
    : "ログインフォームの見た目確認用です。Auth が無効なときは送信されません。"
  : interactive
    ? "Sign in with staging Supabase project credentials."
    : "Preview login form layout. Enable G-5y-d env gate for real Auth.";
const submitLabel = operatorMode
  ? interactive
    ? "ログイン"
    : "ログイン（無効）"
  : interactive
    ? "Sign in"
    : "Sign in (disabled)";
---

<section
  class="admin-login-shell"
  id="login-ui-shell"
  data-scaffold="true"
  data-phase={phase}
  data-auth-mode={authMode}
>
  <header class="admin-login-shell__header">
    <h2 class="admin-login-shell__title">{shellTitle}</h2>
    <p class="admin-login-shell__subtitle">{subtitle}</p>
  </header>

  <div class="admin-login-shell__grid" class:list={{ "admin-login-shell__grid--operator": operatorMode }}>
    <div class="admin-login-shell__form-col">
      <AdminLoginForm
        title={formTitle}
        description={formDescription}
        submitLabel={submitLabel}
        forgotPasswordHref={forgotPasswordHref}
        forgotPasswordLabel={forgotPasswordLabel}
        disabled={!interactive}
        interactive={interactive}
        readonlyNotice={readonlyNotice}
      />
      <p class="admin-login-shell__ja" lang="ja">{readonlyNoticeJa}</p>
      <p id="staging-auth-error" class="admin-message admin-message--error" hidden role="alert"></p>
      {
        interactive ? (
          <div class="admin-login-shell__signout-row">
            <button
              class="admin-button admin-button--secondary"
              id="staging-sign-out-btn"
              data-staging-sign-out
              type="button"
              hidden
            >
              {operatorMode ? "ログアウト" : "Sign out"}
            </button>
          </div>
        ) : null
      }
    </div>

    {
      operatorMode ? null : (
        <aside class="admin-login-shell__aside">
      <section class="admin-login-shell__mock-panel" aria-labelledby="mock-login-title">
        <h3 id="mock-login-title" class="admin-login-shell__mock-title">
          {interactive ? "Session preview" : "Mock login preview"}
        </h3>
        <dl class="admin-login-shell__mock-list">
          <div>
            <dt>email</dt>
            <dd>{interactive ? "(signed-in user)" : "mock-admin@example.com"}</dd>
          </div>
          <div>
            <dt>role</dt>
            <dd>{interactive ? "viewer (default)" : "admin"}</dd>
          </div>
          <div>
            <dt>status</dt>
            <dd>{interactive ? "supabase-staging" : "mock"}</dd>
          </div>
          <div>
            <dt>connectedToRuntime</dt>
            <dd>{interactive ? "true" : "false"}</dd>
          </div>
          <div>
            <dt>productionReady</dt>
            <dd>false</dd>
          </div>
        </dl>
        <p class="admin-login-shell__mock-note">
          {
            interactive
              ? "Role enforcement deferred to G-5y-e. No admin_users table in G-5y-d."
              : "No credentials submitted. ENABLE_ADMIN_STAGING_AUTH=false or PUBLIC_ADMIN_AUTH_PROVIDER=mock."
          }
        </p>
      </section>

      <div class="admin-login-shell__badge-row">
        <span class="admin-login-shell__badge-label">Role badge preview</span>
        <AdminPermissionBadge variant="viewer" label="Viewer (G-5y-d default)" />
        <AdminPermissionBadge variant="editor" label="Editor" />
        <AdminPermissionBadge variant="admin" label="Admin" />
      </div>
    </aside>
      )
    }
  </div>
</section>

<style>
  .admin-login-shell {
    margin: 0 0 1.25rem;
    padding: 1.25rem;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: #fafafa;
  }
  .admin-login-shell__header {
    margin-bottom: 1rem;
  }
  .admin-login-shell__title {
    margin: 0 0 0.35rem;
    font-size: 1.125rem;
    font-weight: 700;
    color: #0f172a;
  }
  .admin-login-shell__subtitle {
    margin: 0;
    font-size: 0.875rem;
    color: #64748b;
  }
  .admin-login-shell__grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr 1fr;
  }
  .admin-login-shell__grid--operator {
    grid-template-columns: 1fr;
    max-width: 36rem;
  }
  @media (max-width: 768px) {
    .admin-login-shell__grid {
      grid-template-columns: 1fr;
    }
  }
  .admin-login-shell__ja {
    margin: 0.75rem 0 0;
    font-size: 0.8125rem;
    color: #475569;
    line-height: 1.5;
  }
  .admin-login-shell__signout-row {
    margin-top: 0.75rem;
  }
  .admin-login-shell__mock-panel {
    padding: 1rem;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    background: #f8fafc;
  }
  .admin-login-shell__mock-title {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .admin-login-shell__mock-list {
    margin: 0;
    display: grid;
    gap: 0.3rem 0.75rem;
    grid-template-columns: max-content 1fr;
    font-size: 0.875rem;
  }
  .admin-login-shell__mock-list dt {
    font-weight: 600;
    color: #475569;
  }
  .admin-login-shell__mock-list dd {
    margin: 0;
    font-family: ui-monospace, monospace;
    font-size: 0.8125rem;
  }
  .admin-login-shell__mock-note {
    margin: 0.75rem 0 0;
    font-size: 0.75rem;
    color: #64748b;
  }
  .admin-login-shell__badge-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .admin-login-shell__badge-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #475569;
    width: 100%;
  }
</style>
