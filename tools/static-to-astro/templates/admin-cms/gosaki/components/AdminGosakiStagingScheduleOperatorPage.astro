---
/**
 * Gosaki staging shell — operator-facing schedule add/edit UI (forms only; no save).
 */

import type { SiteSlugScheduleRowPickerBinding } from "../../../../../../src/lib/admin/staging-data/staging-schedule-site-slug-row-picker-binding";
import type { ScheduleRecord } from "../../../../../../src/lib/admin/staging-write/schedule-dry-run-types";
import {
  G9K_SAVE_BUTTON_PAGE_CONFIG_ELEMENT_ID,
  resolveG9kSaveButtonPageServerConfig,
} from "../../../../../../src/lib/admin/staging-write/gosaki-schedule-save-button-page-config";
import {
  G13C1_EVENT_A_POC_CLEANUP_PAGE_CONFIG_ELEMENT_ID,
  resolveG13c1EventAPocCleanupPageServerConfig,
} from "../../../../../../src/lib/admin/staging-write/gosaki-schedule-event-a-poc-cleanup-page-config";
import {
  G13C2_EVENT_B_POC_CLEANUP_PAGE_CONFIG_ELEMENT_ID,
  resolveG13c2EventBPocCleanupPageServerConfig,
} from "../../../../../../src/lib/admin/staging-write/gosaki-schedule-event-b-poc-cleanup-page-config";
import {
  GOSAKI_STAGING_ADMIN_BASE,
  GOSAKI_STAGING_PREVIEW_URL,
} from "../gosaki-staging-admin-paths";

interface Props {
  binding: SiteSlugScheduleRowPickerBinding;
}

const { binding } = Astro.props;

const g9kSaveButtonPageConfig = resolveG9kSaveButtonPageServerConfig(import.meta.env);
const g13c1PageConfig = resolveG13c1EventAPocCleanupPageServerConfig(import.meta.env);
const g13c2PageConfig = resolveG13c2EventBPocCleanupPageServerConfig(import.meta.env);

const savePrepNote = g9kSaveButtonPageConfig.saveButtonSaveEnabled
  ? "「変更を確認」で内容を確認してから「更新する」を押してください。"
  : "「変更を確認」で内容を確認できます。保存が必要な場合は戸山が代行します。";
const scheduleStatusMessage = g9kSaveButtonPageConfig.saveButtonSaveEnabled
  ? "変更内容の保存が有効です。「変更を確認」のあと「更新する」で反映できます。"
  : "公演内容の確認・入力ができます。保存が必要な場合は戸山が代行します。";

const isLive = binding.source === "supabase" && binding.selectableCount > 0;
const rowsJson = JSON.stringify(binding.selectableRows);
const monthOptions = binding.monthOptions;

function displayValue(value: string | null | undefined): string {
  const trimmed = String(value ?? "").trim();
  return trimmed || "—";
}
---

<section
  id="gosaki-schedule-operator"
  class="admin-gosaki-schedule-operator admin-page admin-page--wide admin-prototype-section gosaki-schedule-operator-primary"
  data-section="admin-schedule"
  data-read-source={binding.source}
  data-selectable-rows={rowsJson}
  data-preview-base={GOSAKI_STAGING_PREVIEW_URL}
  aria-label="スケジュール管理"
>
  <div
    id={G9K_SAVE_BUTTON_PAGE_CONFIG_ELEMENT_ID}
    data-g9k-save-button-save-enabled={g9kSaveButtonPageConfig.saveButtonSaveEnabled ? "true" : "false"}
    data-g9k-staging-shell-enabled={g9kSaveButtonPageConfig.stagingShellEnabled ? "true" : "false"}
    data-g9k-staging-write-enabled={g9kSaveButtonPageConfig.stagingWriteEnabled ? "true" : "false"}
    data-g9k-env-arm-armed={g9kSaveButtonPageConfig.envArmArmed ? "true" : "false"}
    data-g9k-legacy-env-arm-armed={g9kSaveButtonPageConfig.legacyG9kEnvArmArmed ? "true" : "false"}
    data-g9k-practical-edit-env-arm-armed={g9kSaveButtonPageConfig.practicalEditEnvArmArmed ? "true" : "false"}
    data-g9k-optimistic-lock-enabled={g9kSaveButtonPageConfig.optimisticLockEnabled ? "true" : "false"}
    data-g9k-write-dry-run-disabled={g9kSaveButtonPageConfig.writeDryRunDisabled ? "true" : "false"}
    data-g9k-write-provider={g9kSaveButtonPageConfig.writeProvider}
    data-g9k-write-module={g9kSaveButtonPageConfig.writeModule}
    data-g9k-write-approval-id={g9kSaveButtonPageConfig.writeApprovalId}
    hidden
  />
  <header class="admin-gosaki-page-header admin-gosaki-page-header--with-actions">
    <div>
      <a class="admin-gosaki-back-link" href={GOSAKI_STAGING_ADMIN_BASE}>← 管理画面トップへ</a>
      <h1 class="admin-gosaki-page-header__title">スケジュール</h1>
      <p class="admin-gosaki-page-header__subtitle">
        公演スケジュールの追加・編集を行う画面です。
      </p>
    </div>
    <button
      type="button"
      class="admin-button admin-button-secondary admin-gosaki-logout-btn"
      data-staging-sign-out
      hidden
    >
      ログアウト
    </button>
  </header>

  <p class="admin-form__hint admin-static-notice">
    公演の追加・編集ができます。公開サイトへの反映は、保存後に再生成・アップロードが必要です（戸山が代行）。
  </p>

  <p class="admin-gosaki-status-bar admin-gosaki-status-bar--soft" role="status">
    {scheduleStatusMessage}
  </p>

  <div
    id="gosaki-schedule-operator-read-source-banner"
    class="gosaki-schedule-operator-read-source-banner"
    hidden
    role="status"
  ></div>

  <aside class="gosaki-schedule-operator-guide" role="note" aria-label="通常操作の案内">
    <p class="gosaki-schedule-operator-guide__title">通常の Schedule 操作はこちら</p>
    <p class="gosaki-schedule-operator-guide__body">
      上部の<strong>公演一覧</strong>で <code>legacy_id</code> / 日付 / タイトルを確認し、「編集する」を押してください。
      非公開化は「<strong>非公開化案を作成</strong>」→「変更を確認」→「非公開化を保存」の順です。
      再公開（非公開行）は「<strong>再公開案を作成</strong>」→「変更を確認」→「再公開を保存」の順です（G-22h6b で env arm 有効化後に1回だけ）。
      ページ内検索は <code>unpublish</code> / <code>republish</code> ではなく「<strong>非公開</strong>」「<strong>再公開</strong>」を使用。
    </p>
    <p class="gosaki-schedule-operator-guide__dev-note">
      ページ下部の「開発者向け詳細」は <strong>mock / dry-run PoC 用</strong>です。Gosaki の本番運用操作では使いません。
    </p>
  </aside>

  <section class="gosaki-schedule-operator-procedure-hints" aria-label="操作手順のヒント">
    <h2 class="gosaki-schedule-operator-procedure-hints__title">操作手順のヒント</h2>
    <p class="gosaki-schedule-operator-procedure-hints__lead">
      各操作は <strong>Step 1 対象を選ぶ / 案を作成</strong> → <strong>Step 2 変更を確認</strong> →
      <strong>Step 3 戸山が確認して保存</strong> の順です。
      「変更を確認」まではDBは変わりません。保存ボタンを押すまでDBは変更されません。
    </p>
    <ul class="gosaki-schedule-operator-procedure-hints__safety">
      <li>「変更を確認」= 保存前プレビュー。DBは変わりません</li>
      <li>保存ボタンは<strong>1回だけ</strong>押してください（連打禁止）</li>
      <li>「削除（準備中）」= 現在は使いません（物理削除は未実装）</li>
    </ul>
    <div class="gosaki-schedule-operator-procedure-hints__grid">
      <article class="gosaki-schedule-operator-procedure-hints__card" data-gosaki-procedure-hint="existing-update">
        <h3 class="gosaki-schedule-operator-procedure-hints__card-title">通常更新</h3>
        <ol class="gosaki-schedule-operator-procedure-hints__steps">
          <li>公演一覧で対象を選び「編集する」</li>
          <li>内容を直して「変更を確認」</li>
          <li>戸山が確認して「更新する」</li>
        </ol>
        <p class="gosaki-schedule-operator-procedure-hints__note">「変更を確認」= 保存前プレビュー。DBは変わりません。</p>
      </article>
      <article class="gosaki-schedule-operator-procedure-hints__card" data-gosaki-procedure-hint="duplicate">
        <h3 class="gosaki-schedule-operator-procedure-hints__card-title">複製</h3>
        <ol class="gosaki-schedule-operator-procedure-hints__steps">
          <li>公演を選び「複製案を作成」</li>
          <li>内容を直して「変更を確認」</li>
          <li>戸山が確認して「複製案を保存」</li>
        </ol>
        <p class="gosaki-schedule-operator-procedure-hints__note">「複製案を作成」= 元の公演は変更しません。</p>
      </article>
      <article class="gosaki-schedule-operator-procedure-hints__card" data-gosaki-procedure-hint="new-event">
        <h3 class="gosaki-schedule-operator-procedure-hints__card-title">新規追加</h3>
        <ol class="gosaki-schedule-operator-procedure-hints__steps">
          <li>上部フォームに入力し「新規追加案を作成」</li>
          <li>内容を直して「変更を確認」</li>
          <li>戸山が確認して「新規追加を保存」</li>
        </ol>
        <p class="gosaki-schedule-operator-procedure-hints__note">「新規追加案を作成」= まだ保存されません。</p>
      </article>
      <article class="gosaki-schedule-operator-procedure-hints__card" data-gosaki-procedure-hint="unpublish">
        <h3 class="gosaki-schedule-operator-procedure-hints__card-title">非公開化</h3>
        <ol class="gosaki-schedule-operator-procedure-hints__steps">
          <li>公演を選び「非公開化案を作成」</li>
          <li>「変更を確認」</li>
          <li>戸山が確認して「非公開化を保存」</li>
        </ol>
        <p class="gosaki-schedule-operator-procedure-hints__note">「非公開化案を作成」= 行は削除しません。「非公開化を保存」= published を false にします（物理削除ではありません）。</p>
      </article>
      <article class="gosaki-schedule-operator-procedure-hints__card" data-gosaki-procedure-hint="republish">
        <h3 class="gosaki-schedule-operator-procedure-hints__card-title">再公開</h3>
        <ol class="gosaki-schedule-operator-procedure-hints__steps">
          <li>非公開行を選び「再公開案を作成」</li>
          <li>「変更を確認」</li>
          <li>「再公開を保存」— G-22h6b で env arm 有効化後に1回だけ</li>
        </ol>
        <p class="gosaki-schedule-operator-procedure-hints__note">published を false から true に戻します。保存ボタンを押すまでDBは変更されません。公開サイトへの反映は別フェーズです。</p>
      </article>
    </div>
    <aside
      id="gosaki-schedule-admin-read-procedure-hint"
      class="gosaki-schedule-operator-procedure-hints__admin-read"
      hidden
      role="note"
    >
      <p class="gosaki-schedule-operator-procedure-hints__admin-read-title">ログイン後の管理データについて</p>
      <ul class="gosaki-schedule-operator-procedure-hints__admin-read-list">
        <li>非公開行（<code>published=false</code>）も管理画面の公演一覧に表示されます</li>
        <li>「非公開のみ」フィルタで非公開行だけを絞り込めます</li>
        <li><code>legacy_id</code> キーワード検索が使えます（例: <code>schedule-2026-07-008</code>）</li>
        <li>公開サイトには非公開行は表示されません</li>
      </ul>
    </aside>
  </section>

  {
    binding.message ? (
      <p class="admin-gosaki-schedule-operator__unavailable" role="alert">
        スケジュールを読み込めませんでした。しばらくしてから再度お試しください。
      </p>
    ) : null
  }

  <section class="admin-card admin-gosaki-card gosaki-schedule-admin-add-card">
    <h2 class="admin-gosaki-card__title">新規公演の追加</h2>
    <p class="admin-gosaki-card__lead">まずここで公演の内容を入力します。</p>

    <form id="gosaki-schedule-add-form" class="admin-form admin-form--grid gosaki-schedule-admin-form" novalidate>
      <label class="admin-form__field admin-form__field--full">
        <span class="admin-form__label">日付</span>
        <input id="gosaki-add-date" type="date" />
        <p id="gosaki-add-month-hint" class="gosaki-schedule-admin-month-hint" role="note">
          日付を選ぶと、表示先の月が自動で決まります。
        </p>
      </label>

      <label class="admin-form__field admin-form__field--full">
        <span class="admin-form__label">タイトル</span>
        <input id="gosaki-add-title" type="text" placeholder="公演タイトル" />
      </label>

      <label class="admin-form__field admin-form__field--full">
        <span class="admin-form__label">会場</span>
        <input id="gosaki-add-venue" type="text" placeholder="会場名" />
      </label>

      <div class="gosaki-schedule-admin-form__row">
        <label class="admin-form__field">
          <span class="admin-form__label">開場</span>
          <input id="gosaki-add-open-time" type="text" placeholder="例: 18:00" />
        </label>
        <label class="admin-form__field">
          <span class="admin-form__label">開演</span>
          <input id="gosaki-add-start-time" type="text" placeholder="例: 19:00" />
        </label>
      </div>

      <label class="admin-form__field">
        <span class="admin-form__label">料金</span>
        <input id="gosaki-add-price" type="text" placeholder="例: 3,500 (tax in)" />
      </label>

      <label class="admin-form__field admin-form__field--full">
        <span class="admin-form__label">備考 / 説明</span>
        <textarea id="gosaki-add-description" rows="4" placeholder="出演メンバー・備考など"></textarea>
      </label>

      <label class="admin-form__field admin-form__field--checkbox">
        <input id="gosaki-add-published" type="checkbox" />
        <span>公開する</span>
      </label>

      <div class="gosaki-schedule-admin-form__row gosaki-schedule-admin-form__row--duplicate">
        <label class="admin-form__field">
          <span class="admin-form__label">複製元（任意）</span>
          <select id="gosaki-add-duplicate-source">
            <option value="">既存の公演を選ぶ</option>
            {
              binding.selectableRows.map((row: ScheduleRecord) => (
                <option value={row.id}>
                  {row.date} — {displayValue(row.legacy_id)} — {displayValue(row.title)}
                </option>
              ))
            }
          </select>
        </label>
        <div class="admin-form__field">
          <span class="admin-form__label">公開ページ</span>
          <p class="gosaki-schedule-admin-preview-link-wrap">
            <a
              id="gosaki-add-preview-link"
              href={`${GOSAKI_STAGING_PREVIEW_URL}schedule/`}
              target="_blank"
              rel="noopener noreferrer"
            >
              スケジュールページを見る
            </a>
          </p>
        </div>
      </div>
    </form>

    <div class="admin-actions">
      <button
        type="button"
        class="admin-button"
        id="gosaki-schedule-add-btn"
        title="新規追加案を作成します（保存はまだできません）"
      >
        新規追加案を作成
      </button>
    </div>
    <p class="admin-gosaki-save-note" role="note">
      ※ 新規追加案の作成と「変更を確認」ができます。保存は現在無効です。必要な場合は戸山が確認して反映します。
    </p>
  </section>

  <div class="gosaki-schedule-admin-workspace">
    <section class="admin-card admin-gosaki-card admin-gosaki-schedule-list-card gosaki-schedule-admin-list-panel">
      <h2 class="admin-gosaki-card__title">公演一覧</h2>
      <p class="admin-gosaki-card__lead">編集したい公演を選んでください。</p>

      <div class="admin-gosaki-schedule-filters">
        <label class="admin-gosaki-schedule-filters__field">
          <span class="admin-gosaki-schedule-filters__label">月</span>
          <select id="gosaki-schedule-operator-month-filter">
            <option value="all" selected>すべて</option>
            {
              monthOptions.map((month) => (
                <option value={month}>{month}</option>
              ))
            }
          </select>
        </label>
        <label class="admin-gosaki-schedule-filters__field">
          <span class="admin-gosaki-schedule-filters__label">公開状態</span>
          <select id="gosaki-schedule-operator-published-filter">
            <option value="published" selected>公開のみ</option>
            <option value="all">すべて</option>
            <option value="draft">非公開のみ</option>
          </select>
        </label>
        <label class="admin-gosaki-schedule-filters__field admin-gosaki-schedule-filters__field--grow">
          <span class="admin-gosaki-schedule-filters__label">キーワード</span>
          <input
            id="gosaki-schedule-operator-keyword"
            type="search"
            placeholder="legacy_id・タイトル・会場で検索"
            autocomplete="off"
          />
        </label>
      </div>

      <p class="admin-gosaki-schedule-count" role="status">
        <span id="gosaki-schedule-operator-filtered-count">{binding.selectableCount}</span> 件表示
      </p>

      {
        !isLive ? (
          <p class="admin-gosaki-schedule-operator__empty">
            登録済みスケジュールがありません。
          </p>
        ) : (
          <div class="gosaki-schedule-admin-list-views">
            <div class="admin-gosaki-schedule-table-wrap">
              <table class="admin-gosaki-schedule-table">
                <thead>
                  <tr>
                    <th scope="col">日付</th>
                    <th scope="col">legacy_id</th>
                    <th scope="col">タイトル</th>
                    <th scope="col">会場</th>
                    <th scope="col">開場</th>
                    <th scope="col">開演</th>
                    <th scope="col">料金</th>
                    <th scope="col" class="admin-gosaki-schedule-table__actions-col">操作</th>
                  </tr>
                </thead>
                <tbody id="gosaki-schedule-operator-table-body">
                  {
                    binding.selectableRows.map((row: ScheduleRecord) => (
                      <tr class="admin-gosaki-schedule-table__row" data-row-id={row.id}>
                        <td>{row.date}</td>
                        <td class="admin-gosaki-schedule-table__legacy-col">
                          <code class="gosaki-schedule-legacy-id-code">{displayValue(row.legacy_id)}</code>
                        </td>
                        <td class="admin-gosaki-schedule-table__title-col">{displayValue(row.title)}</td>
                        <td>{displayValue(row.venue)}</td>
                        <td>{displayValue(row.open_time)}</td>
                        <td>{displayValue(row.start_time)}</td>
                        <td>{displayValue(row.price)}</td>
                        <td class="admin-gosaki-schedule-table__actions-col">
                          <button
                            type="button"
                            class="admin-button admin-button--secondary admin-gosaki-schedule-select-btn"
                            data-select-row-id={row.id}
                          >
                            編集する
                          </button>
                        </td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
            <ul
              id="gosaki-schedule-operator-card-list"
              class="gosaki-schedule-admin-card-list"
              aria-label="公演一覧"
            ></ul>
          </div>
        )
      }
    </section>

    <section
      id="gosaki-schedule-operator-edit"
      class="admin-card admin-gosaki-card admin-gosaki-schedule-edit-card gosaki-schedule-admin-editor-panel"
      aria-live="polite"
    >
      <h2 class="admin-gosaki-card__title">選択中の公演を編集</h2>
      <p class="admin-gosaki-card__lead">一覧で選んだ公演の内容を変更します。</p>
      <div
        id="gosaki-schedule-operator-selected-summary"
        class="gosaki-schedule-operator-selected-summary"
        hidden
        aria-live="polite"
      ></div>
      <p id="gosaki-schedule-operator-edit-empty" class="admin-gosaki-schedule-edit__empty">
        一覧から「編集する」を押すと、ここに編集フォームが表示されます。
      </p>

      <form
        id="gosaki-schedule-edit-form"
        class="admin-form admin-form--grid gosaki-schedule-admin-form"
        hidden
        novalidate
      >
        <div
          id="gosaki-schedule-new-event-draft-banner"
          class="gosaki-schedule-new-event-draft-banner admin-form__field--full"
          hidden
          data-draft-mode=""
          role="status"
        >
          <p class="gosaki-schedule-new-event-draft-banner__title">新規追加案</p>
          <p class="gosaki-schedule-new-event-draft-banner__body">
            まだ保存されていません。保存は戸山が確認して反映します。
          </p>
          <p class="gosaki-schedule-new-event-draft-banner__hint">
            変更を確認すると、新規追加予定の内容を確認できます。保存は現在無効です。
          </p>
        </div>

        <div
          id="gosaki-schedule-republish-draft-banner"
          class="gosaki-schedule-republish-draft-banner admin-form__field--full"
          hidden
          data-draft-mode=""
          data-target-id=""
          data-target-legacy-id=""
          role="status"
        >
          <p class="gosaki-schedule-republish-draft-banner__title">再公開案</p>
          <p class="gosaki-schedule-republish-draft-banner__body">
            まだ保存されていません。published を false から true に戻す操作です。
          </p>
          <p class="gosaki-schedule-republish-draft-banner__hint">
            保存ボタンを押すまでDBは変更されません。公開サイトへの反映は別フェーズです。保存は G-22h6 以降で有効化されます。
          </p>
          <p class="gosaki-schedule-republish-draft-banner__target">
            対象: <code data-target-label></code>
          </p>
        </div>

        <div
          id="gosaki-schedule-unpublish-draft-banner"
          class="gosaki-schedule-unpublish-draft-banner admin-form__field--full"
          hidden
          data-draft-mode=""
          data-target-id=""
          data-target-legacy-id=""
          role="status"
        >
          <p class="gosaki-schedule-unpublish-draft-banner__title">非公開化案</p>
          <p class="gosaki-schedule-unpublish-draft-banner__body">
            まだ保存されていません。保存は戸山が確認して反映します。
          </p>
          <p class="gosaki-schedule-unpublish-draft-banner__hint">
            公開サイトから外す予定です。データベースからは削除しません。保存は現在無効です。
          </p>
          <p class="gosaki-schedule-unpublish-draft-banner__target">
            対象: <code data-target-label></code>
          </p>
        </div>

        <div
          id="gosaki-schedule-duplicate-draft-banner"
          class="gosaki-schedule-duplicate-draft-banner admin-form__field--full"
          hidden
          data-draft-mode=""
          data-source-id=""
          data-source-legacy-id=""
          role="status"
        >
          <p class="gosaki-schedule-duplicate-draft-banner__title">複製案</p>
          <p class="gosaki-schedule-duplicate-draft-banner__body">
