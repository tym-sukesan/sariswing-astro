---
/**
 * Gosaki staging shell operator portal (G-20u39b3).
 * Portal only — no content lists / forms on the home route.
 */
import AdminGosakiStagingNav from "./AdminGosakiStagingNav.astro";
import AdminGosakiStagingSafetyChips from "./AdminGosakiStagingSafetyChips.astro";
import {
  GOSAKI_STAGING_ADMIN_ABOUT_PATH,
  GOSAKI_STAGING_ADMIN_DISCOGRAPHY_PATH,
  GOSAKI_STAGING_ADMIN_SCHEDULE_PATH,
  GOSAKI_STAGING_ADMIN_YOUTUBE_PATH,
  GOSAKI_STAGING_PREVIEW_URL,
} from "../gosaki-staging-admin-paths";

interface Props {
  previewUrl?: string;
  schedulePath?: string;
}

const {
  previewUrl = GOSAKI_STAGING_PREVIEW_URL,
  schedulePath = GOSAKI_STAGING_ADMIN_SCHEDULE_PATH,
} = Astro.props;

const portalCards = [
  {
    id: "schedule",
    title: "スケジュール",
    href: schedulePath,
    statuses: [
      { label: "閲覧可能", tone: "ok" },
      { label: "dry-run可能", tone: "ok" },
    ],
    blurb: "公演の確認・入力と変更プレビュー",
  },
  {
    id: "discography",
    title: "ディスコグラフィ",
    href: GOSAKI_STAGING_ADMIN_DISCOGRAPHY_PATH,
    statuses: [
      { label: "閲覧可能", tone: "ok" },
      { label: "dry-run可能", tone: "ok" },
    ],
    blurb: "作品情報の確認・入力と変更プレビュー",
  },
  {
    id: "youtube",
    title: "YouTube",
    href: GOSAKI_STAGING_ADMIN_YOUTUBE_PATH,
    statuses: [
      { label: "閲覧可能", tone: "ok" },
      { label: "dry-run可能", tone: "ok" },
    ],
    blurb: "トップ埋め込みの確認・入力",
  },
  {
    id: "about",
    title: "プロフィール・バンド",
    href: GOSAKI_STAGING_ADMIN_ABOUT_PATH,
    statuses: [
      { label: "閲覧可能", tone: "ok" },
      { label: "dry-run可能", tone: "ok" },
    ],
    blurb: "About 本文の確認・入力",
  },
];
---

<section
  id="gosaki-home"
  class="admin-gosaki-operator-home admin-gosaki-operator-portal admin-prototype-section"
  data-section="admin-home"
  data-gosaki-admin-portal="true"
  aria-label="Gosaki Piano 管理画面トップ"
>
  <header class="admin-gosaki-page-header admin-gosaki-page-header--with-actions">
    <div>
      <h1 class="admin-gosaki-page-header__title">Gosaki Piano CMS</h1>
      <p class="admin-gosaki-page-header__subtitle">
        管理トップです。各機能の画面へ移動して内容を確認・入力できます。
      </p>
      <AdminGosakiStagingSafetyChips showSaveDisabled={false} />
    </div>
    <button
      type="button"
      class="admin-button admin-button-secondary admin-gosaki-logout-btn"
      data-staging-sign-out
      hidden
    >
      ログアウト
    </button>
  </header>

  <AdminGosakiStagingNav current="home" />

  <p class="admin-gosaki-status-bar admin-gosaki-status-bar--soft" role="status">
    内容の確認・入力はできます。公開サイトへの反映は管理者が行います。
  </p>

  <section
    class="admin-gosaki-portal-cards"
    aria-labelledby="gosaki-portal-cards-title"
    data-gosaki-portal-cards="true"
  >
    <h2 class="admin-gosaki-card__title--visually-quiet" id="gosaki-portal-cards-title">
      管理画面メニュー
    </h2>
    <ul class="admin-gosaki-portal-cards__list">
      {
        portalCards.map((card) => (
          <li class="admin-gosaki-portal-card">
            <a class="admin-gosaki-portal-card__link" href={card.href} data-portal-card={card.id}>
              <span class="admin-gosaki-portal-card__title">{card.title}</span>
              <span class="admin-gosaki-portal-card__blurb">{card.blurb}</span>
              <span class="admin-gosaki-portal-card__statuses" aria-label="機能の状態">
                {card.statuses.map((status) => (
                  <span
                    class:list={[
                      "admin-gosaki-portal-status",
                      status.tone === "ok" && "admin-gosaki-portal-status--ok",
                      status.tone === "pending" && "admin-gosaki-portal-status--pending",
                    ]}
                  >
                    {status.label}
                  </span>
                ))}
              </span>
            </a>
          </li>
        ))
      }
      <li class="admin-gosaki-portal-card admin-gosaki-portal-card--muted">
        <div class="admin-gosaki-portal-card__static" data-portal-card="publish-self">
          <span class="admin-gosaki-portal-card__title">本番反映（ご本人操作）</span>
          <span class="admin-gosaki-portal-card__blurb">公開操作のセルフサービス</span>
          <span class="admin-gosaki-portal-card__statuses">
            <span class="admin-gosaki-portal-status admin-gosaki-portal-status--pending">準備中</span>
          </span>
        </div>
      </li>
    </ul>
  </section>

  <p class="admin-gosaki-portal-preview">
    <a
      class="admin-button admin-button-secondary"
      href={previewUrl}
      target="_blank"
      rel="noopener noreferrer"
      data-gosaki-public-preview-link="true"
    >
      公開サイトを確認する
    </a>
  </p>

  <p class="admin-gosaki-field-hint admin-gosaki-portal-hint" role="note">
    「変更を確認」まではデータベースは変わりません。保存が必要な場合は管理者が確認のうえ反映します。
  </p>

  <details class="admin-gosaki-dev-tools admin-gosaki-home-supplement">
    <summary>開発者向け詳細（通常は開かないでください）</summary>
    <p class="admin-gosaki-dev-tools__note" role="note">
      STG パッケージでも同じ portal / nav / chips を使います（G-20u39b4）。
      siteSlug / build snapshot / phase ID / approval ID / PoC / dry-run JSON
      などの技術情報は各コンテンツ画面の開発者向け詳細にあります。
    </p>
  </details>
</section>
