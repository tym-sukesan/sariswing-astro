---
/**
 * Gosaki Schedule 管理 — 運用者向けヘッダー（Sariswing /admin/schedule/ 参考）。
 */
interface Props {
  homeHref?: string;
  previewUrl?: string;
}

const {
  homeHref = "#gosaki-home",
  previewUrl = "https://yskcreate.weblike.jp/cms-kit-staging/gosaki-piano/schedule/",
} = Astro.props;
---

<div class="admin-gosaki-schedule-intro" id="gosaki-schedule-intro">
  <header class="admin-gosaki-page-header admin-gosaki-page-header--with-actions">
    <div>
      <a class="admin-gosaki-back-link" href={homeHref}>← 管理画面トップへ</a>
      <h1 class="admin-gosaki-page-header__title">Schedule管理</h1>
      <p class="admin-gosaki-page-header__subtitle">
        公演スケジュールの内容を確認する画面です。
      </p>
    </div>
    <button
      type="button"
      class="admin-button admin-button-secondary admin-gosaki-logout-btn"
      data-staging-sign-out
      hidden
    >
      ログアウト
    </button>
  </header>

  <p class="admin-gosaki-status-bar" role="status">
    今は確認用です。保存はまだ開放していません。
    <a class="admin-gosaki-status-bar__link" href={previewUrl} target="_blank" rel="noopener noreferrer">
      公開前のスケジュールページを見る
    </a>
  </p>
</div>
