---
/**
 * G-5y-c / G-5y-d — Password reset UI shell. No reset email sent.
 */
import AdminPasswordResetForm from "../../components/AdminPasswordResetForm.astro";

interface Props {
  phase?: string;
}

const { phase = "G-5y-d" } = Astro.props;
---

<section
  class="admin-password-reset-shell"
  id="password-reset-shell"
  data-scaffold="true"
  data-phase={phase}
>
  <header class="admin-password-reset-shell__header">
    <h2 class="admin-password-reset-shell__title">Password reset UI shell ({phase})</h2>
    <p class="admin-password-reset-shell__notice" role="alert">
      Password reset: planned for later. No reset email is sent in {phase}.
      <code>resetPasswordForEmail</code> is not called. Production Auth is not touched.
    </p>
    <p class="admin-password-reset-shell__notice-ja" lang="ja">
      パスワードリセットメールは G-5y-d では送信されません。Supabase Auth の reset API は呼び出しません。
    </p>
  </header>

  <div class="admin-password-reset-shell__grid">
    <div id="forgot-password">
      <AdminPasswordResetForm
        mode="request"
        title="Forgot password (staging shell)"
        description="Preview forgot-password flow. Send reset email button is disabled."
        submitLabel="Send reset email (disabled)"
        disabled={true}
      />
    </div>
    <div id="reset-password-preview">
      <AdminPasswordResetForm
        mode="reset"
        title="Reset password (preview)"
        description="Preview reset-password form layout for a future callback URL."
        submitLabel="Update password (disabled)"
        disabled={true}
      />
    </div>
  </div>

  <p class="admin-password-reset-shell__future">
    Future phase: staging-only password reset email flow with callback URL on this shell route.
    Not implemented in {phase}.
  </p>
</section>

<style>
  .admin-password-reset-shell {
    margin: 0 0 1.25rem;
    padding: 1.25rem;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: #fafafa;
  }
  .admin-password-reset-shell__header {
    margin-bottom: 1rem;
  }
  .admin-password-reset-shell__title {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: #0f172a;
  }
  .admin-password-reset-shell__notice {
    margin: 0 0 0.35rem;
    font-size: 0.875rem;
    color: #b45309;
    background: #fffbeb;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    border: 1px solid #fde68a;
  }
  .admin-password-reset-shell__notice-ja {
    margin: 0 0 0.75rem;
    font-size: 0.8125rem;
    color: #475569;
  }
  .admin-password-reset-shell__grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr 1fr;
  }
  @media (max-width: 768px) {
    .admin-password-reset-shell__grid {
      grid-template-columns: 1fr;
    }
  }
  .admin-password-reset-shell__future {
    margin: 1rem 0 0;
    font-size: 0.8125rem;
    color: #64748b;
  }
</style>
