---
/**
 * G-9g1 / G-9g2 / G-9g3a / G-9g3b / G-9g3c / G-9g3d — Staging shell Gosaki site_slug schedule edit.
 */
import AdminCard from "../../components/AdminCard.astro";
import AdminFormField from "../../components/AdminFormField.astro";
import type { SiteSlugScheduleEditBinding } from "../../../../../../src/lib/admin/staging-data/staging-schedule-site-slug-edit-binding";

interface Props {
  binding: SiteSlugScheduleEditBinding;
}

const { binding } = Astro.props;

const row = binding.targetRow;
const uiDisabled = binding.source !== "supabase" || !row;
const targetRowJson = row ? JSON.stringify(row) : "";
const g9g3dSaveSectionVisible =
  binding.g9g3dArmed ||
  binding.g9g3dPocExecuted ||
  Boolean(binding.g9g3dArmFailureReason);
const legacyPoCSectionVisible = binding.legacyPoCUiVisible;
const hostAlertClass = binding.isKnownProductionHost
  ? "admin-staging-schedule-site-slug-edit__host-danger"
  : "admin-staging-schedule-site-slug-edit__host-warning";
---

<section
  id="admin-staging-schedule-site-slug-edit"
  class="admin-staging-schedule-site-slug-edit"
  data-phase={binding.phase}
  data-g9g3a-phase={binding.g9g3aPhase}
  data-g9g3b-phase={binding.g9g3bPhase}
  data-g9g3c-phase={binding.g9g3cPhase}
  data-g9g3d-phase={binding.g9g3dPhase}
  data-approval-id={binding.approvalId}
  data-g9g3b-approval-id={binding.g9g3bApprovalId}
  data-g9g3c-approval-id={binding.g9g3cApprovalId}
  data-g9g3d-approval-id={binding.g9g3dApprovalId}
  data-site-slug={binding.siteSlug}
  data-source={binding.source}
  data-dry-run-preview-only="true"
  data-actual-write="false"
  data-g9g3a-save-hidden={binding.g9g3aSaveUiHidden ? "true" : "false"}
  data-legacy-poc-ui-visible={binding.legacyPoCUiVisible ? "true" : "false"}
  data-g9g3b-armed={binding.g9g3bArmed ? "true" : "false"}
  data-g9g3b-save-enabled={binding.g9g3bSaveEnabled ? "true" : "false"}
  data-g9g3c-armed={binding.g9g3cArmed ? "true" : "false"}
  data-g9g3c-save-enabled={binding.g9g3cSaveEnabled ? "true" : "false"}
  data-g9g3d-armed={binding.g9g3dArmed ? "true" : "false"}
  data-g9g3d-save-enabled={binding.g9g3dSaveEnabled ? "true" : "false"}
  data-g9g3d-poc-executed={binding.g9g3dPocExecuted ? "true" : "false"}
  data-host-gate-passed={binding.hostGatePassed ? "true" : "false"}
  data-active-host={binding.activeHost}
  data-expected-host={binding.expectedHost}
  data-target-row={targetRowJson}
  role="region"
  aria-label="Gosaki site_slug schedule edit"
>
  <h2 class="admin-staging-schedule-site-slug-edit__title">
    Schedule site_slug general edit (G-9g3e1)
  </h2>

  <p class="admin-staging-schedule-site-slug-edit__staging-banner" role="note">
    <strong>Staging shell only</strong> — not production Sariswing <code>/admin</code>.
    Host: <code>{binding.expectedHost}</code>
  </p>

  <p
    id="site-slug-edit-production-stop"
    class="admin-staging-schedule-site-slug-edit__production-stop"
    role="alert"
    hidden={!binding.isKnownProductionHost && binding.hostGatePassed}
  >
    {
      binding.isKnownProductionHost
        ? "STOP — production Supabase host detected. All writes blocked."
        : !binding.hostGatePassed
          ? `STOP — ${binding.hostGateWarning ?? "Supabase host gate failed."}`
          : ""
    }
  </p>

  <p class="admin-staging-schedule-site-slug-edit__safety" role="note">
    <strong>Preview path never writes.</strong> Dry-run always{" "}
    <code>actualWrite=false</code>. G-9g3d general Save gated — operator manual only, not auto-clicked.
    G-9g2 / G-9g3b / G-9g3c / G-9g3d PoC Saves executed — do not re-run.
  </p>

  {
    binding.g9g3dPocExecuted ? (
      <p class="admin-staging-schedule-site-slug-edit__poc-frozen" role="alert">
        <strong>G-9g3d PoC executed — audit only.</strong> General edit non-dry-run Save is frozen.
        Operational writes deferred to G-9g3g+.
      </p>
    ) : null
  }

  <p
    id="site-slug-edit-stale-lock-banner"
    class="admin-staging-schedule-site-slug-edit__stale-lock"
    role="alert"
    hidden
  >
    STOP — optimistic lock stale. Reload row and re-run Preview before Save.
  </p>

  <p
    id="site-slug-edit-auth-banner"
    class="admin-staging-schedule-site-slug-edit__auth-checking"
    role="status"
  >
    Checking auth session…
  </p>

  {
    !binding.hostGatePassed ? (
      <p class={`admin-staging-schedule-site-slug-edit__host-alert ${hostAlertClass}`} role="alert">
        <strong>Supabase host gate failed.</strong>{" "}
        {binding.hostGateWarning ?? "Active host does not match expected staging host."}
      </p>
    ) : (
      <p class="admin-staging-schedule-site-slug-edit__host-ok" role="status">
        Host gate passed — active host matches expected staging project.
      </p>
    )
  }

  {
    binding.message ? (
      <p class="admin-staging-schedule-site-slug-edit__message" role="status">
        {binding.message}
      </p>
    ) : null
  }

  <dl class="admin-staging-schedule-site-slug-edit__summary">
    <div>
      <dt>Phase</dt>
      <dd>{binding.g9g3dPhase}</dd>
    </div>
    <div>
      <dt>G-9g3d approval ID</dt>
      <dd><code>{binding.g9g3dApprovalId}</code></dd>
    </div>
    <div>
      <dt>G-9g3c approval ID (legacy)</dt>
      <dd><code>{binding.g9g3cApprovalId}</code></dd>
    </div>
    <div>
      <dt>G-9g3b approval ID (legacy)</dt>
      <dd><code>{binding.g9g3bApprovalId}</code></dd>
    </div>
    <div>
      <dt>Site slug</dt>
      <dd><code>{binding.siteSlug}</code></dd>
    </div>
    <div>
      <dt>activeHost</dt>
      <dd><code id="site-slug-edit-active-host">{binding.activeHost}</code></dd>
    </div>
    <div>
      <dt>expectedHost</dt>
      <dd><code>{binding.expectedHost}</code></dd>
    </div>
    <div>
      <dt>hostGatePassed</dt>
      <dd id="site-slug-edit-host-gate-passed">{binding.hostGatePassed ? "true" : "false"}</dd>
    </div>
    <div>
      <dt>Data source</dt>
      <dd>{binding.source === "supabase" ? "Supabase SELECT" : "Unavailable"}</dd>
    </div>
  </dl>

  <AdminCard title="Target row" description="Fixed — id + legacy_id + site_slug scoped">
    <dl class="admin-staging-schedule-site-slug-edit__target">
      <div>
        <dt>id</dt>
        <dd><code>{binding.targetId}</code></dd>
      </div>
      <div>
        <dt>legacy_id</dt>
        <dd><code>{binding.legacyId}</code></dd>
      </div>
      <div>
        <dt>site_slug</dt>
        <dd><code>{binding.siteSlug}</code></dd>
      </div>
      <div>
        <dt>updated_at</dt>
        <dd><code id="site-slug-edit-baseline-updated-at">{row?.updated_at ?? "—"}</code></dd>
      </div>
      <div>
        <dt>date</dt>
        <dd>{row?.date ?? "—"}</dd>
      </div>
    </dl>
  </AdminCard>

  <AdminCard
    title="Edit (safe fields)"
    description="G-9g3e1 — unified general edit. Loaded DB values (read-only) vs candidate edit inputs."
  >
    <AdminFormField label="Title">
      <p class="admin-staging-schedule-site-slug-edit__loaded-value admin-staging-schedule-site-slug-edit__loaded-col">
        <span class="admin-staging-schedule-site-slug-edit__value-label">Loaded from DB (read-only):</span>{" "}
        <code id="site-slug-edit-loaded-title">{row?.title ?? "—"}</code>
      </p>
      <p class="admin-staging-schedule-site-slug-edit__candidate-label">Your edit (candidate)</p>
      <input
        id="site-slug-edit-dry-run-title"
        type="text"
        value={row?.title ?? ""}
        disabled={uiDisabled}
        autocomplete="off"
      />
    </AdminFormField>
    <AdminFormField label="Venue">
      <p class="admin-staging-schedule-site-slug-edit__loaded-value admin-staging-schedule-site-slug-edit__loaded-col">
        <span class="admin-staging-schedule-site-slug-edit__value-label">Loaded from DB (read-only):</span>{" "}
        <code id="site-slug-edit-loaded-venue">{row?.venue ?? "—"}</code>
      </p>
      <p class="admin-staging-schedule-site-slug-edit__candidate-label">Your edit (candidate)</p>
      <input
        id="site-slug-edit-dry-run-venue"
        type="text"
        value={row?.venue ?? ""}
        disabled={uiDisabled}
        autocomplete="off"
      />
    </AdminFormField>
    <AdminFormField label="Open time">
      <p class="admin-staging-schedule-site-slug-edit__loaded-value admin-staging-schedule-site-slug-edit__loaded-col">
        <span class="admin-staging-schedule-site-slug-edit__value-label">Loaded from DB (read-only):</span>{" "}
        <code id="site-slug-edit-loaded-open-time">{row?.open_time ?? "—"}</code>
      </p>
      <p class="admin-staging-schedule-site-slug-edit__candidate-label">Your edit (candidate)</p>
      <input
        id="site-slug-edit-dry-run-open-time"
        type="text"
        value={row?.open_time ?? ""}
        disabled={uiDisabled}
        autocomplete="off"
      />
    </AdminFormField>
    <AdminFormField label="Start time">
      <p class="admin-staging-schedule-site-slug-edit__loaded-value admin-staging-schedule-site-slug-edit__loaded-col">
        <span class="admin-staging-schedule-site-slug-edit__value-label">Loaded from DB (read-only):</span>{" "}
        <code id="site-slug-edit-loaded-start-time">{row?.start_time ?? "—"}</code>
      </p>
      <p class="admin-staging-schedule-site-slug-edit__candidate-label">Your edit (candidate)</p>
      <input
        id="site-slug-edit-dry-run-start-time"
        type="text"
        value={row?.start_time ?? ""}
        disabled={uiDisabled}
        autocomplete="off"
      />
    </AdminFormField>
    <AdminFormField label="Price">
      <p class="admin-staging-schedule-site-slug-edit__loaded-value admin-staging-schedule-site-slug-edit__loaded-col">
        <span class="admin-staging-schedule-site-slug-edit__value-label">Loaded from DB (read-only):</span>{" "}
        <code id="site-slug-edit-loaded-price">{row?.price ?? "—"}</code>
      </p>
      <p class="admin-staging-schedule-site-slug-edit__candidate-label">Your edit (candidate)</p>
      <input
        id="site-slug-edit-dry-run-price"
        type="text"
        value={row?.price ?? ""}
        disabled={uiDisabled}
        autocomplete="off"
      />
    </AdminFormField>
    <AdminFormField label="Description">
      <p class="admin-staging-schedule-site-slug-edit__loaded-value admin-staging-schedule-site-slug-edit__loaded-col">
        <span class="admin-staging-schedule-site-slug-edit__value-label">Loaded from DB (read-only):</span>{" "}
        <code id="site-slug-edit-loaded-description">{row?.description ?? "—"}</code>
      </p>
      <p class="admin-staging-schedule-site-slug-edit__candidate-label">Your edit (candidate)</p>
      <textarea
        id="site-slug-edit-dry-run-description"
        rows={3}
        disabled={uiDisabled}
        autocomplete="off">{row?.description ?? ""}</textarea>
    </AdminFormField>

    <div class="admin-staging-schedule-site-slug-edit__actions">
      <button
        id="site-slug-edit-dry-run-preview-btn"
        class="admin-button"
        type="button"
        disabled={uiDisabled}
        title="Client-side dry-run preview — actualWrite=false"
      >
        Preview dry-run
      </button>
      {
        g9g3dSaveSectionVisible ? (
          <button
            id="site-slug-edit-g9g3d-save-btn"
            class="admin-button admin-button--primary"
            type="button"
            disabled={true}
            title={
              binding.g9g3dPocExecuted
                ? "G-9g3d PoC executed — Save frozen"
                : "G-9g3d general edit — gated; operator manual only"
            }
          >
            {binding.g9g3dPocExecuted ? "Save general edit (frozen)" : "Save general edit"}
          </button>
        ) : null
      }
    </div>
    <p
      id="site-slug-edit-save-gate-panel"
      class="admin-staging-schedule-site-slug-edit__save-gate-panel"
      role="status"
    >
      Save gate status loading…
    </p>
    {
      g9g3dSaveSectionVisible ? (
        <p id="site-slug-edit-g9g3d-save-hint" class="admin-staging-schedule-site-slug-edit__hint" role="status">
          {binding.g9g3dPocExecuted
            ? `Save general edit disabled — General edit PoC executed — do not re-run`
            : binding.g9g3dArmFailureReason
              ? `Save general edit disabled — ${binding.g9g3dArmFailureReason}`
              : "G-9g3d — Preview dry-run required before Save."}
        </p>
      ) : (
        <p id="site-slug-edit-g9g3a-hint" class="admin-staging-schedule-site-slug-edit__hint" role="status">
          G-9g3d not armed — Preview dry-run only. Set {binding.g9g3dArmEnv}=true to expose Save.
        </p>
      )
    }
  </AdminCard>

  <AdminCard title="Dry-run result" description="Preview — actualWrite=false always">
    <div
      id="site-slug-edit-dry-run-result"
      class="site-slug-edit-dry-run-result"
      aria-live="polite"
    >
      <p class="site-slug-edit-dry-run-result__placeholder">
        Click Preview dry-run to generate a client-side preview.
      </p>
    </div>
  </AdminCard>

  {
    g9g3dSaveSectionVisible ? (
      <AdminCard title="Save result (G-9g3d)" description="Non-dry-run — operator manual only">
        <div
          id="site-slug-edit-g9g3d-save-result"
          class="site-slug-edit-save-result"
          aria-live="polite"
        >
          <p class="site-slug-edit-save-result__placeholder">
            Save not executed — operator clicks Save general edit once in execution phase.
          </p>
        </div>
      </AdminCard>
    ) : null
  }

  {
    legacyPoCSectionVisible ? (
      <details class="admin-staging-schedule-site-slug-edit__legacy-poc">
        <summary>Legacy PoC (executed — audit only)</summary>
        <p class="admin-staging-schedule-site-slug-edit__legacy-banner" role="alert">
          G-9g2 / G-9g3b / G-9g3c / G-9g3d PoC Saves executed — audit only. Do not re-run.
          Operational path deferred to G-9g3g+.
        </p>
        <div class="admin-staging-schedule-site-slug-edit__actions">
          <button
            id="site-slug-edit-g9g3d-legacy-save-btn"
            class="admin-button admin-button--primary"
            type="button"
            disabled={true}
            title="G-9g3d general edit PoC — frozen"
          >
            Save general edit PoC (frozen)
          </button>
          <button
            id="site-slug-edit-g9g3c-save-btn"
            class="admin-button admin-button--primary"
            type="button"
            disabled={true}
            title="G-9g3c time+price PoC — frozen"
          >
            Save time+price PoC (frozen)
          </button>
          <button
            id="site-slug-edit-g9g3b-save-btn"
            class="admin-button admin-button--primary"
            type="button"
            disabled={true}
            title="G-9g3b venue+description PoC — frozen"
          >
            Save venue+description PoC (frozen)
          </button>
        </div>
        <p id="site-slug-edit-g9g3d-legacy-save-hint" class="admin-staging-schedule-site-slug-edit__hint" role="status">
          G-9g3d PoC executed — do not re-run.
        </p>
        <p id="site-slug-edit-g9g3c-save-hint" class="admin-staging-schedule-site-slug-edit__hint" role="status">
          Slice PoC executed — audit only — do not re-run.
        </p>
        <p id="site-slug-edit-g9g3b-save-hint" class="admin-staging-schedule-site-slug-edit__hint" role="status">
          Slice PoC executed — audit only — do not re-run.
        </p>
        <div
          id="site-slug-edit-g9g3c-save-result"
          class="site-slug-edit-save-result"
          aria-live="polite"
        >
          <p class="site-slug-edit-save-result__placeholder">Legacy G-9g3c — not re-executed.</p>
        </div>
        <div
          id="site-slug-edit-g9g3b-save-result"
          class="site-slug-edit-save-result"
          aria-live="polite"
        >
          <p class="site-slug-edit-save-result__placeholder">Legacy G-9g3b — not re-executed.</p>
        </div>
      </details>
    ) : null
  }

  <AdminCard title="Safety flags">
    <dl class="admin-staging-schedule-site-slug-edit__flags">
      <div><dt>dryRunPreview actualWrite</dt><dd>false</dd></div>
      <div><dt>g9g3dArmed</dt><dd>{binding.g9g3dArmed ? "true" : "false"}</dd></div>
      <div><dt>g9g3dSaveEnabled</dt><dd>{binding.g9g3dSaveEnabled ? "true" : "false"}</dd></div>
      <div><dt>g9g3dPocExecuted</dt><dd>{binding.g9g3dPocExecuted ? "true" : "false"}</dd></div>
      <div><dt>legacyPoCUiVisible</dt><dd>{binding.legacyPoCUiVisible ? "true" : "false"}</dd></div>
      <div><dt>g9g3cArmed</dt><dd>{binding.g9g3cArmed ? "true" : "false"}</dd></div>
      <div><dt>g9g3bArmed</dt><dd>{binding.g9g3bArmed ? "true" : "false"}</dd></div>
      <div><dt>hostGatePassed</dt><dd>{binding.hostGatePassed ? "true" : "false"}</dd></div>
      <div><dt>restoreSaveImplemented</dt><dd>false</dd></div>
      <div><dt>writeAdapterUsed (preview)</dt><dd>false</dd></div>
      <div><dt>supabaseWriteCalled (preview)</dt><dd>false</dd></div>
    </dl>
  </AdminCard>
</section>

<script>
  import "../../../../../../src/lib/admin/staging-data/staging-schedule-site-slug-edit-ui.ts";
</script>

<style>
  .admin-staging-schedule-site-slug-edit {
    margin: 1.5rem 0 0;
    padding: 1rem;
    border: 1px solid #93c5fd;
    border-radius: 8px;
    background: #eff6ff;
  }

  .admin-staging-schedule-site-slug-edit__title {
    margin: 0 0 0.75rem;
    font-size: 1.1rem;
  }

  .admin-staging-schedule-site-slug-edit__safety,
  .admin-staging-schedule-site-slug-edit__host-alert,
  .admin-staging-schedule-site-slug-edit__host-ok {
    margin: 0 0 1rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-size: 0.9rem;
  }

  .admin-staging-schedule-site-slug-edit__safety {
    background: #dbeafe;
    border: 1px solid #93c5fd;
    color: #1e3a8a;
  }

  .admin-staging-schedule-site-slug-edit__staging-banner {
    margin: 0 0 1rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    background: #e0e7ff;
    border: 1px solid #a5b4fc;
    color: #312e81;
    font-size: 0.9rem;
  }

  .admin-staging-schedule-site-slug-edit__production-stop,
  .admin-staging-schedule-site-slug-edit__poc-frozen,
  .admin-staging-schedule-site-slug-edit__stale-lock {
    margin: 0 0 1rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    background: #fee2e2;
    border: 1px solid #fca5a5;
    color: #991b1b;
    font-size: 0.9rem;
  }

  .admin-staging-schedule-site-slug-edit__save-gate-panel {
    margin: 0.75rem 0 0;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    background: #f8fafc;
    border: 1px solid #cbd5e1;
    color: #334155;
    font-size: 0.8rem;
    line-height: 1.4;
  }

  .admin-staging-schedule-site-slug-edit__host-warning {
    background: #fef3c7;
    border: 1px solid #fcd34d;
    color: #92400e;
  }

  .admin-staging-schedule-site-slug-edit__host-danger {
    background: #fee2e2;
    border: 1px solid #fca5a5;
    color: #991b1b;
  }

  .admin-staging-schedule-site-slug-edit__host-ok {
    background: #d1fae5;
    border: 1px solid #6ee7b7;
    color: #065f46;
  }

  .admin-staging-schedule-site-slug-edit__summary,
  .admin-staging-schedule-site-slug-edit__target,
  .admin-staging-schedule-site-slug-edit__flags {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(10rem, 1fr));
    gap: 0.75rem 1rem;
    margin: 0;
    font-size: 0.9rem;
  }

  .admin-staging-schedule-site-slug-edit__summary dt,
  .admin-staging-schedule-site-slug-edit__target dt,
  .admin-staging-schedule-site-slug-edit__flags dt {
    font-weight: 600;
    color: #64748b;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .admin-staging-schedule-site-slug-edit__summary dd,
  .admin-staging-schedule-site-slug-edit__target dd,
  .admin-staging-schedule-site-slug-edit__flags dd {
    margin: 0.15rem 0 0;
  }

  .admin-staging-schedule-site-slug-edit__message,
  .admin-staging-schedule-site-slug-edit__hint,
  .admin-staging-schedule-site-slug-edit__loaded-value {
    margin: 0.5rem 0 0;
    font-size: 0.875rem;
    color: #475569;
  }

  .admin-staging-schedule-site-slug-edit__loaded-value code {
    word-break: break-all;
  }

  .admin-staging-schedule-site-slug-edit__loaded-col {
    padding: 0.35rem 0.5rem;
    border-radius: 4px;
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
  }

  .admin-staging-schedule-site-slug-edit__candidate-label {
    margin: 0.35rem 0 0.15rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .admin-staging-schedule-site-slug-edit__auth-badge {
    display: inline-block;
    margin-right: 0.35rem;
    padding: 0.1rem 0.45rem;
    border-radius: 4px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .admin-staging-schedule-site-slug-edit__auth-badge--ok {
    background: #065f46;
    color: #ecfdf5;
