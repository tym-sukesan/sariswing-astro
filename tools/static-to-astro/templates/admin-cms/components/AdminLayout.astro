---
/**
 * CMS Kit Admin UI shell — layout scaffold (G-5l).
 * Not connected to runtime. No Auth / Supabase / Publish.
 */
import "../styles/admin.css";

interface Props {
  title: string;
  siteName?: string;
  currentSection?: string;
  stagingLabel?: string;
  brandHref?: string;
}

const {
  title,
  siteName = "CMS Kit Admin",
  currentSection = "",
  stagingLabel = "Scaffold only",
  brandHref = "#",
} = Astro.props;

const fullTitle = currentSection ? `${title} | ${siteName}` : `${siteName} | ${title}`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{fullTitle}</title>
  </head>
  <body class="admin-body">
    <div class="admin-shell">
      <header class="admin-header">
        <a class="admin-header__brand" href={brandHref}>{siteName}</a>
        <div class="admin-header__meta">
          <slot name="nav" />
          {stagingLabel ? <span class="admin-badge">{stagingLabel}</span> : null}
        </div>
      </header>

      <div class="admin-main">
        <slot name="status" />
        <slot />
      </div>

      <footer class="admin-footer">
        CMS Kit Admin UI scaffold (G-5l) — not connected to runtime.
      </footer>
    </div>
  </body>
</html>
