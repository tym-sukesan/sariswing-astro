    {showClientScript ? (
      <>
      <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.49.1/dist/umd/supabase.js"></script>
    <script is:inline>
      (function () {
        var body = document.body;
        // Auth wiring must not depend on YouTube dry-run DOM (G-20u36e login-blocked tools-draft)
        if (!body) return;

        var authStatus = document.getElementById("gra-auth-status");
        var authLoginForm = document.getElementById("gra-auth-login-form");
        var authSignedIn = document.getElementById("gra-auth-signed-in");
        var authSignInBtn = document.getElementById("gra-auth-sign-in-btn");
        var authSignOutBtn = document.getElementById("gra-auth-sign-out-btn");
        var authEmail = document.getElementById("gra-auth-email");
        var authPassword = document.getElementById("gra-auth-password");

        var supabaseUrl = (body.dataset.gosakiSupabaseUrl || "").trim();
        var supabaseAnonKey = (body.dataset.gosakiSupabaseAnonKey || "").trim();
        var supabaseAuthConfigured = body.dataset.gosakiSupabaseAuthConfigured === "true";
        var supabaseClient = null;
        var signedIn = false;

        function resolveCreateClient() {
          var lib = window.supabase;
          if (!lib) return null;
          if (typeof lib.createClient === "function") return lib.createClient;
          if (lib.default && typeof lib.default.createClient === "function") return lib.default.createClient;
          return null;
        }

        function getSupabaseClient() {
          if (!supabaseAuthConfigured || !supabaseUrl || !supabaseAnonKey) return null;
          var createClient = resolveCreateClient();
          if (!createClient) return null;
          if (!supabaseClient) {
            supabaseClient = createClient(supabaseUrl, supabaseAnonKey, {
              auth: {
                persistSession: true,
                autoRefreshToken: true,
                detectSessionInUrl: false,
              },
            });
          }
          return supabaseClient;
        }

        function updateLoginButton() {
          if (!authSignInBtn) return;
          // Enable only when Auth configured and signed out — no Save / probe coupling
          if (!supabaseAuthConfigured || signedIn) {
            authSignInBtn.disabled = true;
            return;
          }
          authSignInBtn.disabled = false;
        }

        function updateSignOutButton() {
          if (!authSignOutBtn) return;
          authSignOutBtn.disabled = !signedIn;
        }

        function setAuthUiSignedIn(email) {
          signedIn = true;
          if (authStatus) {
            authStatus.textContent = "ログイン済み" + (email ? " — " + email : "");
            var badge = document.getElementById("gra-auth-signed-badge");
            if (badge) badge.textContent = "ログイン済み";
          }
          if (authLoginForm) authLoginForm.hidden = true;
          if (authSignedIn) authSignedIn.hidden = false;
          updateLoginButton();
          updateSignOutButton();
          try {
            window.dispatchEvent(new CustomEvent("gosaki-admin-auth-changed", { detail: { signedIn: true } }));
          } catch (_e) {}
        }

        function setAuthUiSignedOut(message) {
          signedIn = false;
          if (authStatus) {
            if (!supabaseAuthConfigured) {
              authStatus.textContent =
                message ||
                "Supabase Auth 未設定 — PUBLIC_SUPABASE_URL / PUBLIC_SUPABASE_ANON_KEY が build に必要です";
            } else {
              authStatus.textContent =
                message || "未ログイン — staging 管理者でログインしてから dry-run してください";
            }
          }
          if (authLoginForm) authLoginForm.hidden = !supabaseAuthConfigured;
          if (authSignedIn) authSignedIn.hidden = true;
          updateLoginButton();
          updateSignOutButton();
          try {
            window.dispatchEvent(new CustomEvent("gosaki-admin-auth-changed", { detail: { signedIn: false } }));
          } catch (_e) {}
        }

        function waitForSupabaseClient(maxAttempts, delayMs) {
          return new Promise(function (resolve) {
            var attempt = 0;
            function tick() {
              if (getSupabaseClient()) {
                resolve(getSupabaseClient());
                return;
              }
              attempt += 1;
              if (attempt >= maxAttempts) {
                resolve(null);
                return;
              }
              setTimeout(tick, delayMs);
            }
            tick();
          });
        }

        function refreshAuthStatus() {
          if (!supabaseAuthConfigured) {
            setAuthUiSignedOut();
            return Promise.resolve();
          }

          if (authStatus) {
            authStatus.textContent = "ログイン状態を確認しています…";
          }
          updateLoginButton();

          return waitForSupabaseClient(40, 100).then(function (client) {
            if (!client) {
              setAuthUiSignedOut("Supabase JS の読み込みに失敗しました — ページを再読み込みしてください");
              return;
            }
            return client.auth.getSession().then(function (sessionRes) {
              var session = sessionRes.data && sessionRes.data.session;
              if (session && session.access_token) {
                setAuthUiSignedIn(session.user && session.user.email);
              } else {
                setAuthUiSignedOut();
              }
            });
          });
        }

        if (authLoginForm && authEmail && authPassword) {
          ["input", "change", "keyup"].forEach(function (evtName) {
            authEmail.addEventListener(evtName, updateLoginButton);
            authPassword.addEventListener(evtName, updateLoginButton);
          });

          authLoginForm.addEventListener("submit", function (ev) {
            ev.preventDefault();
            if (!supabaseAuthConfigured) {
              setAuthUiSignedOut();
              return;
            }
            var email = String(authEmail.value || "").trim();
            var password = String(authPassword.value || "");
            if (!email || !password) {
              setAuthUiSignedOut("メールアドレスとパスワードを入力してください");
              return;
            }
            var client = getSupabaseClient();
            if (!client) {
              setAuthUiSignedOut("Supabase JS の読み込みに失敗しました — ページを再読み込みしてください");
              return;
            }
            if (authSignInBtn) authSignInBtn.disabled = true;
            client.auth
              .signInWithPassword({ email: email, password: password })
              .then(function (res) {
                if (res.error) {
                  // Do not dump raw provider error.message (may include sensitive hints)
                  setAuthUiSignedOut("ログイン失敗 — 認証情報を確認してください");
                  return;
                }
                setAuthUiSignedIn(res.data.user && res.data.user.email);
              })
              .finally(function () {
                updateLoginButton();
              });
          });
        }

        if (authSignOutBtn) {
          authSignOutBtn.addEventListener("click", function () {
            if (!signedIn) return;
            var client = getSupabaseClient();
            if (!client) return;
            authSignOutBtn.disabled = true;
            client.auth.signOut().then(function () {
              setAuthUiSignedOut();
            });
          });
        }

        // After auth config read: ensure login button state is applied (and autofill-safe re-eval)
        updateLoginButton();
        setTimeout(updateLoginButton, 0);
        setTimeout(updateLoginButton, 250);
        setTimeout(updateLoginButton, 1000);

        refreshAuthStatus();
        // YouTube dry-run / Save: gosaki-staging-youtube-operational-edit (click-only · no page-load fetch)
      })();
    </script>
      </>
    ) : null}
    <script>
      import {
        validateDiscographyTrackListDryRun,
        buildDiscographyDryRunEndpointRequest,
        buildDiscographySaveEndpointRequest,
        sanitizeDiscographyDryRunEndpointDisplay,
        assertG20u36cDiscographyDryRunEndpointSafe,
        assertG20u41DiscographySaveEndpointSafe,
        evaluateDiscographyOperationalSaveGate,
        isDiscographySaveConflictResponse,
        G20U36C_DISCOGRAPHY_DRY_RUN_OPERATION,
        G20U41_DISCOGRAPHY_SAVE_OPERATION,
        G20U41_DISCOGRAPHY_SAVE_APPROVAL_ID,
        G20U41_DISCOGRAPHY_CONFLICT_MESSAGE,
        G20U36C_PRODUCTION_PROJECT_REF_STOP,
        G20U45_SCHEDULE_DRY_RUN_OPERATION,
        G20U45_SCHEDULE_SAVE_OPERATION,
        G20U45_SCHEDULE_SAVE_APPROVAL_ID,
        G20U45_SCHEDULE_CONFLICT_MESSAGE,
        assertGosakiScheduleDryRunEndpointSafe,
        assertGosakiScheduleSaveEndpointSafe,
        buildScheduleDryRunEndpointRequest,
        buildScheduleSaveEndpointRequest,
        sanitizeScheduleDryRunEndpointDisplay,
        sanitizeScheduleSaveEndpointDisplay,
        evaluateScheduleOperationalSaveGate,
        isScheduleSaveConflictResponse,
        G20U36E_ADMIN_PROBE_RPC_NAME,
        assertG20u36eAdminProbeSupabaseHostSafe,
        buildG20u36eAdminProbeDisplay,
        createG20u36eAdminProbeIdleDisplay,
        createG20u36eAdminProbeRunningDisplay,
        formatG20u36eAdminProbeDisplay,
        G11C6_APPROVAL_ID,
        G11C6_CONFLICT_MESSAGE,
        assertGosakiYoutubeDryRunEndpointSafe,
        assertGosakiYoutubeSaveEndpointSafe,
        buildYoutubeDryRunEndpointRequest,
        buildYoutubeSaveEndpointRequest,
        sanitizeYoutubeDryRunEndpointDisplay,
        sanitizeYoutubeSaveEndpointDisplay,
        evaluateYoutubeOperationalSaveGate,
        isYoutubeSaveConflictResponse,
        G12A_ABOUT_SAVE_APPROVAL_ID,
        G12A_ABOUT_CONFLICT_MESSAGE,
        assertGosakiAboutDryRunEndpointSafe,
        assertGosakiAboutSaveEndpointSafe,
        buildAboutDryRunEndpointRequest,
        buildAboutSaveEndpointRequest,
        sanitizeAboutDryRunEndpointDisplay,
        sanitizeAboutSaveEndpointDisplay,
        evaluateAboutOperationalSaveGate,
        isAboutSaveConflictResponse,
      } from "../lib/gosaki-staging-read-only-admin";
      import { initGosakiDiscographyOperationalEdit } from "../lib/gosaki-staging-discography-operational-edit";
      import { initGosakiScheduleOperationalEdit } from "../lib/gosaki-staging-schedule-operational-edit";
      import { initGosakiYoutubeOperationalEdit } from "../lib/gosaki-staging-youtube-operational-edit";
      import { initGosakiAboutOperationalEdit } from "../lib/gosaki-staging-about-operational-edit";

      function resolveDiscographyAccessToken() {
        const body = document.body;
        const supabaseUrl = (body?.dataset.gosakiSupabaseUrl || "").trim();
        const supabaseAnonKey = (body?.dataset.gosakiSupabaseAnonKey || "").trim();
        const configured = body?.dataset.gosakiSupabaseAuthConfigured === "true";
        if (!configured || !supabaseUrl || !supabaseAnonKey) {
          return Promise.resolve(null);
        }
        const lib = window.supabase;
        const createClient =
          lib && typeof lib.createClient === "function"
            ? lib.createClient
            : lib?.default && typeof lib.default.createClient === "function"
              ? lib.default.createClient
              : null;
        if (!createClient) return Promise.resolve(null);
        const client = createClient(supabaseUrl, supabaseAnonKey, {
          auth: { persistSession: true, autoRefreshToken: true, detectSessionInUrl: false },
        });
        return client.auth.getSession().then((res) => res.data?.session?.access_token ?? null);
      }

      /** G-20u36e admin probe — manual `rpc('is_admin')` only · never logs tokens / user_id / email · never arms Save. */
      (function wireG20u36eAdminProbe() {
        try {
        const probeBtn = document.getElementById("gra-admin-probe-btn");
        const probeResult = document.getElementById("gra-admin-probe-result");
        const body = document.body;
        if (!(probeBtn instanceof HTMLButtonElement) || !probeResult || !body) return;

        const supabaseUrl = (body.dataset.gosakiSupabaseUrl || "").trim();
        const supabaseAnonKey = (body.dataset.gosakiSupabaseAnonKey || "").trim();
        const supabaseAuthConfigured = body.dataset.gosakiSupabaseAuthConfigured === "true";

        function showProbe(display) {
          probeResult.textContent = formatG20u36eAdminProbeDisplay(display);
        }

        showProbe(createG20u36eAdminProbeIdleDisplay());

        function resolveCreateClient() {
          const lib = window.supabase;
          if (!lib) return null;
          if (typeof lib.createClient === "function") return lib.createClient;
          if (lib.default && typeof lib.default.createClient === "function") return lib.default.createClient;
          return null;
        }

        function getProbeClient() {
          if (!supabaseAuthConfigured || !supabaseUrl || !supabaseAnonKey) return null;
          const createClient = resolveCreateClient();
          if (!createClient) return null;
          return createClient(supabaseUrl, supabaseAnonKey, {
            auth: {
              persistSession: true,
              autoRefreshToken: true,
              detectSessionInUrl: false,
            },
          });
        }

        probeBtn.addEventListener("click", () => {
          // Host gate first — production STOP · staging ref required
          if (!assertG20u36eAdminProbeSupabaseHostSafe(supabaseUrl)) {
            showProbe(
              buildG20u36eAdminProbeDisplay({
                supabaseUrl,
                sessionPresent: false,
              }),
            );
            return;
          }

          const client = getProbeClient();
          if (!client) {
            showProbe(
              buildG20u36eAdminProbeDisplay({
                supabaseUrl,
                sessionPresent: false,
              }),
            );
            return;
          }

          probeBtn.disabled = true;
          showProbe(createG20u36eAdminProbeRunningDisplay());

          client.auth
            .getSession()
            .then((sessionRes) => {
              const session = sessionRes?.data?.session;
              // Session object presence only — do not read/display user id, email, or tokens in probe result
              const sessionPresent = Boolean(session);
              if (!sessionPresent) {
                showProbe(
                  buildG20u36eAdminProbeDisplay({
                    supabaseUrl,
                    sessionPresent: false,
                  }),
                );
                return;
              }

              return client.rpc(G20U36E_ADMIN_PROBE_RPC_NAME).then((rpcRes) => {
                showProbe(
                  buildG20u36eAdminProbeDisplay({
                    supabaseUrl,
                    sessionPresent: true,
                    rpcData: rpcRes?.data,
                    rpcFailed: Boolean(rpcRes?.error),
                  }),
                );
              });
            })
            .catch(() => {
              showProbe(
                buildG20u36eAdminProbeDisplay({
                  supabaseUrl,
                  sessionPresent: true,
                  rpcFailed: true,
                }),
              );
            })
            .finally(() => {
              probeBtn.disabled = !supabaseAuthConfigured;
              // Explicit: probe must never enable Save buttons
            });
        });
        } catch (_probeInitError) {
          // Probe init failure must never stop auth / page scripts
        }
      })();

      const discRoot = document.getElementById("gosaki-discography-content");
      if (discRoot instanceof HTMLElement) {
        const body = document.body;
        initGosakiDiscographyOperationalEdit(discRoot, {
          validateTrackListDryRun: validateDiscographyTrackListDryRun,
          buildDryRunEndpointRequest: buildDiscographyDryRunEndpointRequest,
          buildSaveEndpointRequest: buildDiscographySaveEndpointRequest,
          sanitizeEndpointDisplay: sanitizeDiscographyDryRunEndpointDisplay,
          isSaveConflictResponse: isDiscographySaveConflictResponse,
          evaluateSaveGate: evaluateDiscographyOperationalSaveGate,
          assertDryRunEndpointSafe: assertG20u36cDiscographyDryRunEndpointSafe,
          assertSaveEndpointSafe: assertG20u41DiscographySaveEndpointSafe,
          dryRunOperation: G20U36C_DISCOGRAPHY_DRY_RUN_OPERATION,
          saveOperation: G20U41_DISCOGRAPHY_SAVE_OPERATION,
          expectedSaveApprovalId: G20U41_DISCOGRAPHY_SAVE_APPROVAL_ID,
          saveArmed: body?.dataset.gosakiDiscographySaveArmed === "true",
          conflictMessage: G20U41_DISCOGRAPHY_CONFLICT_MESSAGE,
          productionProjectRefStop: G20U36C_PRODUCTION_PROJECT_REF_STOP,
          getAccessToken: resolveDiscographyAccessToken,
        });
      }

      const scheduleRoot = document.getElementById("gosaki-schedule-content");
      if (scheduleRoot instanceof HTMLElement) {
        const body = document.body;
        initGosakiScheduleOperationalEdit(scheduleRoot, {
          saveArmed: body?.dataset.gosakiScheduleSaveArmed === "true",
          getAccessToken: resolveDiscographyAccessToken,
          dryRunEndpoint: (body?.dataset.gosakiScheduleDryRunEndpoint || "").trim(),
          anonKey: (body?.dataset.gosakiSupabaseAnonKey || "").trim(),
          assertDryRunEndpointSafe: assertGosakiScheduleDryRunEndpointSafe,
          assertSaveEndpointSafe: assertGosakiScheduleSaveEndpointSafe,
          buildDryRunEndpointRequest: buildScheduleDryRunEndpointRequest,
          buildSaveEndpointRequest: buildScheduleSaveEndpointRequest,
          sanitizeEndpointDisplay: sanitizeScheduleDryRunEndpointDisplay,
          sanitizeSaveEndpointDisplay: sanitizeScheduleSaveEndpointDisplay,
          evaluateSaveGate: evaluateScheduleOperationalSaveGate,
          isSaveConflictResponse: isScheduleSaveConflictResponse,
          dryRunOperation: G20U45_SCHEDULE_DRY_RUN_OPERATION,
          saveOperation: G20U45_SCHEDULE_SAVE_OPERATION,
          expectedSaveApprovalId:
            (body?.dataset.g20u45ScheduleSaveApprovalId || "").trim() ||
            G20U45_SCHEDULE_SAVE_APPROVAL_ID,
          conflictMessage: G20U45_SCHEDULE_CONFLICT_MESSAGE,
          productionProjectRefStop: G20U36C_PRODUCTION_PROJECT_REF_STOP,
        });
      }

      const youtubeRoot = document.getElementById("gosaki-youtube-content");
      if (youtubeRoot instanceof HTMLElement) {
        const body = document.body;
        initGosakiYoutubeOperationalEdit(youtubeRoot, {
          saveArmed: body?.dataset.gosakiYoutubeSaveArmed === "true",
          getAccessToken: resolveDiscographyAccessToken,
          dryRunEndpoint: (body?.dataset.gosakiYoutubeDryRunEndpoint || "").trim(),
          saveEndpoint: (body?.dataset.gosakiYoutubeSaveEndpoint || "").trim(),
          anonKey: (body?.dataset.gosakiSupabaseAnonKey || "").trim(),
          assertDryRunEndpointSafe: assertGosakiYoutubeDryRunEndpointSafe,
          assertSaveEndpointSafe: assertGosakiYoutubeSaveEndpointSafe,
          buildDryRunEndpointRequest: buildYoutubeDryRunEndpointRequest,
          buildSaveEndpointRequest: buildYoutubeSaveEndpointRequest,
          sanitizeDryRunDisplay: sanitizeYoutubeDryRunEndpointDisplay,
          sanitizeSaveDisplay: sanitizeYoutubeSaveEndpointDisplay,
          evaluateSaveGate: evaluateYoutubeOperationalSaveGate,
          isSaveConflictResponse: isYoutubeSaveConflictResponse,
          expectedSaveApprovalId:
            (body?.dataset.g11c6ApprovalId || "").trim() || G11C6_APPROVAL_ID,
          conflictMessage: G11C6_CONFLICT_MESSAGE,
          productionProjectRefStop: G20U36C_PRODUCTION_PROJECT_REF_STOP,
        });
      }

      const aboutRoot = document.getElementById("gosaki-about-content");
      if (aboutRoot instanceof HTMLElement) {
        const body = document.body;
        initGosakiAboutOperationalEdit(aboutRoot, {
          saveArmed: body?.dataset.gosakiAboutSaveArmed === "true",
          getAccessToken: resolveDiscographyAccessToken,
          dryRunEndpoint: (body?.dataset.gosakiAboutDryRunEndpoint || "").trim(),
          saveEndpoint: (body?.dataset.gosakiAboutSaveEndpoint || "").trim(),
          anonKey: (body?.dataset.gosakiSupabaseAnonKey || "").trim(),
          assertDryRunEndpointSafe: assertGosakiAboutDryRunEndpointSafe,
          assertSaveEndpointSafe: assertGosakiAboutSaveEndpointSafe,
          buildDryRunEndpointRequest: buildAboutDryRunEndpointRequest,
          buildSaveEndpointRequest: buildAboutSaveEndpointRequest,
          sanitizeDryRunDisplay: sanitizeAboutDryRunEndpointDisplay,
          sanitizeSaveDisplay: sanitizeAboutSaveEndpointDisplay,
          evaluateSaveGate: evaluateAboutOperationalSaveGate,
          isSaveConflictResponse: isAboutSaveConflictResponse,
          expectedSaveApprovalId:
            (body?.dataset.g12aAboutSaveApprovalId || "").trim() || G12A_ABOUT_SAVE_APPROVAL_ID,
          conflictMessage: G12A_ABOUT_CONFLICT_MESSAGE,
          productionProjectRefStop: G20U36C_PRODUCTION_PROJECT_REF_STOP,
        });
      }
    </script>
  </body>
