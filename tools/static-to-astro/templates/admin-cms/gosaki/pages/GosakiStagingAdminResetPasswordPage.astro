---

import AdminGosakiStagingShellLayout from "../components/AdminGosakiStagingShellLayout.astro";
import { getStagingAuthConfig } from "../../../../../../src/lib/admin/staging-auth/staging-auth-config";
import { resolveStagingAuthPageServerFlags } from "../../../../../../src/lib/admin/staging-auth/staging-auth-page-config";
import {
GOSAKI_STAGING_ADMIN_BASE,
GOSAKI_STAGING_AUTH_FORGOT_PASSWORD_PATH,
} from "../gosaki-staging-admin-paths";

const authConfig = getStagingAuthConfig();
const pageFlags = resolveStagingAuthPageServerFlags();

const interactive =
pageFlags.stagingAuthEnabled &&
pageFlags.adminAuthProvider === "supabase" &&
authConfig.supabaseConfigured;
---

<AdminGosakiStagingShellLayout title="新しいパスワードの設定">
  <div
    id="staging-auth-page-config"
    data-staging-auth-enabled={pageFlags.stagingAuthEnabled ? "true" : "false"}
    data-admin-auth-provider={pageFlags.adminAuthProvider}
    data-supabase-configured={authConfig.supabaseConfigured ? "true" : "false"}
    hidden
  ></div>

  <main class="admin-staging-auth-page">
    <div class="admin-staging-auth-page__header">
      <h1 class="admin-staging-auth-page__title">新しいパスワードの設定</h1>
    </div>

<section class="admin-card admin-staging-auth-card">
  {
    !interactive ? (
      <p class="admin-message admin-message--error" role="alert">
        ステージング Auth が無効です。オペレータが ENABLE_ADMIN_STAGING_AUTH=true と
        PUBLIC_ADMIN_AUTH_PROVIDER=supabase を設定してください。
      </p>
    ) : null
  }

  <form
    id="staging-reset-password-form"
    class="admin-form admin-staging-auth-form"
    class:list={{ "is-hidden": !interactive }}
    novalidate
  >
    <label class="admin-form__field">
      <span class="admin-form__label">新しいパスワード</span>
      <input
        id="staging-reset-password-new"
        type="password"
        name="password"
        autocomplete="new-password"
        minlength="8"
        required
        disabled={!interactive}
      />
    </label>

    <label class="admin-form__field">
      <span class="admin-form__label">新しいパスワード（確認）</span>
      <input
        id="staging-reset-password-confirm"
        type="password"
        name="password_confirm"
        autocomplete="new-password"
        minlength="8"
        required
        disabled={!interactive}
      />
    </label>

    <div class="admin-actions admin-staging-auth-form__actions">
      <button
        id="staging-reset-password-submit"
        class="admin-button"
        type="submit"
        disabled={!interactive}
      >
        パスワードを保存
      </button>
    </div>
  </form>

  <div id="staging-reset-password-invalid" class="admin-staging-auth-invalid is-hidden" role="alert">
    <p class="admin-message admin-message--error">
      リンクが無効か期限切れです。もう一度パスワード再設定をお試しください。
    </p>
    <p class="admin-staging-auth-links">
      <a href={GOSAKI_STAGING_AUTH_FORGOT_PASSWORD_PATH}>パスワード再設定をやり直す</a>
      {" · "}
      <a href={GOSAKI_STAGING_ADMIN_BASE}>管理画面に戻る</a>
    </p>
  </div>

  <p
    id="staging-reset-password-error"
    class="admin-message admin-message--error"
    hidden
    role="alert"
  />

  <p class="admin-staging-auth-hint">
    メールリンクから戻ったとき、URL ハッシュはブラウザ内でのみ処理します。トークンは画面・ログに表示しません。
  </p>
</section>
```

  </main>
</AdminGosakiStagingShellLayout>

<script>
  import "../../../../../../src/lib/admin/staging-auth/staging-reset-password-page.ts";
</script>
