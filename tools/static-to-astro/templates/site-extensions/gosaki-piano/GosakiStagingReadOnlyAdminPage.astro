---
/**
 * Gosaki staging read-only CMS admin (G-11b / G-20u28 dashboard polish).
 * Static build-time data + YouTube dry-run endpoint wiring (no Save / JSON write).
 */
import "../styles/gosaki-staging-read-only-admin.css";
import "../styles/gosaki-admin-shell-chrome.css";
import AdminGosakiStagingOperatorHome from "./gosaki-admin/AdminGosakiStagingOperatorHome.astro";
import AdminGosakiStagingNav from "./gosaki-admin/AdminGosakiStagingNav.astro";
import AdminGosakiStagingSafetyChips from "./gosaki-admin/AdminGosakiStagingSafetyChips.astro";
import AdminGosakiStagingScheduleContentPanel from "./gosaki-admin/AdminGosakiStagingScheduleContentPanel.astro";
import AdminGosakiStagingAboutContentPanel from "./gosaki-admin/AdminGosakiStagingAboutContentPanel.astro";
import AdminGosakiStagingDiscographyContentPanel from "./gosaki-admin/AdminGosakiStagingDiscographyContentPanel.astro";
import AdminGosakiStagingYoutubeContentPanel from "./gosaki-admin/AdminGosakiStagingYoutubeContentPanel.astro";
import AdminGosakiStagingCompactAuthBar from "./gosaki-admin/AdminGosakiStagingCompactAuthBar.astro";
import {
  GOSAKI_STAGING_ADMIN_BASE,
  GOSAKI_STAGING_ADMIN_SCHEDULE_PATH,
  GOSAKI_STAGING_PREVIEW_URL as GOSAKI_PACKAGE_PREVIEW_URL,
} from "../lib/gosaki-package-admin-paths";
import youtubeConfig from "../data/gosaki-youtube-embed.json";
import aboutConfig from "../data/gosaki-about-content.json";
import contactConfig from "../data/gosaki-contact-hubspot.json";
import dashboardSnapshot from "../data/gosaki-read-only-admin-dashboard.json";
import discographyEditorSnapshot from "../data/gosaki-read-only-admin-discography-editor.json";
import scheduleEventsSnapshot from "../data/gosaki-read-only-admin-schedule-events.json";
import {
  G11C6A_PHASE,
  G11C4A_STAGING_DRY_RUN_ENDPOINT,
  G11C6A_STAGING_SAVE_ENDPOINT,
  G11C6_APPROVAL_ID,
  G11C6_OPERATION_ID,
  G11C6_SAVE_DISABLED_REASON,
  G11C6_SAVE_ENABLED_DEFAULT,
  G20U28_ADMIN_UI_PHASE,
  G20U29_DISCOGRAPHY_EDITOR_PHASE,
  G20U29_DISCOGRAPHY_EDITOR_SAVE_DISABLED_REASON,
  G20U30_DISCOGRAPHY_DRY_RUN_PHASE,
  G20U30_DISCOGRAPHY_DRY_RUN_NOTE,
  G20U36C_DISCOGRAPHY_DRY_RUN_FETCH_POST_PHASE,
  G20U36C_DISCOGRAPHY_DRY_RUN_NOTE,
  G20U36C_DISCOGRAPHY_DRY_RUN_APPROVAL_ID,
  G20U36C_DISCOGRAPHY_DRY_RUN_OPERATION,
  G20U36E_ADMIN_PROBE_UI_TOOLS_DRAFT_PHASE,
  G20U36E_ADMIN_PROBE_BUTTON_LABEL,
  G20U36E_ADMIN_PROBE_NOTE,
  G20U41_DISCOGRAPHY_OPERATIONAL_SAVE_PHASE,
  G20U41_DISCOGRAPHY_SAVE_OPERATION,
  G20U41_DISCOGRAPHY_SAVE_APPROVAL_ID,
  G20U41_DISCOGRAPHY_CONFLICT_MESSAGE,
  buildDiscographySaveEndpointRequest,
  evaluateDiscographyOperationalSaveGate,
  isDiscographySaveConflictResponse,
  isG20u41DiscographyOperationalSaveArmed,
  resolveG20u41DiscographySaveEndpoint,
  assertG20u41DiscographySaveEndpointSafe,
  GOSAKI_STAGING_PREVIEW_URL,
  buildGosakiReadOnlyAdminViewModel,
  isG11c4aSupabaseAuthConfigured,
  isG11c6aSaveEnabled,
  resolveG11c4aDryRunEndpoint,
  resolveG11c4aSupabaseAnonKey,
  resolveG11c4aSupabaseUrl,
  resolveG11c6aSaveEndpoint,
  resolveG20u36cDiscographyDryRunEndpoint,
  resolveGosakiScheduleDryRunEndpoint,
  assertGosakiScheduleDryRunEndpointSafe,
  assertGosakiScheduleSaveEndpointSafe,
  buildScheduleDryRunEndpointRequest,
  buildScheduleSaveEndpointRequest,
  sanitizeScheduleDryRunEndpointDisplay,
  sanitizeScheduleSaveEndpointDisplay,
  evaluateScheduleOperationalSaveGate,
  isScheduleSaveConflictResponse,
  isG20u45ScheduleOperationalSaveArmed,
  G20U45_SCHEDULE_DRY_RUN_OPERATION,
  G20U45_SCHEDULE_SAVE_OPERATION,
  G20U45_SCHEDULE_SAVE_APPROVAL_ID,
  G20U45_SCHEDULE_CONFLICT_MESSAGE,
  G12A_ABOUT_SAVE_APPROVAL_ID,
  G12A_ABOUT_SAVE_OPERATION_ID,
  G12A_ABOUT_DRY_RUN_APPROVAL_ID,
  G12A_ABOUT_CONFLICT_MESSAGE,
  resolveG12aAboutDryRunEndpoint,
  resolveG12aAboutSaveEndpoint,
  isG12aAboutSaveEnabled,
  assertGosakiAboutDryRunEndpointSafe,
  assertGosakiAboutSaveEndpointSafe,
} from "../lib/gosaki-staging-read-only-admin";

interface Props {
  page?: "portal" | "schedule" | "discography" | "youtube" | "about";
}

const { page = "portal" } = Astro.props as Props;

const dryRunEndpoint = resolveG11c4aDryRunEndpoint(import.meta.env);
const saveEndpoint = resolveG11c6aSaveEndpoint(import.meta.env);
const discographyDryRunEndpoint = resolveG20u36cDiscographyDryRunEndpoint(import.meta.env);
const discographySaveEndpoint = resolveG20u41DiscographySaveEndpoint(import.meta.env);
const discographySaveArmed = isG20u41DiscographyOperationalSaveArmed(import.meta.env);
const scheduleSaveArmed = isG20u45ScheduleOperationalSaveArmed(import.meta.env);
const scheduleDryRunEndpointRaw = resolveGosakiScheduleDryRunEndpoint(import.meta.env);
const scheduleDryRunEndpoint = assertGosakiScheduleDryRunEndpointSafe(scheduleDryRunEndpointRaw)
  ? scheduleDryRunEndpointRaw
  : "";
const aboutDryRunEndpointRaw = resolveG12aAboutDryRunEndpoint(import.meta.env);
const aboutDryRunEndpoint = assertGosakiAboutDryRunEndpointSafe(aboutDryRunEndpointRaw)
  ? aboutDryRunEndpointRaw
  : "";
const aboutSaveEndpointRaw = resolveG12aAboutSaveEndpoint(import.meta.env);
const aboutSaveEndpoint = assertGosakiAboutSaveEndpointSafe(aboutSaveEndpointRaw)
  ? aboutSaveEndpointRaw
  : "";
const aboutSaveArmed = isG12aAboutSaveEnabled(import.meta.env);
const supabaseUrl = resolveG11c4aSupabaseUrl(import.meta.env);
const supabaseAnonKey = resolveG11c4aSupabaseAnonKey(import.meta.env);
const supabaseAuthConfigured = isG11c4aSupabaseAuthConfigured(import.meta.env);
const endpointConfigured = Boolean(dryRunEndpoint);
const saveEndpointConfigured = Boolean(saveEndpoint);
const saveEnabled = isG11c6aSaveEnabled(import.meta.env);
const g11c1OperationId = "G-11c1-gosaki-youtube-url-web-save-dry-run-poc";
const g11c1ApprovalId = "G-11c1-youtube-url-dry-run";

const view = buildGosakiReadOnlyAdminViewModel({
  youtube: youtubeConfig,
  about: aboutConfig,
  contact: contactConfig,
});

const dashboard = dashboardSnapshot;
const discographyEditor = discographyEditorSnapshot;
const scheduleEvents = scheduleEventsSnapshot;
const stagingSiteBase = String(import.meta.env.SITE ?? GOSAKI_STAGING_PREVIEW_URL).replace(/\/?$/, "/");
const pagePathSuffix =
  page === "portal" ? "admin/" : `admin/${page}/`;
const adminCanonical = new URL(pagePathSuffix, stagingSiteBase).href;
const publicHomeUrl = stagingSiteBase;
const publicScheduleUrl = new URL("schedule/", stagingSiteBase).href;
const publicAugustUrl = new URL("schedule/2026-08/", stagingSiteBase).href;
const publicDiscographyUrl = new URL("discography/", stagingSiteBase).href;
const publicContactUrl = new URL("contact/", stagingSiteBase).href;
const publicLinkUrl = new URL("link/", stagingSiteBase).href;
const publicAboutUrl = new URL("about/", stagingSiteBase).href;
const robotsContent = "noindex,nofollow,noarchive";
const pageTitleByRoute = {
  portal: "Gosaki Piano CMS（テスト環境）",
  schedule: "スケジュール管理（テスト環境）",
  discography: "ディスコグラフィ管理（テスト環境）",
  youtube: "YouTube管理（テスト環境）",
  about: "プロフィール管理（テスト環境）",
} as const;
const pageTitle = pageTitleByRoute[page];
const navCurrent = page === "portal" ? "home" : page;
/** Auth script on every admin route (including portal) so logout works everywhere. */
const showClientScript = true;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={robotsContent} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={adminCanonical} />
    <meta property="og:url" content={adminCanonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:type" content="website" />
  </head>
  <body
    class="gosaki-read-only-admin"
    data-gosaki-read-only-admin="true"
    data-gosaki-admin-page={page}
    data-gosaki-admin-multi-route="true"
    data-phase={G20U28_ADMIN_UI_PHASE}
    data-discography-editor-phase={G20U29_DISCOGRAPHY_EDITOR_PHASE}
    data-discography-dry-run-phase={G20U30_DISCOGRAPHY_DRY_RUN_PHASE}
    data-discography-endpoint-dry-run-phase={G20U36C_DISCOGRAPHY_DRY_RUN_FETCH_POST_PHASE}
    data-g11c6a-phase={G11C6A_PHASE}
    data-gosaki-youtube-dry-run-endpoint={dryRunEndpoint}
    data-gosaki-youtube-save-endpoint={saveEndpoint}
    data-gosaki-discography-dry-run-endpoint={discographyDryRunEndpoint}
    data-gosaki-discography-save-endpoint={discographySaveEndpoint}
    data-gosaki-schedule-dry-run-endpoint={scheduleDryRunEndpoint}
    data-g20u45-schedule-dry-run-operation={G20U45_SCHEDULE_DRY_RUN_OPERATION}
    data-g20u45-schedule-save-operation={G20U45_SCHEDULE_SAVE_OPERATION}
    data-g20u45-schedule-save-approval-id={G20U45_SCHEDULE_SAVE_APPROVAL_ID}
    data-gosaki-schedule-save-armed={scheduleSaveArmed ? "true" : "false"}
    data-g20u41-discography-operational-save-phase={G20U41_DISCOGRAPHY_OPERATIONAL_SAVE_PHASE}
    data-g20u41-discography-save-operation={G20U41_DISCOGRAPHY_SAVE_OPERATION}
    data-g20u41-discography-save-approval-id={G20U41_DISCOGRAPHY_SAVE_APPROVAL_ID}
    data-gosaki-discography-save-armed={discographySaveArmed ? "true" : "false"}
    data-g20u36c-discography-dry-run-operation={G20U36C_DISCOGRAPHY_DRY_RUN_OPERATION}
    data-g20u36c-discography-dry-run-approval-id={G20U36C_DISCOGRAPHY_DRY_RUN_APPROVAL_ID}
    data-gosaki-supabase-url={supabaseUrl}
    data-gosaki-supabase-anon-key={supabaseAnonKey}
    data-gosaki-supabase-auth-configured={supabaseAuthConfigured ? "true" : "false"}
    data-gosaki-youtube-current-embed={view.youtube.sourceUrl}
    data-gosaki-youtube-current-videoid={view.youtube.videoId ?? ""}
    data-g11c1-operation-id={g11c1OperationId}
    data-g11c1-approval-id={g11c1ApprovalId}
    data-g11c6-operation-id={G11C6_OPERATION_ID}
    data-g11c6-approval-id={G11C6_APPROVAL_ID}
    data-g11c6-save-enabled={saveEnabled ? "true" : "false"}
    data-gosaki-youtube-save-armed={saveEnabled ? "true" : "false"}
    data-gosaki-about-dry-run-endpoint={aboutDryRunEndpoint}
    data-gosaki-about-save-endpoint={aboutSaveEndpoint}
    data-gosaki-about-save-armed={aboutSaveArmed ? "true" : "false"}
    data-g12a-about-dry-run-approval-id={G12A_ABOUT_DRY_RUN_APPROVAL_ID}
    data-g12a-about-save-operation-id={G12A_ABOUT_SAVE_OPERATION_ID}
    data-g12a-about-save-approval-id={G12A_ABOUT_SAVE_APPROVAL_ID}
  >
        <div class="gosaki-read-only-admin__shell">
      <header class="gosaki-read-only-admin__header">
        <a class="gosaki-read-only-admin__brand" href={GOSAKI_STAGING_ADMIN_BASE}>Gosaki Piano CMS</a>
        {page !== "portal" ? <AdminGosakiStagingSafetyChips /> : null}
      </header>

      <main class="gosaki-read-only-admin__main" data-gosaki-multi-route-main="true">
        {
          page === "portal" ? (
            <AdminGosakiStagingOperatorHome
              previewUrl={GOSAKI_PACKAGE_PREVIEW_URL || publicHomeUrl}
              schedulePath={GOSAKI_STAGING_ADMIN_SCHEDULE_PATH}
              supabaseAuthConfigured={supabaseAuthConfigured}
            />
          ) : (
            <>
              <p class="gosaki-read-only-admin__meta">
                <a class="admin-gosaki-back-link" href={GOSAKI_STAGING_ADMIN_BASE}>← 管理トップへ</a>
              </p>
              <AdminGosakiStagingNav current={navCurrent} />
            </>
          )
        }

        {page === "schedule" ? (
          <>
            <AdminGosakiStagingScheduleContentPanel
              events={scheduleEvents.events ?? []}
              dataSource={scheduleEvents.dataSource ?? dashboard.schedule.dataSource}
              publicScheduleUrl={publicScheduleUrl}
              note="公演の確認・追加・編集ができます"
            />
            <AdminGosakiStagingCompactAuthBar
              supabaseAuthConfigured={supabaseAuthConfigured}
              probePhase={G20U36E_ADMIN_PROBE_UI_TOOLS_DRAFT_PHASE}
              probeNote={G20U36E_ADMIN_PROBE_NOTE}
              probeButtonLabel={G20U36E_ADMIN_PROBE_BUTTON_LABEL}
              purposeNote="変更の確認・保存にはログインが必要です（HTTP Basic 認証とは別です）。"
              showDeveloperTools={false}
            />
          </>
        ) : null}

        {page === "discography" ? (
          <>
            <AdminGosakiStagingDiscographyContentPanel
              albums={discographyEditor.albums ?? []}
              dataSource={discographyEditor.dataSource ?? "build-snapshot"}
              releaseCount={discographyEditor.releaseCount ?? 0}
              trackCount={discographyEditor.trackCount ?? 0}
              publicDiscographyUrl={publicDiscographyUrl}
              dryRunEndpointConfigured={Boolean(discographyDryRunEndpoint)}
            />
            <AdminGosakiStagingCompactAuthBar
              supabaseAuthConfigured={supabaseAuthConfigured}
              probePhase={G20U36E_ADMIN_PROBE_UI_TOOLS_DRAFT_PHASE}
              probeNote={G20U36E_ADMIN_PROBE_NOTE}
              probeButtonLabel={G20U36E_ADMIN_PROBE_BUTTON_LABEL}
              purposeNote="変更の確認・保存にはログインが必要です（HTTP Basic 認証とは別です）。"
              showDeveloperTools={false}
            />
          </>
        ) : null}

        {page === "youtube" ? (
          <>
            <AdminGosakiStagingYoutubeContentPanel
              config={youtubeConfig}
              publicHomeUrl={publicHomeUrl}
            />
            <AdminGosakiStagingCompactAuthBar
              supabaseAuthConfigured={supabaseAuthConfigured}
              probePhase={G20U36E_ADMIN_PROBE_UI_TOOLS_DRAFT_PHASE}
              probeNote={G20U36E_ADMIN_PROBE_NOTE}
              probeButtonLabel={G20U36E_ADMIN_PROBE_BUTTON_LABEL}
              purposeNote="変更の確認・保存にはログインが必要です（HTTP Basic 認証とは別です）。"
              showDeveloperTools={false}
            />
          </>
        ) : null}

        {page === "about" ? (
          <>
            <AdminGosakiStagingAboutContentPanel
              profileLabel={view.about.profileLabel}
              bandsLabel={view.about.bandsLabel}
              profileHtml={view.about.profileHtml}
              bandsHtml={view.about.bandsHtml}
              bandImages={view.about.bandImages}
              publicAboutUrl={publicAboutUrl}
            />
            <AdminGosakiStagingCompactAuthBar
              supabaseAuthConfigured={supabaseAuthConfigured}
              probePhase={G20U36E_ADMIN_PROBE_UI_TOOLS_DRAFT_PHASE}
              probeNote={G20U36E_ADMIN_PROBE_NOTE}
              probeButtonLabel={G20U36E_ADMIN_PROBE_BUTTON_LABEL}
              purposeNote="変更の確認・保存にはログインが必要です（HTTP Basic 認証とは別です）。"
              showDeveloperTools={false}
            />
          </>
        ) : null}
      </main>

      <footer class="gosaki-read-only-admin__footer">
        Gosaki Piano CMS — テスト環境｜公開サイトには自動反映されません
      </footer>
    </div>
    {showClientScript ? (
      <>
      <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.49.1/dist/umd/supabase.js"></script>
    <script is:inline>
      (function () {
        var body = document.body;
        // Auth wiring must not depend on YouTube dry-run DOM (G-20u36e login-blocked tools-draft)
        if (!body) return;

        var authStatus = document.getElementById("gra-auth-status");
        var authLoginForm = document.getElementById("gra-auth-login-form");
        var authSignedIn = document.getElementById("gra-auth-signed-in");
        var authSignInBtn = document.getElementById("gra-auth-sign-in-btn");
        var authSignOutBtn = document.getElementById("gra-auth-sign-out-btn");
        var authEmail = document.getElementById("gra-auth-email");
        var authPassword = document.getElementById("gra-auth-password");

        var supabaseUrl = (body.dataset.gosakiSupabaseUrl || "").trim();
        var supabaseAnonKey = (body.dataset.gosakiSupabaseAnonKey || "").trim();
        var supabaseAuthConfigured = body.dataset.gosakiSupabaseAuthConfigured === "true";
        var supabaseClient = null;
        var signedIn = false;

        function resolveCreateClient() {
          var lib = window.supabase;
          if (!lib) return null;
          if (typeof lib.createClient === "function") return lib.createClient;
          if (lib.default && typeof lib.default.createClient === "function") return lib.default.createClient;
          return null;
        }

        function getSupabaseClient() {
          if (!supabaseAuthConfigured || !supabaseUrl || !supabaseAnonKey) return null;
          var createClient = resolveCreateClient();
          if (!createClient) return null;
          if (!supabaseClient) {
            supabaseClient = createClient(supabaseUrl, supabaseAnonKey, {
              auth: {
                persistSession: true,
                autoRefreshToken: true,
                detectSessionInUrl: false,
              },
            });
          }
          return supabaseClient;
        }

        function updateLoginButton() {
          if (!authSignInBtn) return;
          // Enable only when Auth configured and signed out — no Save / probe coupling
          if (!supabaseAuthConfigured || signedIn) {
            authSignInBtn.disabled = true;
            return;
          }
          authSignInBtn.disabled = false;
        }

        function updateSignOutButton() {
          if (!authSignOutBtn) return;
          authSignOutBtn.disabled = !signedIn;
        }

        function setAuthUiSignedIn(email) {
          signedIn = true;
          var label = email ? "ログイン中: " + email : "ログイン中";
          if (authStatus) {
            authStatus.textContent = label;
          }
          var badge = document.getElementById("gra-auth-signed-badge");
          if (badge) badge.textContent = label;
          if (authLoginForm) authLoginForm.hidden = true;
          if (authSignedIn) authSignedIn.hidden = false;
          updateLoginButton();
          updateSignOutButton();
          try {
            window.dispatchEvent(new CustomEvent("gosaki-admin-auth-changed", { detail: { signedIn: true } }));
          } catch (_e) {}
        }

        function setAuthUiSignedOut(message) {
          signedIn = false;
          if (authStatus) {
            if (!supabaseAuthConfigured) {
              authStatus.textContent =
                message ||
                "Supabase Auth 未設定 — PUBLIC_SUPABASE_URL / PUBLIC_SUPABASE_ANON_KEY が build に必要です";
            } else {
              authStatus.textContent = message || "未ログイン";
            }
          }
          var badge = document.getElementById("gra-auth-signed-badge");
          if (badge) badge.textContent = "ログイン中";
          if (authLoginForm) authLoginForm.hidden = !supabaseAuthConfigured;
          if (authSignedIn) authSignedIn.hidden = true;
          if (authEmail) authEmail.value = "";
          if (authPassword) authPassword.value = "";
          updateLoginButton();
          updateSignOutButton();
          try {
            window.dispatchEvent(new CustomEvent("gosaki-admin-auth-changed", { detail: { signedIn: false } }));
          } catch (_e) {}
        }

        function waitForSupabaseClient(maxAttempts, delayMs) {
          return new Promise(function (resolve) {
            var attempt = 0;
            function tick() {
              if (getSupabaseClient()) {
                resolve(getSupabaseClient());
                return;
              }
              attempt += 1;
              if (attempt >= maxAttempts) {
                resolve(null);
                return;
              }
              setTimeout(tick, delayMs);
            }
            tick();
          });
        }

        function refreshAuthStatus() {
          if (!supabaseAuthConfigured) {
            setAuthUiSignedOut();
            return Promise.resolve();
          }

          if (authStatus) {
            authStatus.textContent = "ログイン状態を確認しています…";
          }
          updateLoginButton();

          return waitForSupabaseClient(40, 100).then(function (client) {
            if (!client) {
              setAuthUiSignedOut("Supabase JS の読み込みに失敗しました — ページを再読み込みしてください");
              return;
            }
            return client.auth.getSession().then(function (sessionRes) {
              var session = sessionRes.data && sessionRes.data.session;
              if (session && session.access_token) {
                setAuthUiSignedIn(session.user && session.user.email);
              } else {
                setAuthUiSignedOut();
              }
            });
          });
        }

        if (authLoginForm && authEmail && authPassword) {
          ["input", "change", "keyup"].forEach(function (evtName) {
            authEmail.addEventListener(evtName, updateLoginButton);
            authPassword.addEventListener(evtName, updateLoginButton);
          });

          authLoginForm.addEventListener("submit", function (ev) {
            ev.preventDefault();
            if (!supabaseAuthConfigured) {
              setAuthUiSignedOut();
              return;
            }
            var email = String(authEmail.value || "").trim();
            var password = String(authPassword.value || "");
            if (!email || !password) {
              setAuthUiSignedOut("メールアドレスとパスワードを入力してください");
              return;
            }
            var client = getSupabaseClient();
            if (!client) {
              setAuthUiSignedOut("Supabase JS の読み込みに失敗しました — ページを再読み込みしてください");
              return;
            }
            if (authSignInBtn) authSignInBtn.disabled = true;
            client.auth
              .signInWithPassword({ email: email, password: password })
              .then(function (res) {
                if (res.error) {
                  // Do not dump raw provider error.message (may include sensitive hints)
                  setAuthUiSignedOut("ログイン失敗 — 認証情報を確認してください");
                  return;
                }
                setAuthUiSignedIn(res.data.user && res.data.user.email);
              })
              .finally(function () {
                updateLoginButton();
              });
          });
        }

        if (authSignOutBtn) {
          authSignOutBtn.addEventListener("click", function () {
            authSignOutBtn.disabled = true;
            var finish = function (message) {
              setAuthUiSignedOut(message || "ログアウトしました");
              updateSignOutButton();
            };
            waitForSupabaseClient(40, 100).then(function (client) {
              if (!client) {
                // Always clear local UI even if client failed to load
                try {
                  Object.keys(localStorage)
                    .filter(function (k) {
                      return k.indexOf("sb-") === 0 || k.indexOf("supabase") !== -1;
                    })
                    .forEach(function (k) {
                      try {
                        localStorage.removeItem(k);
                      } catch (_e) {}
                    });
                } catch (_e2) {}
                finish("ログアウトしました（ローカルセッションをクリア）");
                return;
              }
              // scope:local clears persisted session even if network signOut fails
              return client.auth
                .signOut({ scope: "local" })
                .then(function () {
                  finish("ログアウトしました");
                })
                .catch(function () {
                  finish("ログアウトしました");
                });
            });
          });
        }

        // After auth config read: ensure login button state is applied (and autofill-safe re-eval)
        updateLoginButton();
        setTimeout(updateLoginButton, 0);
        setTimeout(updateLoginButton, 250);
        setTimeout(updateLoginButton, 1000);

        refreshAuthStatus();
        // YouTube dry-run / Save: gosaki-staging-youtube-operational-edit (click-only · no page-load fetch)
      })();
    </script>
      </>
    ) : null}
    <script>
      import {
        validateDiscographyTrackListDryRun,
        buildDiscographyDryRunEndpointRequest,
        buildDiscographySaveEndpointRequest,
        sanitizeDiscographyDryRunEndpointDisplay,
        assertG20u36cDiscographyDryRunEndpointSafe,
        assertG20u41DiscographySaveEndpointSafe,
        evaluateDiscographyOperationalSaveGate,
        isDiscographySaveConflictResponse,
        G20U36C_DISCOGRAPHY_DRY_RUN_OPERATION,
        G20U41_DISCOGRAPHY_SAVE_OPERATION,
        G20U41_DISCOGRAPHY_SAVE_APPROVAL_ID,
        G20U41_DISCOGRAPHY_CONFLICT_MESSAGE,
        G20U36C_PRODUCTION_PROJECT_REF_STOP,
        G20U45_SCHEDULE_DRY_RUN_OPERATION,
        G20U45_SCHEDULE_SAVE_OPERATION,
        G20U45_SCHEDULE_SAVE_APPROVAL_ID,
        G20U45_SCHEDULE_CONFLICT_MESSAGE,
        assertGosakiScheduleDryRunEndpointSafe,
        assertGosakiScheduleSaveEndpointSafe,
        buildScheduleDryRunEndpointRequest,
        buildScheduleSaveEndpointRequest,
        sanitizeScheduleDryRunEndpointDisplay,
        sanitizeScheduleSaveEndpointDisplay,
        evaluateScheduleOperationalSaveGate,
        isScheduleSaveConflictResponse,
        G20U36E_ADMIN_PROBE_RPC_NAME,
        assertG20u36eAdminProbeSupabaseHostSafe,
        buildG20u36eAdminProbeDisplay,
        createG20u36eAdminProbeIdleDisplay,
        createG20u36eAdminProbeRunningDisplay,
        formatG20u36eAdminProbeDisplay,
        G11C6_APPROVAL_ID,
        G11C6_CONFLICT_MESSAGE,
        G11C7_ITEMS_SAVE_APPROVAL_ID,
        assertGosakiYoutubeDryRunEndpointSafe,
        assertGosakiYoutubeSaveEndpointSafe,
        buildYoutubeDryRunEndpointRequest,
        buildYoutubeSaveEndpointRequest,
        buildYoutubeItemsDryRunEndpointRequest,
        buildYoutubeItemsSaveEndpointRequest,
        sanitizeYoutubeDryRunEndpointDisplay,
        sanitizeYoutubeSaveEndpointDisplay,
        evaluateYoutubeOperationalSaveGate,
        isYoutubeSaveConflictResponse,
        G12A_ABOUT_SAVE_APPROVAL_ID,
        G12A_ABOUT_CONFLICT_MESSAGE,
        assertGosakiAboutDryRunEndpointSafe,
        assertGosakiAboutSaveEndpointSafe,
        buildAboutDryRunEndpointRequest,
        buildAboutSaveEndpointRequest,
        sanitizeAboutDryRunEndpointDisplay,
        sanitizeAboutSaveEndpointDisplay,
        evaluateAboutOperationalSaveGate,
        isAboutSaveConflictResponse,
      } from "../lib/gosaki-staging-read-only-admin";
      import { initGosakiDiscographyOperationalEdit } from "../lib/gosaki-staging-discography-operational-edit";
      import { initGosakiScheduleOperationalEdit } from "../lib/gosaki-staging-schedule-operational-edit";
      import { initGosakiYoutubeOperationalEdit } from "../lib/gosaki-staging-youtube-operational-edit";
      import { initGosakiYoutubeMultiOperationalEdit } from "../lib/gosaki-staging-youtube-multi-operational-edit";
      import { initGosakiAboutOperationalEdit } from "../lib/gosaki-staging-about-operational-edit";

      function resolveDiscographyAccessToken() {
        const body = document.body;
        const supabaseUrl = (body?.dataset.gosakiSupabaseUrl || "").trim();
        const supabaseAnonKey = (body?.dataset.gosakiSupabaseAnonKey || "").trim();
        const configured = body?.dataset.gosakiSupabaseAuthConfigured === "true";
        if (!configured || !supabaseUrl || !supabaseAnonKey) {
          return Promise.resolve(null);
        }
        const lib = window.supabase;
        const createClient =
          lib && typeof lib.createClient === "function"
            ? lib.createClient
            : lib?.default && typeof lib.default.createClient === "function"
              ? lib.default.createClient
              : null;
        if (!createClient) return Promise.resolve(null);
        const client = createClient(supabaseUrl, supabaseAnonKey, {
          auth: { persistSession: true, autoRefreshToken: true, detectSessionInUrl: false },
        });
        return client.auth.getSession().then((res) => res.data?.session?.access_token ?? null);
      }

      /** G-20u36e admin probe — manual `rpc('is_admin')` only · never logs tokens / user_id / email · never arms Save. */
      (function wireG20u36eAdminProbe() {
        try {
        const probeBtn = document.getElementById("gra-admin-probe-btn");
        const probeResult = document.getElementById("gra-admin-probe-result");
        const body = document.body;
        if (!(probeBtn instanceof HTMLButtonElement) || !probeResult || !body) return;

        const supabaseUrl = (body.dataset.gosakiSupabaseUrl || "").trim();
        const supabaseAnonKey = (body.dataset.gosakiSupabaseAnonKey || "").trim();
        const supabaseAuthConfigured = body.dataset.gosakiSupabaseAuthConfigured === "true";

        function showProbe(display) {
          probeResult.textContent = formatG20u36eAdminProbeDisplay(display);
        }

        showProbe(createG20u36eAdminProbeIdleDisplay());

        function resolveCreateClient() {
          const lib = window.supabase;
          if (!lib) return null;
          if (typeof lib.createClient === "function") return lib.createClient;
          if (lib.default && typeof lib.default.createClient === "function") return lib.default.createClient;
          return null;
        }

        function getProbeClient() {
          if (!supabaseAuthConfigured || !supabaseUrl || !supabaseAnonKey) return null;
          const createClient = resolveCreateClient();
          if (!createClient) return null;
          return createClient(supabaseUrl, supabaseAnonKey, {
            auth: {
              persistSession: true,
              autoRefreshToken: true,
              detectSessionInUrl: false,
            },
          });
        }

        probeBtn.addEventListener("click", () => {
          // Host gate first — production STOP · staging ref required
          if (!assertG20u36eAdminProbeSupabaseHostSafe(supabaseUrl)) {
            showProbe(
              buildG20u36eAdminProbeDisplay({
                supabaseUrl,
                sessionPresent: false,
              }),
            );
            return;
          }

          const client = getProbeClient();
          if (!client) {
            showProbe(
              buildG20u36eAdminProbeDisplay({
                supabaseUrl,
                sessionPresent: false,
              }),
            );
            return;
          }

          probeBtn.disabled = true;
          showProbe(createG20u36eAdminProbeRunningDisplay());

          client.auth
            .getSession()
            .then((sessionRes) => {
              const session = sessionRes?.data?.session;
              // Session object presence only — do not read/display user id, email, or tokens in probe result
              const sessionPresent = Boolean(session);
              if (!sessionPresent) {
                showProbe(
                  buildG20u36eAdminProbeDisplay({
                    supabaseUrl,
                    sessionPresent: false,
                  }),
                );
                return;
              }

              return client.rpc(G20U36E_ADMIN_PROBE_RPC_NAME).then((rpcRes) => {
                showProbe(
                  buildG20u36eAdminProbeDisplay({
                    supabaseUrl,
                    sessionPresent: true,
                    rpcData: rpcRes?.data,
                    rpcFailed: Boolean(rpcRes?.error),
                  }),
                );
              });
            })
            .catch(() => {
              showProbe(
                buildG20u36eAdminProbeDisplay({
                  supabaseUrl,
                  sessionPresent: true,
                  rpcFailed: true,
                }),
              );
            })
            .finally(() => {
              probeBtn.disabled = !supabaseAuthConfigured;
              // Explicit: probe must never enable Save buttons
            });
        });
        } catch (_probeInitError) {
          // Probe init failure must never stop auth / page scripts
        }
      })();

      const discRoot = document.getElementById("gosaki-discography-content");
      if (discRoot instanceof HTMLElement) {
        const body = document.body;
        initGosakiDiscographyOperationalEdit(discRoot, {
          validateTrackListDryRun: validateDiscographyTrackListDryRun,
          buildDryRunEndpointRequest: buildDiscographyDryRunEndpointRequest,
          buildSaveEndpointRequest: buildDiscographySaveEndpointRequest,
          sanitizeEndpointDisplay: sanitizeDiscographyDryRunEndpointDisplay,
          isSaveConflictResponse: isDiscographySaveConflictResponse,
          evaluateSaveGate: evaluateDiscographyOperationalSaveGate,
          assertDryRunEndpointSafe: assertG20u36cDiscographyDryRunEndpointSafe,
          assertSaveEndpointSafe: assertG20u41DiscographySaveEndpointSafe,
          dryRunOperation: G20U36C_DISCOGRAPHY_DRY_RUN_OPERATION,
          saveOperation: G20U41_DISCOGRAPHY_SAVE_OPERATION,
          expectedSaveApprovalId: G20U41_DISCOGRAPHY_SAVE_APPROVAL_ID,
          saveArmed: body?.dataset.gosakiDiscographySaveArmed === "true",
          conflictMessage: G20U41_DISCOGRAPHY_CONFLICT_MESSAGE,
          productionProjectRefStop: G20U36C_PRODUCTION_PROJECT_REF_STOP,
          getAccessToken: resolveDiscographyAccessToken,
        });
      }

      const scheduleRoot = document.getElementById("gosaki-schedule-content");
      if (scheduleRoot instanceof HTMLElement) {
        const body = document.body;
        initGosakiScheduleOperationalEdit(scheduleRoot, {
          saveArmed: body?.dataset.gosakiScheduleSaveArmed === "true",
          getAccessToken: resolveDiscographyAccessToken,
          dryRunEndpoint: (body?.dataset.gosakiScheduleDryRunEndpoint || "").trim(),
          anonKey: (body?.dataset.gosakiSupabaseAnonKey || "").trim(),
          assertDryRunEndpointSafe: assertGosakiScheduleDryRunEndpointSafe,
          assertSaveEndpointSafe: assertGosakiScheduleSaveEndpointSafe,
          buildDryRunEndpointRequest: buildScheduleDryRunEndpointRequest,
          buildSaveEndpointRequest: buildScheduleSaveEndpointRequest,
          sanitizeEndpointDisplay: sanitizeScheduleDryRunEndpointDisplay,
          sanitizeSaveEndpointDisplay: sanitizeScheduleSaveEndpointDisplay,
          evaluateSaveGate: evaluateScheduleOperationalSaveGate,
          isSaveConflictResponse: isScheduleSaveConflictResponse,
          dryRunOperation: G20U45_SCHEDULE_DRY_RUN_OPERATION,
          saveOperation: G20U45_SCHEDULE_SAVE_OPERATION,
          expectedSaveApprovalId:
            (body?.dataset.g20u45ScheduleSaveApprovalId || "").trim() ||
            G20U45_SCHEDULE_SAVE_APPROVAL_ID,
          conflictMessage: G20U45_SCHEDULE_CONFLICT_MESSAGE,
          productionProjectRefStop: G20U36C_PRODUCTION_PROJECT_REF_STOP,
        });
      }

      const youtubeRoot = document.getElementById("gosaki-youtube-content");
      if (youtubeRoot instanceof HTMLElement) {
        const body = document.body;
        if (youtubeRoot.getAttribute("data-gosaki-youtube-multi") === "true") {
          const cfgEl = document.getElementById("gosaki-youtube-config-json");
          let config = {};
          try {
            config = cfgEl ? JSON.parse(cfgEl.textContent || "{}") : {};
          } catch (_e) {
            config = {};
          }
          initGosakiYoutubeMultiOperationalEdit(youtubeRoot, {
            config,
            saveArmed: body?.dataset.gosakiYoutubeSaveArmed === "true",
            getAccessToken: resolveDiscographyAccessToken,
            dryRunEndpoint: (body?.dataset.gosakiYoutubeDryRunEndpoint || "").trim(),
            saveEndpoint: (body?.dataset.gosakiYoutubeSaveEndpoint || "").trim(),
            anonKey: (body?.dataset.gosakiSupabaseAnonKey || "").trim(),
            assertDryRunEndpointSafe: assertGosakiYoutubeDryRunEndpointSafe,
            assertSaveEndpointSafe: assertGosakiYoutubeSaveEndpointSafe,
            buildDryRunEndpointRequest: buildYoutubeItemsDryRunEndpointRequest,
            buildSaveEndpointRequest: buildYoutubeItemsSaveEndpointRequest,
            evaluateSaveGate: evaluateYoutubeOperationalSaveGate,
            expectedSaveApprovalId: G11C7_ITEMS_SAVE_APPROVAL_ID,
            conflictMessage: G11C6_CONFLICT_MESSAGE,
          });
        } else {
          initGosakiYoutubeOperationalEdit(youtubeRoot, {
            saveArmed: body?.dataset.gosakiYoutubeSaveArmed === "true",
            getAccessToken: resolveDiscographyAccessToken,
            dryRunEndpoint: (body?.dataset.gosakiYoutubeDryRunEndpoint || "").trim(),
            saveEndpoint: (body?.dataset.gosakiYoutubeSaveEndpoint || "").trim(),
            anonKey: (body?.dataset.gosakiSupabaseAnonKey || "").trim(),
            assertDryRunEndpointSafe: assertGosakiYoutubeDryRunEndpointSafe,
            assertSaveEndpointSafe: assertGosakiYoutubeSaveEndpointSafe,
            buildDryRunEndpointRequest: buildYoutubeDryRunEndpointRequest,
            buildSaveEndpointRequest: buildYoutubeSaveEndpointRequest,
            sanitizeDryRunDisplay: sanitizeYoutubeDryRunEndpointDisplay,
            sanitizeSaveDisplay: sanitizeYoutubeSaveEndpointDisplay,
            evaluateSaveGate: evaluateYoutubeOperationalSaveGate,
            isSaveConflictResponse: isYoutubeSaveConflictResponse,
            expectedSaveApprovalId:
              (body?.dataset.g11c6ApprovalId || "").trim() || G11C6_APPROVAL_ID,
            conflictMessage: G11C6_CONFLICT_MESSAGE,
            productionProjectRefStop: G20U36C_PRODUCTION_PROJECT_REF_STOP,
          });
        }
      }

      const aboutRoot = document.getElementById("gosaki-about-content");
      if (aboutRoot instanceof HTMLElement) {
        const body = document.body;
        initGosakiAboutOperationalEdit(aboutRoot, {
          saveArmed: body?.dataset.gosakiAboutSaveArmed === "true",
          getAccessToken: resolveDiscographyAccessToken,
          dryRunEndpoint: (body?.dataset.gosakiAboutDryRunEndpoint || "").trim(),
          saveEndpoint: (body?.dataset.gosakiAboutSaveEndpoint || "").trim(),
          anonKey: (body?.dataset.gosakiSupabaseAnonKey || "").trim(),
          assertDryRunEndpointSafe: assertGosakiAboutDryRunEndpointSafe,
          assertSaveEndpointSafe: assertGosakiAboutSaveEndpointSafe,
          buildDryRunEndpointRequest: buildAboutDryRunEndpointRequest,
          buildSaveEndpointRequest: buildAboutSaveEndpointRequest,
          sanitizeDryRunDisplay: sanitizeAboutDryRunEndpointDisplay,
          sanitizeSaveDisplay: sanitizeAboutSaveEndpointDisplay,
          evaluateSaveGate: evaluateAboutOperationalSaveGate,
          isSaveConflictResponse: isAboutSaveConflictResponse,
          expectedSaveApprovalId:
            (body?.dataset.g12aAboutSaveApprovalId || "").trim() || G12A_ABOUT_SAVE_APPROVAL_ID,
          conflictMessage: G12A_ABOUT_CONFLICT_MESSAGE,
          productionProjectRefStop: G20U36C_PRODUCTION_PROJECT_REF_STOP,
        });
      }
    </script>
  </body>
</html>
