---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { supabase } from "../../../lib/supabase";
import {
  buildVenueAreaLookup,
  formatMonthLabel,
  formatScheduleDateLabel,
  formatScheduleVenueDisplay,
  getTimeTypeSymbol,
  groupSchedulesByMonth,
  isImageUrl,
  resolveVenueArea,
  sortSchedules,
} from "../../../lib/schedule";

export async function getStaticPaths() {
  const publicScheduleStartMonth = "2026-06";
  const [schedulesResult, venuesResult] = await Promise.all([
    supabase
      .from("schedules")
      .select("*")
      .eq("is_published", true)
      .is("deleted_at", null)
      .gte("date", `${publicScheduleStartMonth}-01`),
    supabase.from("venues").select("id, name, area"),
  ]);

  const { data: schedules, error } = schedulesResult;

  if (error) {
    console.error("[schedule] schedules の取得に失敗:", error.message);
    return [];
  }

  if (venuesResult.error) {
    console.warn("[schedule] venues の取得に失敗:", venuesResult.error.message);
  }

  const venueAreaLookup = buildVenueAreaLookup(venuesResult.data);
  const schedulesWithVenueArea = (schedules ?? []).map((item) => ({
    ...item,
    venue_area: resolveVenueArea(item, venueAreaLookup),
  }));

  const byMonth = groupSchedulesByMonth(schedulesWithVenueArea);

  const availableMonths = [...byMonth.keys()]
    .filter((m) => m >= publicScheduleStartMonth)
    .sort();

  return availableMonths.map((month, index) => ({
    params: { month },
    props: {
      month,
      monthLabel: formatMonthLabel(month),
      schedules: sortSchedules(byMonth.get(month) ?? []),
      prevMonth: index > 0 ? availableMonths[index - 1] : null,
      nextMonth: index < availableMonths.length - 1 ? availableMonths[index + 1] : null,
    },
  }));
}

const { month, monthLabel, schedules, prevMonth, nextMonth } = Astro.props;

function resolveScheduleImageUrls(item: { image_urls?: unknown; image_url?: string | null }) {
  if (Array.isArray(item.image_urls)) {
    const normalized = item.image_urls
      .filter((value): value is string => typeof value === "string")
      .map((value) => value.trim())
      .filter((value) => isImageUrl(value));
    if (normalized.length > 0) return normalized;
  }

  const fallback = item.image_url?.trim() ?? "";
  return isImageUrl(fallback) ? [fallback] : [];
}
---

<BaseLayout
  title={`${monthLabel} | 紗理 / SARI`}
  description={`${monthLabel}のライブ・コンサート・イベントスケジュール。ジャズシンガー紗理（SARI）公式サイト。`}
  canonical={`/schedule/${month}/`}
>
  <Header />

  <main>
    <div id="lowerWrap">
      <h1 class="postList_title">{monthLabel}</h1>

      <div class="entry-content month-schedule">
        <div class="schedule-legend" aria-label="ライブ時間帯の凡例">
          <p class="schedule-legend__item">
            <span class="schedule-legend__symbol">☀</span>
            <span class="schedule-legend__text">= 昼のLIVE</span>
          </p>
          <p class="schedule-legend__item">
            <span class="schedule-legend__symbol">☽</span>
            <span class="schedule-legend__text">= 夜のLIVE</span>
          </p>
        </div>

        {schedules.length > 0 ? (
          <ul class="month-schedule__list">
            {schedules.map((item) => {
              const venueLabel = formatScheduleVenueDisplay(item.venue_name, item.venue_area);
              const imageUrls = resolveScheduleImageUrls(item);
              const hasImages = imageUrls.length > 0;

              return (
              <li class="month-schedule__list-item">
                <div
                  class:list={[
                    "schedule-card",
                    { "schedule-card--tour": item.is_special },
                  ]}
                >
                  <div
                    class:list={[
                      "schedule-card__inner",
                      { "schedule-card__inner--with-image": hasImages },
                    ]}
                  >
                    <div class="schedule-card-body">
                      <p class="schedule-item__line schedule-item__line--primary">
                        {getTimeTypeSymbol(item.time_type) && (
                          <span class="schedule-item__symbol">{getTimeTypeSymbol(item.time_type)}</span>
                        )}
                        <span class="schedule-item__date">{formatScheduleDateLabel(item.date)}</span>
                        {venueLabel && (
                          <span class="schedule-item__venue">{venueLabel}</span>
                        )}
                      </p>

                      {(item.title || item.genre) && (
                        <p class="schedule-item__line schedule-item__line--title">
                          {item.title && (
                            <span class="schedule-item__title">&lt;{item.title}&gt;</span>
                          )}
                          {item.genre && <span class="schedule-item__genre">{item.genre}</span>}
                        </p>
                      )}

                      <dl class="schedule-card__details">
                        {item.open_time && (
                          <>
                            <dt>OPEN</dt>
                            <dd>{item.open_time}</dd>
                          </>
                        )}
                        {item.start_time && (
                          <>
                            <dt>START</dt>
                            <dd>{item.start_time}</dd>
                          </>
                        )}
                        {item.price && (
                          <>
                            <dt>CHARGE</dt>
                            <dd>{item.price}</dd>
                          </>
                        )}
                        {item.members && (
                          <>
                            <dt>MEMBERS</dt>
                            <dd>{item.members}</dd>
                          </>
                        )}
                      </dl>

                      {item.note && <p class="schedule-card__note">{item.note}</p>}

                      {item.reservation_url && (
                        <p class="schedule-card__action">
                          <a
                            href={item.reservation_url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="schedule-card__button"
                          >
                            予約・詳細
                          </a>
                        </p>
                      )}
                    </div>

                    {hasImages && (
                      imageUrls.length === 1 ? (
                        <div class="schedule-card-image">
                          <img src={imageUrls[0]} alt={item.title || monthLabel} loading="lazy" />
                        </div>
                      ) : (
                        <div class="schedule-carousel" data-schedule-carousel>
                          <div class="schedule-carousel__viewport">
                            {imageUrls.map((url, index) => (
                              <img
                                src={url}
                                alt={item.title || monthLabel}
                                loading="lazy"
                                class:list={[
                                  "schedule-carousel__slide",
                                  { "is-active": index === 0 },
                                ]}
                                data-carousel-slide
                                hidden={index !== 0}
                              />
                            ))}
                          </div>
                          <div class="schedule-carousel__controls">
                            <button type="button" class="schedule-carousel__button" data-carousel-prev>
                              前へ
                            </button>
                            <span class="schedule-carousel__status" data-carousel-status>
                              1 / {imageUrls.length}
                            </span>
                            <button type="button" class="schedule-carousel__button" data-carousel-next>
                              次へ
                            </button>
                          </div>
                        </div>
                      )
                    )}
                  </div>

                  {item.is_special && (
                    <span class="schedule-card__tour">TOUR</span>
                  )}
                </div>
              </li>
              );
            })}
          </ul>
        ) : (
          <p>この月のライブ予定はありません。</p>
        )}

        <nav class="month-schedule__nav" aria-label="月別スケジュールのナビゲーション">
          <div class="month-schedule__nav-slot month-schedule__nav-slot--start">
            {
              prevMonth && (
                <a class="month-schedule__nav-link" href={`/schedule/${prevMonth}/`}>
                  ← 前の月
                </a>
              )
            }
          </div>
          <div class="month-schedule__nav-slot month-schedule__nav-slot--center">
            <a class="month-schedule__nav-link month-schedule__nav-link--index" href="/schedule/">
              LIVE SCHEDULE 一覧へ
            </a>
          </div>
          <div class="month-schedule__nav-slot month-schedule__nav-slot--end">
            {
              nextMonth && (
                <a class="month-schedule__nav-link" href={`/schedule/${nextMonth}/`}>
                  次の月 →
                </a>
              )
            }
          </div>
        </nav>
      </div>
    </div>
  </main>

  <Footer />

  <script is:inline>
    (() => {
      const carousels = document.querySelectorAll("[data-schedule-carousel]");
      for (const carousel of carousels) {
        const slides = [...carousel.querySelectorAll("[data-carousel-slide]")];
        if (slides.length <= 1) continue;

        const status = carousel.querySelector("[data-carousel-status]");
        const prevButton = carousel.querySelector("[data-carousel-prev]");
        const nextButton = carousel.querySelector("[data-carousel-next]");
        if (!(prevButton instanceof HTMLButtonElement) || !(nextButton instanceof HTMLButtonElement)) {
          continue;
        }

        let current = 0;
        const update = () => {
          slides.forEach((slide, index) => {
            const active = index === current;
            slide.hidden = !active;
            slide.classList.toggle("is-active", active);
          });
          if (status) {
            status.textContent = `${current + 1} / ${slides.length}`;
          }
        };

        prevButton.addEventListener("click", () => {
          current = (current - 1 + slides.length) % slides.length;
          update();
        });

        nextButton.addEventListener("click", () => {
          current = (current + 1) % slides.length;
          update();
        });

        update();
      }
    })();
  </script>
</BaseLayout>

<style>
  .month-schedule {
    margin-bottom: 80px;
  }

  @media screen and (min-width: 769px) {
    .month-schedule {
      width: 1000px;
      max-width: 100%;
    }

    .month-schedule__list-item {
      width: 1000px;
      max-width: 100%;
    }
  }

  .schedule-legend {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 24px 48px;
    margin: 0 0 40px;
    padding: 20px 16px;
    text-align: center;
  }

  .schedule-legend__item {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0;
    font-size: 2rem;
    font-weight: bold;
    line-height: 1.4;
    letter-spacing: 0.08em;
  }

  .schedule-legend__symbol {
    font-size: 2.4rem;
    line-height: 1;
  }

  .schedule-legend__text {
    font-size: 1.8rem;
  }

  .month-schedule__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .month-schedule__list-item {
    margin: 0;
  }

  .schedule-card {
    position: relative;
    background: #f3ebdf;
    border-radius: 5px;
    padding: 24px 20px;
  }

  .schedule-card--tour {
    padding-bottom: 36px;
  }

  .schedule-card__tour {
    position: absolute;
    right: 18px;
    bottom: 14px;
    margin: 0;
    padding: 0;
    font-size: 13px;
    font-weight: normal;
    line-height: 1;
    letter-spacing: 0.14em;
    color: #777;
    pointer-events: none;
    user-select: none;
  }

  .schedule-card__inner {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .schedule-card__inner--with-image {
    display: grid;
    grid-template-columns: 1fr min(350px, 38%);
    align-items: start;
    gap: 24px;
  }

  .schedule-card-body {
    min-width: 0;
  }

  .schedule-item__line {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 0.4em;
    margin: 0;
    line-height: 1.6;
    letter-spacing: 0.05em;
  }

  .schedule-item__line--primary {
    margin-bottom: 10px;
    font-size: 2rem;
    font-weight: bold;
  }

  .schedule-item__line--title {
    margin-bottom: 18px;
    font-size: 1.6rem;
    font-weight: bold;
  }

  .schedule-item__symbol {
    margin-right: 0.1em;
  }

  .schedule-item__title {
    color: #008080;
  }

  .schedule-item__title::after {
    content: "\3000";
  }

  .schedule-item__genre {
    color: #ff99cc;
  }

  .schedule-card__details {
    margin: 0;
    display: grid;
    grid-template-columns: 7em 1fr;
    gap: 10px 16px;
    font-size: 1.5rem;
    line-height: 1.7;
    letter-spacing: 0.06em;
  }

  .schedule-card__details dt {
    margin: 0;
    font-weight: bold;
    opacity: 0.7;
  }

  .schedule-card__details dd {
    margin: 0;
  }

  .schedule-card__note {
    margin: 0;
    padding-top: 14px;
    border-top: 1px solid rgba(0, 0, 0, 0.15);
    font-size: 1.5rem;
    line-height: 1.7;
    letter-spacing: 0.06em;
  }

  .schedule-card__action {
    margin: 20px 0 0;
  }

  .schedule-card__button {
    display: inline-block;
    padding: 12px 28px;
    font-size: 1.4rem;
    letter-spacing: 0.12em;
    color: #333;
    text-decoration: none;
    border: 1px solid #333;
    background: #fff;
    transition:
      color 0.2s,
      background 0.2s;
  }

  .schedule-card__button:hover {
    color: #fff;
    background: #333;
  }

  .schedule-card-image {
    overflow: hidden;
    border-radius: 5px;
    background: #eee;
  }

  .schedule-card-image img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: 5px;
  }

  .schedule-carousel {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .schedule-carousel__viewport {
    overflow: visible;
    border-radius: 5px;
    background: #eee;
  }

  .schedule-carousel__slide {
    display: none;
    width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: 5px;
  }

  .schedule-carousel__slide.is-active {
    display: block;
  }

  .schedule-carousel__slide[hidden] {
    display: none !important;
  }

  .schedule-carousel__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .schedule-carousel__button {
    min-width: 72px;
    min-height: 36px;
    border: 1px solid #333;
    background: #fff;
    color: #333;
    cursor: pointer;
    font-size: 1.3rem;
    letter-spacing: 0.08em;
  }

  .schedule-carousel__status {
    min-width: 64px;
    text-align: center;
    font-size: 1.3rem;
    letter-spacing: 0.08em;
    color: #555;
  }

  .month-schedule__nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 16px 24px;
    margin: 48px 0 0;
    font-size: 1.4rem;
    letter-spacing: 0.08em;
  }

  .month-schedule__nav-slot--start {
    text-align: left;
  }

  .month-schedule__nav-slot--center {
    text-align: center;
  }

  .month-schedule__nav-slot--end {
    text-align: right;
  }

  .month-schedule__nav-link {
    color: #666;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .month-schedule__nav-link:hover {
    color: #333;
  }

  .month-schedule__nav-link--index {
    font-weight: bold;
  }

  @media screen and (max-width: 768px) {
    .schedule-legend {
      flex-direction: column;
      gap: 16px;
      margin-bottom: 32px;
    }

    .schedule-legend__item {
      font-size: 1.7rem;
    }

    .schedule-legend__symbol {
      font-size: 2rem;
    }

    .schedule-legend__text {
      font-size: 1.6rem;
    }

    .schedule-card {
      padding: 20px 16px;
    }

    .schedule-card--tour {
      padding-bottom: 32px;
    }

    .schedule-card__tour {
      right: 14px;
      bottom: 12px;
      font-size: 12px;
      letter-spacing: 0.12em;
    }

    .schedule-card__inner--with-image {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .schedule-item__line--primary,
    .schedule-item__line--title {
      font-size: 1.5rem;
    }

    .schedule-card__details {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .schedule-card__details dt {
      margin-top: 8px;
    }

    .schedule-card-image img {
      height: auto;
    }

    .month-schedule__nav {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-top: 40px;
    }

    .month-schedule__nav-slot--start,
    .month-schedule__nav-slot--center,
    .month-schedule__nav-slot--end {
      text-align: center;
    }
  }
</style>
