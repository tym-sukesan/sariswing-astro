---
/**
 * G-5z-d — Staging shell read-only data section.
 */
import AdminReadOnlyDataStatusPanel from "./AdminReadOnlyDataStatusPanel.astro";
import { G5Z_D_PHASE } from "../../../../../../src/lib/admin/staging-data/read-only-data-config";

interface Props {
  phase?: string;
}

const { phase = G5Z_D_PHASE } = Astro.props;
---

<div
  id="admin-staging-readonly-data-root"
  class="admin-staging-readonly-data"
  data-scaffold="true"
  data-phase={phase}
>
  <AdminReadOnlyDataStatusPanel phase={phase} />
</div>

<style>
  .admin-staging-readonly-data {
    margin: 0 0 1.5rem;
  }
</style>
