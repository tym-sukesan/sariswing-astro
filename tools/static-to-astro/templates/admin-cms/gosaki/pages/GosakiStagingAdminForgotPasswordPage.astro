---
import AdminGosakiStagingShellLayout from "../components/AdminGosakiStagingShellLayout.astro";
import { getStagingAuthConfig } from "../../../../../../src/lib/admin/staging-auth/staging-auth-config";
import {
  GOSAKI_STAGING_ADMIN_BASE,
  GOSAKI_STAGING_AUTH_FORGOT_PASSWORD_PATH,
} from "../gosaki-staging-admin-paths";

const authConfig = getStagingAuthConfig();
const interactive =
  authConfig.stagingAuthEnabled && authConfig.supabaseConfigured;
---

<AdminGosakiStagingShellLayout title="パスワード再設定">
  <main class="admin-staging-auth-page">
    <div class="admin-staging-auth-page__header">
      <a class="admin-back-link" href={GOSAKI_STAGING_ADMIN_BASE}>← 管理画面に戻る</a>
      <h1 class="admin-staging-auth-page__title">パスワード再設定</h1>
    </div>

    <section class="admin-card admin-staging-auth-card">
      <p class="admin-staging-auth-lead">
        登録済みのメールアドレスを入力してください。パスワード再設定用のリンクをお送りします。
      </p>

      {
        !interactive ? (
          <p class="admin-message admin-message--error" role="alert">
            ステージング Auth が無効です。オペレータが ENABLE_ADMIN_STAGING_AUTH=true と
            PUBLIC_ADMIN_AUTH_PROVIDER=supabase を設定してください。
          </p>
        ) : null
      }

      <form
        id="staging-forgot-password-form"
        class="admin-form admin-staging-auth-form"
        class:list={{ "is-hidden": !interactive }}
        novalidate
      >
        <label class="admin-form__field">
          <span class="admin-form__label">メールアドレス</span>
          <input
            id="staging-forgot-password-email"
            type="email"
            name="email"
            autocomplete="username"
            required
            disabled={!interactive}
          />
        </label>

        <div class="admin-actions admin-staging-auth-form__actions">
          <button
            id="staging-forgot-password-submit"
            class="admin-button"
            type="submit"
            disabled={!interactive}
          >
            パスワード再設定メールを送る
          </button>
        </div>
      </form>

      <p
        id="staging-forgot-password-success"
        class="admin-message admin-message--success is-hidden"
        role="status"
      >
        再設定メールを送信しました。メール内のリンクから新しいパスワードを設定してください。
      </p>

      <p
        id="staging-forgot-password-error"
        class="admin-message admin-message--error"
        hidden
        role="alert"
      />

      <p class="admin-staging-auth-hint">
        リダイレクト先: <code>{GOSAKI_STAGING_AUTH_FORGOT_PASSWORD_PATH}</code> から送信。メールリンクは
        staging shell の reset-password 画面へ戻ります（トークンは表示しません）。
      </p>
    </section>
  </main>
</AdminGosakiStagingShellLayout>

<script>
  import "../../../../../../src/lib/admin/staging-auth/staging-forgot-password.ts";
</script>
