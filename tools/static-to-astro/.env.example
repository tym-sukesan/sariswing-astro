# Supabase Staging credentials
# Copy this file to .env.local and fill in your staging project values.
# NEVER commit .env.local to Git.
# NEVER use production Supabase credentials here.

# Staging Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://your-staging-project.supabase.co

# Staging Supabase service role key (server-side only, NEVER expose to browser)
# Used only for seed insert via CLI. Not used in frontend Astro build.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anon / publishable key for RLS public-read verification (Phase 3-N)
# Accepts legacy anon JWT or new sb_publishable_... key in this variable.
SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# Staging admin bootstrap password (Phase 3-O) — NEVER commit .env.local
# Prefer this over --password to avoid shell history. Not logged by CLI.
SUPABASE_ADMIN_PASSWORD=your-staging-admin-password-here
