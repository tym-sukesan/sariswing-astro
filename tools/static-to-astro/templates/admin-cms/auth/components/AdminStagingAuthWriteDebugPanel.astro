---
/**
 * G-6-d-auth-session-display-investigation — Auth / write gate debug panel.
 * Staging shell only. Not /admin/.
 */
interface Props {
  phase?: string;
}

const { phase = "G-6-d-auth-session-display-investigation" } = Astro.props;
---

<section
  id="staging-auth-write-debug-panel"
  class="admin-auth-write-debug-panel"
  role="status"
  aria-live="polite"
  data-scaffold="true"
  data-phase={phase}
>
  <h2 class="admin-auth-write-debug-panel__title">
    Auth Session / Write Gate Debug ({phase})
  </h2>
  <p class="admin-auth-write-debug-panel__note">
    Staging shell only. Shows why mock preview or real Supabase Auth is active. No secrets.
    Role is resolved from mock allowlist only — <code>admin_users</code> is not queried yet.
  </p>

  <dl class="admin-auth-write-debug-panel__list">
    <div>
      <dt>Server gate injection</dt>
      <dd id="debug-server-gates-injected">—</dd>
    </div>
    <div>
      <dt>Auth provider</dt>
      <dd id="debug-auth-provider">—</dd>
    </div>
    <div>
      <dt>Auth mode</dt>
      <dd id="debug-auth-mode">—</dd>
    </div>
    <div>
      <dt>Auth enabled</dt>
      <dd id="debug-auth-enabled">—</dd>
    </div>
    <div>
      <dt>Auth status</dt>
      <dd id="debug-auth-status">loading</dd>
    </div>
    <div>
      <dt>User email</dt>
      <dd id="debug-user-email">—</dd>
    </div>
    <div>
      <dt>User id</dt>
      <dd id="debug-user-id">—</dd>
    </div>
    <div>
      <dt>Admin role</dt>
      <dd id="debug-admin-role">—</dd>
    </div>
    <div>
      <dt>Role source</dt>
      <dd id="debug-role-source">—</dd>
    </div>
    <div>
      <dt>Dry-run mode</dt>
      <dd id="debug-dry-run">—</dd>
    </div>
    <div>
      <dt>Approval ID</dt>
      <dd id="debug-approval-id">—</dd>
    </div>
    <div>
      <dt>Write enabled</dt>
      <dd id="debug-write-enabled">—</dd>
    </div>
    <div>
      <dt>Save enabled</dt>
      <dd id="debug-save-enabled">—</dd>
    </div>
    <div class="admin-auth-write-debug-panel__reasons">
      <dt>Disabled reasons</dt>
      <dd id="debug-disabled-reasons">—</dd>
    </div>
  </dl>
</section>

<script>
  import "../../../../../../src/lib/admin/staging-auth/staging-auth-write-debug-ui.ts";
</script>

<style>
  .admin-auth-write-debug-panel {
    margin: 0 0 1.25rem;
    padding: 1rem 1.25rem;
    border: 1px solid #94a3b8;
    border-radius: 8px;
    background: #fffbeb;
  }
  .admin-auth-write-debug-panel__title {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: #78350f;
  }
  .admin-auth-write-debug-panel__note {
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
    color: #92400e;
  }
  .admin-auth-write-debug-panel__list {
    margin: 0;
    display: grid;
    gap: 0.35rem 1rem;
    grid-template-columns: max-content 1fr;
  }
  .admin-auth-write-debug-panel__list dt {
    font-weight: 600;
    color: #78350f;
  }
  .admin-auth-write-debug-panel__list dd {
    margin: 0;
    color: #1e293b;
    word-break: break-word;
  }
  .admin-auth-write-debug-panel__reasons {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.35rem 1rem;
  }
  .admin-auth-write-debug-panel__list code {
    font-size: 0.8125rem;
    background: #fde68a;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
  }
</style>
