---
/**
 * G-9g1 / G-9g2 — Staging shell Gosaki site_slug schedule edit (dry-run + gated Save).
 */
import AdminCard from "../../components/AdminCard.astro";
import AdminFormField from "../../components/AdminFormField.astro";
import type { SiteSlugScheduleEditBinding } from "../../../../../../src/lib/admin/staging-data/staging-schedule-site-slug-edit-binding";

interface Props {
  binding: SiteSlugScheduleEditBinding;
}

const { binding } = Astro.props;

const row = binding.targetRow;
const uiDisabled = binding.source !== "supabase" || !row;
const targetRowJson = row ? JSON.stringify(row) : "";
const initialTitle = row?.title ?? binding.g9g2DefaultTitle;
const saveSectionVisible = binding.g9g2Armed || Boolean(binding.g9g2ArmFailureReason);
---

<section
  id="admin-staging-schedule-site-slug-edit"
  class="admin-staging-schedule-site-slug-edit"
  data-phase={binding.phase}
  data-g9g2-phase={binding.g9g2Phase}
  data-approval-id={binding.approvalId}
  data-g9g2-approval-id={binding.g9g2ApprovalId}
  data-site-slug={binding.siteSlug}
  data-source={binding.source}
  data-dry-run-preview-only={binding.dryRunPreviewOnly ? "true" : "false"}
  data-actual-write="false"
  data-g9g2-armed={binding.g9g2Armed ? "true" : "false"}
  data-g9g2-save-enabled={binding.g9g2SaveEnabled ? "true" : "false"}
  data-g9g2-default-title={binding.g9g2DefaultTitle}
  data-target-row={targetRowJson}
  role="region"
  aria-label="Gosaki site_slug schedule edit"
>
  <h2 class="admin-staging-schedule-site-slug-edit__title">
    Schedule site_slug edit preview — dry-run + gated Save (G-9g2)
  </h2>

  <p class="admin-staging-schedule-site-slug-edit__safety" role="note">
    <strong>Dry-run only — preview path never writes.</strong> G-9g1 preview always{" "}
    <code>actualWrite=false</code>. Save is disabled in G-9g1.
    {
      binding.g9g2SaveEnabled ? (
          <>
            {" "}
            G-9g2 Save armed — operator manual Save only after successful preview.
          </>
        ) : (
          <>
            {" "}
            Save is disabled until G-9g2 env arm is satisfied.
          </>
        )
    }
  </p>

  {
    !binding.g9g2Armed ? (
      <p class="admin-staging-schedule-site-slug-edit__arm-note" role="note">
        <strong>G-9g2 title Save is not armed.</strong> Set{" "}
        <code>{binding.g9g2ArmEnv}=true</code> to enable operator-only PoC.
        {binding.g9g2ArmFailureReason ? ` (${binding.g9g2ArmFailureReason})` : ""}
      </p>
    ) : null
  }

  {
    binding.message ? (
      <p class="admin-staging-schedule-site-slug-edit__message" role="status">
        {binding.message}
      </p>
    ) : null
  }

  <dl class="admin-staging-schedule-site-slug-edit__summary">
    <div>
      <dt>Phase</dt>
      <dd>{binding.g9g2Phase}</dd>
    </div>
    <div>
      <dt>Dry-run approval ID</dt>
      <dd><code>{binding.approvalId}</code></dd>
    </div>
    <div>
      <dt>G-9g2 approval ID</dt>
      <dd><code>{binding.g9g2ApprovalId}</code></dd>
    </div>
    <div>
      <dt>Site slug</dt>
      <dd><code>{binding.siteSlug}</code></dd>
    </div>
    <div>
      <dt>G-9g2 armed</dt>
      <dd id="site-slug-edit-g9g2-armed-status">{binding.g9g2Armed ? "true" : "false"}</dd>
    </div>
    <div>
      <dt>Data source</dt>
      <dd>{binding.source === "supabase" ? "Supabase SELECT" : "Unavailable"}</dd>
    </div>
  </dl>

  <AdminCard title="Target row" description="Fixed — id + legacy_id + site_slug scoped">
    <dl class="admin-staging-schedule-site-slug-edit__target">
      <div>
        <dt>id</dt>
        <dd><code>{binding.targetId}</code></dd>
      </div>
      <div>
        <dt>legacy_id</dt>
        <dd><code>{binding.legacyId}</code></dd>
      </div>
      <div>
        <dt>site_slug</dt>
        <dd><code>{binding.siteSlug}</code></dd>
      </div>
      <div>
        <dt>updated_at</dt>
        <dd><code id="site-slug-edit-baseline-updated-at">{row?.updated_at ?? "—"}</code></dd>
      </div>
      <div>
        <dt>date</dt>
        <dd>{row?.date ?? "—"}</dd>
      </div>
    </dl>
  </AdminCard>

  <AdminCard
    title="Edit (title slice)"
    description="G-9g1 dry-run helper supports all safe fields; UI edits title only."
  >
    <AdminFormField label="Title">
      <input
        id="site-slug-edit-dry-run-title"
        type="text"
        value={initialTitle}
        disabled={uiDisabled}
        autocomplete="off"
      />
    </AdminFormField>

    <div class="admin-staging-schedule-site-slug-edit__actions">
      <button
        id="site-slug-edit-dry-run-preview-btn"
        class="admin-button"
        type="button"
        disabled={uiDisabled}
        title="Client-side dry-run preview — actualWrite=false"
      >
        Preview dry-run
      </button>
      {
        saveSectionVisible ? (
          <button
            id="site-slug-edit-g9g2-save-btn"
            class="admin-button admin-button--danger"
            type="button"
            disabled={true}
            title="G-9g2 title non-dry-run — requires preview + gates"
          >
            Save title PoC
          </button>
        ) : null
      }
    </div>
    <p id="site-slug-edit-g9g2-save-hint" class="admin-staging-schedule-site-slug-edit__hint" role="status">
      Save title PoC disabled — preview required.
    </p>
  </AdminCard>

  <AdminCard title="Dry-run result" description="G-9g1 preview — actualWrite=false always">
    <div
      id="site-slug-edit-dry-run-result"
      class="site-slug-edit-dry-run-result"
      aria-live="polite"
    >
      <p class="site-slug-edit-dry-run-result__placeholder">
        Click Preview dry-run to generate a client-side preview.
      </p>
    </div>
  </AdminCard>

  {
    saveSectionVisible ? (
      <AdminCard title="G-9g2 Save result" description="Non-dry-run — actualWrite=true only after operator Save">
        <div
          id="site-slug-edit-g9g2-save-result"
          class="site-slug-edit-save-result"
          aria-live="polite"
        >
          <p class="site-slug-edit-save-result__placeholder">
            Save title PoC not executed — operator manual action only.
          </p>
        </div>
      </AdminCard>
    ) : null
  }

  <AdminCard title="Safety flags">
    <dl class="admin-staging-schedule-site-slug-edit__flags">
      <div><dt>dryRunPreview actualWrite</dt><dd>false</dd></div>
      <div><dt>g9g2SaveEnabled</dt><dd>{binding.g9g2SaveEnabled ? "true" : "false"}</dd></div>
      <div><dt>restoreSaveImplemented</dt><dd>false</dd></div>
      <div><dt>writeAdapterUsed (preview)</dt><dd>false</dd></div>
      <div><dt>supabaseWriteCalled (preview)</dt><dd>false</dd></div>
    </dl>
  </AdminCard>
</section>

<script>
  import "../../../../../../src/lib/admin/staging-data/staging-schedule-site-slug-edit-ui.ts";
</script>

<style>
  .admin-staging-schedule-site-slug-edit {
    margin: 1.5rem 0 0;
    padding: 1rem;
    border: 1px solid #93c5fd;
    border-radius: 8px;
    background: #eff6ff;
  }

  .admin-staging-schedule-site-slug-edit__title {
    margin: 0 0 0.75rem;
    font-size: 1.1rem;
  }

  .admin-staging-schedule-site-slug-edit__safety,
  .admin-staging-schedule-site-slug-edit__arm-note {
    margin: 0 0 1rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-size: 0.9rem;
  }

  .admin-staging-schedule-site-slug-edit__safety {
    background: #dbeafe;
    border: 1px solid #93c5fd;
    color: #1e3a8a;
  }

  .admin-staging-schedule-site-slug-edit__arm-note {
    background: #fef3c7;
    border: 1px solid #fcd34d;
    color: #92400e;
  }

  .admin-staging-schedule-site-slug-edit__summary,
  .admin-staging-schedule-site-slug-edit__target,
  .admin-staging-schedule-site-slug-edit__flags {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(10rem, 1fr));
    gap: 0.75rem 1rem;
    margin: 0;
    font-size: 0.9rem;
  }

  .admin-staging-schedule-site-slug-edit__summary dt,
  .admin-staging-schedule-site-slug-edit__target dt,
  .admin-staging-schedule-site-slug-edit__flags dt {
    font-weight: 600;
    color: #64748b;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .admin-staging-schedule-site-slug-edit__summary dd,
  .admin-staging-schedule-site-slug-edit__target dd,
  .admin-staging-schedule-site-slug-edit__flags dd {
    margin: 0.15rem 0 0;
  }

  .admin-staging-schedule-site-slug-edit__message,
  .admin-staging-schedule-site-slug-edit__hint {
    margin: 0.5rem 0 0;
    font-size: 0.875rem;
    color: #475569;
  }

  .admin-staging-schedule-site-slug-edit__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .site-slug-edit-dry-run-result__placeholder,
  .site-slug-edit-save-result__placeholder {
    margin: 0;
    color: #64748b;
    font-size: 0.875rem;
  }

  .site-slug-edit-dry-run-result__message,
  .site-slug-edit-save-result__message {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
  }

  .site-slug-edit-dry-run-result__meta,
  .site-slug-edit-save-result__meta {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(12rem, 1fr));
    gap: 0.5rem 1rem;
    margin: 0 0 1rem;
    font-size: 0.85rem;
  }

  .site-slug-edit-dry-run-result__meta dt,
  .site-slug-edit-save-result__meta dt {
    font-weight: 600;
    color: #64748b;
    font-size: 0.7rem;
    text-transform: uppercase;
  }

  .site-slug-edit-dry-run-result__meta dd,
  .site-slug-edit-save-result__meta dd {
    margin: 0.1rem 0 0;
    word-break: break-all;
  }

  .site-slug-edit-dry-run-result__subhead,
  .site-slug-edit-save-result__subhead {
    margin: 0.75rem 0 0.35rem;
    font-size: 0.85rem;
  }

  .site-slug-edit-dry-run-result__block,
  .site-slug-edit-save-result__block {
    margin: 0;
    padding: 0.5rem 0.75rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    font-size: 0.75rem;
    overflow-x: auto;
  }

  .site-slug-edit-dry-run-result__stale {
    margin: 0 0 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    background: #fef3c7;
    border: 1px solid #fcd34d;
    color: #92400e;
    font-size: 0.875rem;
  }

  .site-slug-edit-dry-run-result__fresh {
    color: #065f46;
  }
</style>
