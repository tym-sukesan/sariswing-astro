---
/**
 * Gosaki staging shell operator portal.
 * Cards are the primary nav — no horizontal tabs on the home route.
 */
import AdminGosakiStagingSafetyChips from "./AdminGosakiStagingSafetyChips.astro";
import AdminGosakiStagingCompactAuthBar from "./AdminGosakiStagingCompactAuthBar.astro";
import {
  GOSAKI_STAGING_ADMIN_ABOUT_PATH,
  GOSAKI_STAGING_ADMIN_DISCOGRAPHY_PATH,
  GOSAKI_STAGING_ADMIN_SCHEDULE_PATH,
  GOSAKI_STAGING_ADMIN_YOUTUBE_PATH,
  GOSAKI_STAGING_PREVIEW_URL,
} from "../gosaki-staging-admin-paths";

interface Props {
  previewUrl?: string;
  schedulePath?: string;
  supabaseAuthConfigured?: boolean;
  /** STG package portal needs inline auth; local shell AuthGate already handles it. */
  showAuthBar?: boolean;
}

const {
  previewUrl = GOSAKI_STAGING_PREVIEW_URL,
  schedulePath = GOSAKI_STAGING_ADMIN_SCHEDULE_PATH,
  supabaseAuthConfigured = false,
  showAuthBar = true,
} = Astro.props;

const portalCards = [
  {
    id: "schedule",
    title: "Schedule",
    href: schedulePath,
    blurb: "公演スケジュールの確認・追加・編集",
  },
  {
    id: "discography",
    title: "Discography",
    href: GOSAKI_STAGING_ADMIN_DISCOGRAPHY_PATH,
    blurb: "作品情報の確認・編集",
  },
  {
    id: "youtube",
    title: "YouTube",
    href: GOSAKI_STAGING_ADMIN_YOUTUBE_PATH,
    blurb: "トップページの動画一覧",
  },
  {
    id: "about",
    title: "Profile",
    href: GOSAKI_STAGING_ADMIN_ABOUT_PATH,
    blurb: "プロフィール・バンド紹介",
  },
];
---

<section
  id="gosaki-home"
  class="admin-gosaki-operator-home admin-gosaki-operator-portal admin-prototype-section"
  data-section="admin-home"
  data-gosaki-admin-portal="true"
  aria-label="Gosaki Piano 管理画面トップ"
>
  <header class="admin-gosaki-page-header">
    <div>
      <h1 class="admin-gosaki-page-header__title">Gosaki Piano CMS</h1>
      <p class="admin-gosaki-page-header__subtitle">
        管理したい項目を選んでください。
      </p>
      <AdminGosakiStagingSafetyChips />
    </div>
  </header>

  {
    showAuthBar ? (
      <AdminGosakiStagingCompactAuthBar
        supabaseAuthConfigured={supabaseAuthConfigured}
        purposeNote="変更の確認・保存にはログインが必要です（HTTP Basic 認証とは別です）。"
        showDeveloperTools={false}
      />
    ) : null
  }

  <section
    class="admin-gosaki-portal-cards"
    aria-labelledby="gosaki-portal-cards-title"
    data-gosaki-portal-cards="true"
  >
    <h2 class="admin-gosaki-card__title--visually-quiet" id="gosaki-portal-cards-title">
      管理メニュー
    </h2>
    <ul class="admin-gosaki-portal-cards__list">
      {
        portalCards.map((card) => (
          <li class="admin-gosaki-portal-card">
            <a class="admin-gosaki-portal-card__link" href={card.href} data-portal-card={card.id}>
              <span class="admin-gosaki-portal-card__title">{card.title}</span>
              <span class="admin-gosaki-portal-card__blurb">{card.blurb}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <p class="admin-gosaki-portal-preview">
    <a
      class="admin-button admin-button-secondary"
      href={previewUrl}
      target="_blank"
      rel="noopener noreferrer"
      data-gosaki-public-preview-link="true"
    >
      公開サイトを確認する
    </a>
  </p>
</section>
