---
import type { GosakiAboutContentAdminBinding } from "../../../../../../src/lib/admin/staging-data/gosaki-about-content-admin-binding";
import {
  GOSAKI_ABOUT_CONTENT_BLOCK_BANDS_ID,
  GOSAKI_ABOUT_CONTENT_BLOCK_PROFILE_ID,
} from "../../../../../../src/lib/admin/staging-data/gosaki-about-content-admin-binding";
import {
  G10H4A_SAVE_BUTTON_PAGE_CONFIG_ELEMENT_ID,
  resolveG10h4aSaveButtonPageServerConfig,
} from "../../../../../../src/lib/admin/staging-write/gosaki-about-profile-html-static-json-write-page-config";
import {
  G10H4A_ABOUT_PROFILE_HTML_STATIC_JSON_WRITE_APPROVAL_ID,
  G10H4A_SITE_SLUG,
  G10H4A_WRITE_MODULE,
  G10H4A_WRITE_PROVIDER,
} from "../../../../../../src/lib/admin/staging-write/gosaki-about-profile-html-static-json-write-types";
import {
  GOSAKI_STAGING_ADMIN_BASE,
  GOSAKI_STAGING_PREVIEW_URL,
} from "../gosaki-staging-admin-paths";

interface Props {
  binding: GosakiAboutContentAdminBinding;
}

const { binding } = Astro.props;
const previewAboutUrl = `${GOSAKI_STAGING_PREVIEW_URL}${binding.config.previewPath ?? "about/"}`;
const profileView =
  binding.blocks.find((view) => view.block.id === GOSAKI_ABOUT_CONTENT_BLOCK_PROFILE_ID) ?? null;
const bandsView =
  binding.blocks.find((view) => view.block.id === GOSAKI_ABOUT_CONTENT_BLOCK_BANDS_ID) ?? null;

const g10h4aPageConfig = resolveG10h4aSaveButtonPageServerConfig(import.meta.env);
const saveDisabledNote = g10h4aPageConfig.saveButtonSaveEnabled
  ? "Save env は有効です。dry-run 成功後、about-profile-html の html のみ1回 Save できます。"
  : "保存は無効です（G10H4A_ABOUT_PROFILE_HTML_SAVE_ENABLED=false）。dry-run のみ可能です。";
---

<section
  id="gosaki-about-operator"
  class="admin-gosaki-about-operator admin-page admin-page--wide admin-prototype-section"
  data-section="admin-about"
  data-phase="G-10h4b-gosaki-about-profile-html-static-json-write-execution"
  aria-label="About HTML管理"
>
  <div
    id={G10H4A_SAVE_BUTTON_PAGE_CONFIG_ELEMENT_ID}
    data-g10h4a-save-button-save-enabled={g10h4aPageConfig.saveButtonSaveEnabled ? "true" : "false"}
    data-g10h4a-staging-shell-enabled={g10h4aPageConfig.stagingShellEnabled ? "true" : "false"}
    data-g10h4a-write-provider={g10h4aPageConfig.writeProvider || G10H4A_WRITE_PROVIDER}
    data-g10h4a-write-module={g10h4aPageConfig.writeModule || G10H4A_WRITE_MODULE}
    data-g10h4a-write-approval-id={g10h4aPageConfig.writeApprovalId || G10H4A_ABOUT_PROFILE_HTML_STATIC_JSON_WRITE_APPROVAL_ID}
    hidden
  />

  <header class="admin-gosaki-page-header admin-gosaki-page-header--with-actions">
    <div>
      <a class="admin-gosaki-back-link" href={GOSAKI_STAGING_ADMIN_BASE}>← 管理画面トップへ</a>
      <h1 class="admin-gosaki-page-header__title">About HTML</h1>
      <p class="admin-gosaki-page-header__subtitle">
        /about/ の本文 HTML ブロックを編集・確認する画面です（G-10h4b profile Save）。
      </p>
    </div>
    <button
      type="button"
      class="admin-button admin-button-secondary admin-gosaki-logout-btn"
      data-staging-sign-out
      hidden
    >
      ログアウト
    </button>
  </header>

  <p class="admin-form__hint admin-static-notice" role="note">
    <strong>about-profile-html</strong> のみ dry-run / Save 対象です。about-bands-html は今回の保存対象外です。
  </p>

  <p class="admin-gosaki-status-bar admin-gosaki-status-bar--soft" role="status">
    {saveDisabledNote}
  </p>

  {
    binding.message ? (
      <p class="admin-gosaki-operator-alert" role="alert">{binding.message}</p>
    ) : null
  }

  <section class="admin-card admin-gosaki-card">
    <h2 class="admin-gosaki-card__title">設定ファイル</h2>
    <dl class="gosaki-about-admin-meta">
      <div>
        <dt>config path</dt>
        <dd><code>{binding.configPath}</code></dd>
      </div>
      <div>
        <dt>siteSlug</dt>
        <dd><code>{binding.config.siteSlug ?? "—"}</code></dd>
      </div>
      <div>
        <dt>page</dt>
        <dd><code>{binding.config.page ?? "—"}</code></dd>
      </div>
      <div>
        <dt>version</dt>
        <dd>{binding.config.version ?? "—"}</dd>
      </div>
      <div>
        <dt>previewPath</dt>
        <dd><code>{binding.config.previewPath ?? "about/"}</code></dd>
      </div>
      <div>
        <dt>block count</dt>
        <dd>{binding.blockCount}（enabled: {binding.enabledBlockCount}）</dd>
      </div>
      <div>
        <dt>approvalId</dt>
        <dd><code>{G10H4A_ABOUT_PROFILE_HTML_STATIC_JSON_WRITE_APPROVAL_ID}</code></dd>
      </div>
      <div>
        <dt>siteSlug (write)</dt>
        <dd><code>{G10H4A_SITE_SLUG}</code></dd>
      </div>
    </dl>
  </section>

  <section class="admin-card admin-gosaki-card">
    <h2 class="admin-gosaki-card__title">公開前ページ</h2>
    <a
      class="admin-button admin-button--menu admin-button--menu-secondary"
      href={previewAboutUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      Aboutページを見る
    </a>
  </section>

  <section class="admin-card admin-gosaki-card gosaki-about-admin-safety">
    <h2 class="admin-gosaki-card__title">HTML 安全メモ</h2>
    <ul class="admin-gosaki-list admin-gosaki-list--compact">
      <li>dry-run では <code>&lt;script&gt;</code> / <code>&lt;iframe&gt;</code> / <code>on*</code> / <code>javascript:</code> を拒否します。</li>
      <li><code>style=""</code> インライン属性は Wix 互換のため許容します。</li>
      <li><code>&lt;style&gt;</code> ブロックは warning です（profile block）。</li>
      <li>プレビューは管理画面内のコンテナに表示します（iframe は使用しません）。</li>
    </ul>
  </section>

  {
    profileView ? (
      <section
        class="admin-card admin-gosaki-card gosaki-about-admin-block-card gosaki-about-admin-block-card--profile"
        data-block-id={profileView.block.id}
        aria-labelledby="gosaki-about-block-title-profile"
      >
        <header class="gosaki-about-admin-block-card__header">
          <h2 class="admin-gosaki-card__title" id="gosaki-about-block-title-profile">
            {profileView.block.label}
          </h2>
          <p class="admin-gosaki-card__lead">G-10h4a 保存対象ブロック（dry-run のみ）</p>
          <dl class="gosaki-about-admin-block-meta">
            <div>
              <dt>block id</dt>
              <dd><code>{profileView.block.id}</code></dd>
            </div>
            <div>
              <dt>enabled</dt>
              <dd>
                <span
                  class={`gosaki-about-admin-block-meta__status gosaki-about-admin-block-meta__status--${profileView.block.enabled ? "enabled" : "disabled"}`}
                >
                  {profileView.block.enabled ? "true" : "false"}
                </span>
              </dd>
            </div>
            <div>
              <dt>html length</dt>
              <dd>
                <span id="gosaki-about-profile-html-length">
                  {profileView.htmlLength.toLocaleString("ja-JP")}
                </span>{" "}
                文字
              </dd>
            </div>
            <div>
              <dt>lines</dt>
              <dd>{profileView.lineCount.toLocaleString("ja-JP")}</dd>
            </div>
          </dl>
        </header>

        <div class="gosaki-about-admin-block-grid">
          <label class="admin-form__field admin-form__field--full">
            <span class="admin-form__label">HTML ソース（編集可 — profile のみ）</span>
            <textarea
              class="gosaki-about-admin-textarea"
              rows="14"
              id="gosaki-about-html-source-profile"
              data-gosaki-about-profile-html-editor
            >{profileView.block.html}</textarea>
          </label>

          <div class="admin-form__field admin-form__field--full">
            <span class="admin-form__label">プレビュー</span>
            <div
              class="gosaki-about-admin-preview"
              id="gosaki-about-preview-profile"
              data-gosaki-about-profile-preview
              set:html={profileView.block.html}
            />
          </div>
        </div>

        <div class="admin-actions gosaki-about-admin-profile-actions">
          <button type="button" class="admin-button admin-button-secondary" id="gosaki-about-profile-dry-run-btn">
            dry-run 確認
          </button>
          <button
            type="button"
            class="admin-button"
            id="gosaki-about-profile-save-btn"
            data-gosaki-about-save-disabled
            disabled
          >
            保存する（env disabled）
          </button>
        </div>
        <p class="admin-gosaki-save-note" id="gosaki-about-profile-save-note" role="note">
          ※ dry-run 成功後、env が有効な場合のみ Save できます。
        </p>

        <div
          id="gosaki-about-profile-dry-run-result"
          class="gosaki-schedule-edit-dry-run"
          hidden
        />
        <div
          id="gosaki-about-profile-save-result"
          class="gosaki-schedule-edit-save-result"
          hidden
        />
      </section>
    ) : (
      <p class="admin-gosaki-operator-empty">about-profile-html ブロックが見つかりません。</p>
    )
  }

  {
    bandsView ? (
      <section
        class="admin-card admin-gosaki-card gosaki-about-admin-block-card gosaki-about-admin-block-card--bands"
        data-block-id={bandsView.block.id}
        aria-labelledby="gosaki-about-block-title-bands"
      >
        <header class="gosaki-about-admin-block-card__header">
          <h2 class="admin-gosaki-card__title" id="gosaki-about-block-title-bands">
            {bandsView.block.label}
          </h2>
          <p class="admin-gosaki-card__lead admin-gosaki-operator-alert--soft" role="note">
            Bands / Projects は今回の保存対象外です。
          </p>
          <dl class="gosaki-about-admin-block-meta">
            <div>
              <dt>block id</dt>
              <dd><code>{bandsView.block.id}</code></dd>
            </div>
            <div>
              <dt>enabled</dt>
              <dd>
                <span
                  class={`gosaki-about-admin-block-meta__status gosaki-about-admin-block-meta__status--${bandsView.block.enabled ? "enabled" : "disabled"}`}
                >
                  {bandsView.block.enabled ? "true" : "false"}
                </span>
              </dd>
            </div>
            <div>
              <dt>html length</dt>
              <dd>{bandsView.htmlLength.toLocaleString("ja-JP")} 文字</dd>
            </div>
            <div>
              <dt>lines</dt>
              <dd>{bandsView.lineCount.toLocaleString("ja-JP")}</dd>
            </div>
          </dl>
        </header>

        <div class="gosaki-about-admin-block-grid">
          <label class="admin-form__field admin-form__field--full">
            <span class="admin-form__label">HTML ソース（読み取り専用）</span>
            <textarea
              class="gosaki-about-admin-textarea"
              rows="14"
              readonly
              data-gosaki-about-html-source-readonly
              id={`gosaki-about-html-source-${bandsView.block.id}`}
            >{bandsView.block.html}</textarea>
          </label>

          <div class="admin-form__field admin-form__field--full">
            <span class="admin-form__label">プレビュー</span>
            <div
              class="gosaki-about-admin-preview"
              id={`gosaki-about-preview-${bandsView.block.id}`}
              data-gosaki-about-preview-readonly
              set:html={bandsView.block.html}
            />
          </div>
        </div>
      </section>
    ) : null
  }
</section>

<style>
  .gosaki-about-admin-meta,
  .gosaki-about-admin-block-meta {
    display: grid;
    gap: 0.75rem 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    margin: 0;
  }

  .gosaki-about-admin-meta dt,
  .gosaki-about-admin-block-meta dt {
    font-size: 0.75rem;
    color: #6b5f56;
    margin: 0 0 0.15rem;
  }

  .gosaki-about-admin-meta dd,
  .gosaki-about-admin-block-meta dd {
    margin: 0;
    font-size: 0.9rem;
  }

  .gosaki-about-admin-block-card__header {
    margin-bottom: 1rem;
  }

  .gosaki-about-admin-block-grid {
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 960px) {
    .gosaki-about-admin-block-grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .gosaki-about-admin-textarea {
    width: 100%;
    min-height: 16rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 12px;
    line-height: 1.5;
    box-sizing: border-box;
  }

  .gosaki-about-admin-preview {
    min-height: 16rem;
    max-height: 28rem;
    overflow: auto;
    padding: 1rem;
    border: 1px solid #d8cfc4;
    border-radius: 4px;
    background: #fffaf5;
    box-sizing: border-box;
  }

  .gosaki-about-admin-block-meta__status--enabled {
    color: #2f6b3c;
  }

  .gosaki-about-admin-block-meta__status--disabled {
    color: #8a5a2b;
  }

  .gosaki-about-admin-profile-actions {
    margin-top: 1rem;
    gap: 0.75rem;
  }

  .admin-gosaki-operator-alert--soft {
    color: #6b5f56;
    margin: 0 0 0.75rem;
  }
</style>

<script>
  import "../../../../../../src/lib/admin/staging-data/gosaki-staging-about-content-admin-ui.ts";
</script>
