---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { supabase } from "../../../lib/supabase";

const { data: posts } = await supabase
  .from("instagram_posts")
  .select("*")
  .order("id", { ascending: false });
---

<BaseLayout title="Instagram Admin | SARI" admin>
  <main class="admin-page admin-page--wide">
    <div class="admin-page-header">
      <a class="admin-back-link" href="/admin/">← 管理画面トップ</a>
      <h1>Instagram管理</h1>
    </div>

    <section class="admin-card">
      <h2>埋め込みコード追加</h2>

      <div class="admin-form">
        <label class="admin-form__field">
          <span class="admin-form__label">埋め込みコード</span>
          <textarea
            id="embed_code"
            rows="6"
            placeholder="<blockquote class=&quot;instagram-media&quot; ...></blockquote>"
          ></textarea>
        </label>
      </div>

      <div class="admin-actions">
        <button id="add" class="admin-button" type="button">追加</button>
      </div>
      <p id="message" class="admin-message"></p>
    </section>

    <section class="admin-card">
      <h2>現在のInstagram埋め込み</h2>

      <ul id="postList" class="admin-list instagram-admin-list">
        {posts?.map((item) => (
          <li class="admin-list__item instagram-admin-item" data-id={item.id}>
            <div class="instagram-admin-item__preview">
              {item.embed_code && (
                <div class="instagram-admin-preview" set:html={item.embed_code} />
              )}
            </div>

            <div class="instagram-admin-item__editor">
              <div class="admin-form">
                <label class="admin-form__field">
                  <span class="admin-form__label">埋め込みコード</span>
                  <textarea class="edit-embed-code" rows="6">{item.embed_code}</textarea>
                </label>
              </div>

              <div class="admin-actions">
                <button class="admin-button update" type="button">更新</button>
                <button class="admin-button admin-button-danger delete" type="button">削除</button>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <script async src="https://www.instagram.com/embed.js"></script>

  <script>
    import "../../../scripts/admin/instagram.ts";
  </script>
</BaseLayout>
