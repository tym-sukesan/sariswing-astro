---
/**
 * G-6-d-staging-password-reset-callback — Staging-only password reset callback UI.
 * Not /admin/. Anon client only. No resetPasswordForEmail.
 */
import { getStagingAuthConfig } from "../../../../../../src/lib/admin/staging-auth/staging-auth-config";

interface Props {
  phase?: string;
}

const { phase = "G-6-d-staging-password-reset-callback" } = Astro.props;
const authConfig = getStagingAuthConfig();
const interactive =
  authConfig.stagingAuthEnabled && authConfig.supabaseConfigured;
---

<section
  id="staging-password-reset-callback"
  class="admin-staging-password-reset-callback"
  data-phase={phase}
  data-auth-enabled={interactive ? "true" : "false"}
>
  <header class="admin-staging-password-reset-callback__header">
    <h2 class="admin-staging-password-reset-callback__title">
      Password reset callback ({phase})
    </h2>
    <p class="admin-staging-password-reset-callback__notice">
      Staging shell only. Use Supabase Dashboard → Send password recovery. This UI
      calls <code>updateUser(&#123; password &#125;)</code> with the anon client
      when a recovery session is detected. No reset email is sent from this app.
    </p>
    <p class="admin-staging-password-reset-callback__notice-ja" lang="ja">
      本番 Auth には接続しません。トークンは表示しません。PUBLIC_ADMIN_WRITE_DRY_RUN=true
      のまま profile update は行いません。
    </p>
  </header>

  <dl class="admin-staging-password-reset-callback__status">
    <div>
      <dt>Callback enabled</dt>
      <dd id="staging-password-reset-enabled">{interactive ? "true" : "false"}</dd>
    </div>
    <div>
      <dt>Callback status</dt>
      <dd id="staging-password-reset-status">
        {interactive ? "loading" : "disabled"}
      </dd>
    </div>
    <div>
      <dt>Recovery session detected</dt>
      <dd id="staging-password-reset-recovery-detected">false</dd>
    </div>
    <div>
      <dt>User email</dt>
      <dd id="staging-password-reset-user-email">—</dd>
    </div>
  </dl>

  <p
    id="staging-password-reset-error"
    class="admin-staging-password-reset-callback__error"
    hidden=""
    role="alert"
  />

  <p
    id="staging-password-reset-success"
    class="admin-staging-password-reset-callback__success"
    hidden=""
    role="status"
  />

  <div id="staging-password-reset-form" class="admin-staging-password-reset-callback__form" hidden>
    <div class="admin-staging-password-reset-callback__field">
      <label for="staging-password-reset-new">New password</label>
      <input
        id="staging-password-reset-new"
        type="password"
        name="new-password"
        autocomplete="new-password"
        minlength="8"
        disabled={!interactive}
      />
    </div>
    <div class="admin-staging-password-reset-callback__field">
      <label for="staging-password-reset-confirm">Confirm new password</label>
      <input
        id="staging-password-reset-confirm"
        type="password"
        name="confirm-password"
        autocomplete="new-password"
        minlength="8"
        disabled={!interactive}
      />
    </div>
    <div class="admin-staging-password-reset-callback__actions">
      <button
        id="staging-password-reset-submit"
        type="button"
        class="admin-button"
        disabled={!interactive}
      >
        Update password
      </button>
      <button id="staging-password-reset-back-login" type="button" class="admin-button admin-button--secondary">
        Back to login
      </button>
      <button id="staging-password-reset-sign-out" type="button" class="admin-button admin-button--secondary">
        Sign out
      </button>
    </div>
  </div>

  {
    !interactive ? (
      <p class="admin-staging-password-reset-callback__hint" role="status">
        Enable staging Supabase Auth (ENABLE_ADMIN_STAGING_AUTH=true,
        PUBLIC_ADMIN_AUTH_PROVIDER=supabase) to use password reset callback.
      </p>
    ) : (
      <p class="admin-staging-password-reset-callback__hint" role="status">
        After clicking the recovery email link, open this staging shell route with
        the URL hash intact (or navigate here before the hash is cleared). Minimum
        8 characters. Do not paste tokens into chat or docs.
      </p>
    )
  }
</section>

<script>
  import "../../../../../../src/lib/admin/staging-auth/staging-password-reset-ui.ts";
</script>

<style>
  .admin-staging-password-reset-callback {
    margin: 0 0 1.25rem;
    padding: 1.25rem;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    background: #f8fafc;
  }
  .admin-staging-password-reset-callback__title {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: #0f172a;
  }
  .admin-staging-password-reset-callback__notice {
    margin: 0 0 0.35rem;
    font-size: 0.875rem;
    color: #334155;
  }
  .admin-staging-password-reset-callback__notice-ja {
    margin: 0 0 0.75rem;
    font-size: 0.8125rem;
    color: #64748b;
  }
  .admin-staging-password-reset-callback__status {
    margin: 0 0 1rem;
    display: grid;
    gap: 0.35rem 1rem;
    grid-template-columns: max-content 1fr;
  }
  .admin-staging-password-reset-callback__status dt {
    font-weight: 600;
    color: #475569;
  }
  .admin-staging-password-reset-callback__status dd {
    margin: 0;
    color: #1e293b;
  }
  .admin-staging-password-reset-callback__error {
    margin: 0 0 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #991b1b;
    font-size: 0.875rem;
  }
  .admin-staging-password-reset-callback__success {
    margin: 0 0 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    background: #ecfdf5;
    border: 1px solid #a7f3d0;
    color: #065f46;
    font-size: 0.875rem;
  }
  .admin-staging-password-reset-callback__form {
    display: grid;
    gap: 0.75rem;
    max-width: 24rem;
  }
  .admin-staging-password-reset-callback__field label {
    display: block;
    margin-bottom: 0.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #334155;
  }
  .admin-staging-password-reset-callback__field input {
    width: 100%;
    padding: 0.5rem 0.65rem;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    font-size: 0.9375rem;
  }
  .admin-staging-password-reset-callback__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }
  .admin-staging-password-reset-callback__hint {
    margin: 0.75rem 0 0;
    font-size: 0.8125rem;
    color: #64748b;
  }
  .admin-button {
    padding: 0.45rem 0.85rem;
    border-radius: 6px;
    border: 1px solid #94a3b8;
    background: #e2e8f0;
    color: #0f172a;
    font-size: 0.875rem;
    cursor: pointer;
  }
  .admin-button:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }
  .admin-button--secondary {
    background: #fff;
  }
</style>
