---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="新しいパスワードの設定 | SARI" admin showDeployBar={false}>
  <main class="admin-page admin-page--auth">
    <div class="admin-page-header">
      <h1>新しいパスワードの設定</h1>
    </div>

    <section class="admin-card admin-auth-card">
      <form id="resetPasswordForm" class="admin-form admin-auth-form" novalidate>
        <label class="admin-form__field">
          <span class="admin-form__label">新しいパスワード</span>
          <input
            id="resetPasswordNew"
            type="password"
            name="password"
            autocomplete="new-password"
            minlength="6"
            required
          />
        </label>

        <label class="admin-form__field">
          <span class="admin-form__label">新しいパスワード（確認）</span>
          <input
            id="resetPasswordConfirm"
            type="password"
            name="password_confirm"
            autocomplete="new-password"
            minlength="6"
            required
          />
        </label>

        <div class="admin-actions admin-auth-form__actions">
          <button id="resetPasswordSubmit" class="admin-button" type="submit">
            パスワードを保存
          </button>
        </div>
      </form>

      <div id="resetPasswordInvalid" class="admin-auth-invalid is-hidden" role="alert">
        <p class="admin-message admin-message--error">
          リンクが無効か期限切れです。もう一度パスワード再設定をお試しください。
        </p>
        <p class="admin-auth-links">
          <a href="/admin/forgot-password/">パスワード再設定をやり直す</a>
        </p>
      </div>

      <p id="resetPasswordError" class="admin-message admin-message--error is-hidden" role="alert"></p>
    </section>
  </main>

  <script>
    import "../../../scripts/admin/reset-password.ts";
  </script>
</BaseLayout>
