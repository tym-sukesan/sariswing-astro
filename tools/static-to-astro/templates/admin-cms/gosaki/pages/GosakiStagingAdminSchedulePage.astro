---
import AdminGosakiStagingShellLayout from "../components/AdminGosakiStagingShellLayout.astro";
import AdminGosakiStagingScheduleOperatorPage from "../components/AdminGosakiStagingScheduleOperatorPage.astro";
import AdminGosakiStagingAuthGate from "../components/AdminGosakiStagingAuthGate.astro";
import AdminStagingScheduleSiteSlugReadSection from "../../data/components/AdminStagingScheduleSiteSlugReadSection.astro";
import AdminStagingScheduleSiteSlugRowPickerSection from "../../data/components/AdminStagingScheduleSiteSlugRowPickerSection.astro";
import AdminStagingScheduleSiteSlugEditSection from "../../data/components/AdminStagingScheduleSiteSlugEditSection.astro";
import AdminStagingScheduleGeneralEditSection from "../../data/components/AdminStagingScheduleGeneralEditSection.astro";
import AdminStagingScheduleSafeFieldsDryRunSection from "../../data/components/AdminStagingScheduleSafeFieldsDryRunSection.astro";
import AdminStagingScheduleSafeFieldsNonDryRunPocSection from "../../data/components/AdminStagingScheduleSafeFieldsNonDryRunPocSection.astro";
import { resolveGosakiScheduleSiteSlugRowPickerBinding } from "../../../../../../src/lib/admin/staging-data/staging-schedule-site-slug-row-picker-binding";
import { resolveGosakiScheduleSiteSlugReadBinding } from "../../../../../../src/lib/admin/staging-data/staging-schedule-site-slug-read-binding";
import { resolveGosakiScheduleSiteSlugEditBinding } from "../../../../../../src/lib/admin/staging-data/staging-schedule-site-slug-edit-binding";

const rowPickerBinding = await resolveGosakiScheduleSiteSlugRowPickerBinding();
const readBinding = await resolveGosakiScheduleSiteSlugReadBinding();
const editBinding = await resolveGosakiScheduleSiteSlugEditBinding();
---

<AdminGosakiStagingShellLayout title="スケジュール管理">
  <AdminGosakiStagingAuthGate>
    <div class="admin-gosaki-admin-pages">
      <AdminGosakiStagingScheduleOperatorPage binding={rowPickerBinding} />

      <details class="admin-gosaki-dev-tools admin-gosaki-dev-tools--schedule gosaki-schedule-dev-tools-panel">
        <summary>開発者向け詳細 — mock / dry-run PoC（通常操作では使わない）</summary>
        <div class="gosaki-schedule-dev-tools-panel__warning" role="alert">
          <p>
            <strong>運用者向けではありません。</strong>
            このセクションは内部検証用の mock / fixture / dry-run PoC UI です。
            <code>mock-schedule-*</code> や「Selected schedule: mock-schedule-…」は<strong>実データではありません</strong>。
            Gosaki の通常 Schedule 操作はページ<strong>上部</strong>のオペレーター UI（公演一覧・legacy_id 表示）を使用してください。
            非公開化は上部 UI の「非公開化案を作成」から行います（ページ内検索は「非公開」を使用）。
          </p>
        </div>
        <div class="gosaki-schedule-dev-mock-zone" aria-label="開発者向け mock / dry-run PoC">
        {
          readBinding ? (
            <AdminStagingScheduleSiteSlugReadSection binding={readBinding} />
          ) : null
        }
        <AdminStagingScheduleSiteSlugRowPickerSection binding={rowPickerBinding} />
        {
          editBinding ? (
            <AdminStagingScheduleSiteSlugEditSection binding={editBinding} />
          ) : null
        }
        <AdminStagingScheduleGeneralEditSection
          phase="G-6-g1-schedule-title-non-dry-run-slice-implementation"
          g6g2Phase="G-6-g2-schedule-time-fields-non-dry-run-slice-implementation"
        />
        <AdminStagingScheduleSafeFieldsDryRunSection phase="G-6-f4-schedule-safe-fields-dry-run-prototype" />
        <AdminStagingScheduleSafeFieldsNonDryRunPocSection phase="G-6-f6-schedule-safe-fields-non-dry-run-poc-implementation" />
        </div>
      </details>
    </div>
  </AdminGosakiStagingAuthGate>
</AdminGosakiStagingShellLayout>
