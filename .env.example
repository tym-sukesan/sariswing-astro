PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# 画像アップロード用 Storage バケット名（既定: images）
# PUBLIC_STORAGE_BUCKET=images

# Local-only Admin preview route (G-5u) — CMS Kit scaffold at /__admin-preview/musician-basic/
# Must remain false by default. Enable ONLY for local dev: ENABLE_ADMIN_PREVIEW=true npm run dev
# Never enable on production. Does not connect to real admin, DB, Storage, or Publish.
ENABLE_ADMIN_PREVIEW=false

# Local/staging-only Admin runtime shell route (G-5x) — CMS Kit shell at /__admin-staging-shell/musician-basic/
# Must remain false by default. Enable ONLY for local dev: ENABLE_ADMIN_STAGING_SHELL=true npm run dev
# Never enable on production. Shell-only; not /admin/; no Auth, DB, Storage, or Publish.
ENABLE_ADMIN_STAGING_SHELL=false

# Staging-only Admin Auth draft (G-5y-a plan).
# Disabled by default. Do not enable production auth with this flag.
# Auth is NOT connected in G-5y-a. No Supabase client, DB, or RLS changes.
ENABLE_ADMIN_STAGING_AUTH=false
