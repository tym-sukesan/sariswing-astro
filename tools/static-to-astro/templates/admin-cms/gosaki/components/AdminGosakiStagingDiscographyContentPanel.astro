---
/**
 * Shared Discography operational panel (local shell + STG package).
 * View mode → Edit mode (1 album) · dry-run · gated Save (single Save card) · no image edit.
 */
import AdminGosakiStagingEditToolbar from "./AdminGosakiStagingEditToolbar.astro";

export interface DiscographyAlbumView {
  legacyId: string;
  title: string;
  artist?: string | null;
  releaseDate?: string | null;
  label?: string | null;
  catalogNumber?: string | null;
  published?: boolean;
  coverImageUrl?: string | null;
  purchaseUrl?: string | null;
  streamingUrl?: string | null;
  description?: string | null;
  trackListText?: string;
  trackCount?: number;
  updatedAt?: string | null;
}

interface Props {
  albums?: DiscographyAlbumView[];
  dataSource?: string;
  releaseCount?: number;
  trackCount?: number;
  publicDiscographyUrl?: string;
  dryRunEndpointConfigured?: boolean;
}

const {
  albums = [],
  dataSource = "build-snapshot",
  releaseCount = albums.length,
  trackCount = albums.reduce((n, a) => n + (a.trackCount ?? 0), 0),
  publicDiscographyUrl = "",
  dryRunEndpointConfigured = false,
} = Astro.props as Props;

function display(value: string | null | undefined): string {
  const t = String(value ?? "").trim();
  return t || "—";
}
---

<section
  id="gosaki-discography-content"
  class="gosaki-admin-content-panel gosaki-discography-content-panel"
  data-section="admin-discography-content"
  data-gosaki-discography-content="true"
  data-gosaki-discography-operational-edit="true"
  data-mode="view"
  data-dry-run-endpoint-configured={dryRunEndpointConfigured ? "true" : "false"}
  aria-label="ディスコグラフィー管理"
>
  <header class="gosaki-admin-content-panel__header">
    <h1 class="gosaki-admin-content-panel__title">ディスコグラフィー</h1>
    <p class="gosaki-admin-content-panel__subtitle" data-gosaki-disc-status>
      アルバム一覧の確認と編集（閲覧／編集）· Save 無効
    </p>
    <p class="gosaki-admin-content-panel__meta" role="status">
      <strong>{releaseCount}</strong> releases · <strong>{trackCount}</strong> tracks · source: {dataSource}
      {
        publicDiscographyUrl ? (
          <>
            {" · "}
            <a
              class="gosaki-read-only-admin__link"
              href={publicDiscographyUrl}
              target="_blank"
              rel="noopener noreferrer"
              data-gosaki-disc-public-link
            >
              公開 Discography を見る
            </a>
          </>
        ) : null
      }
    </p>
  </header>

  <p
    class="gosaki-discography-content-panel__unsaved"
    data-gosaki-unsaved-banner
    hidden
    role="status"
  >
    未保存の変更があります
  </p>

  {/* —— View mode —— */}
  <div class="gosaki-discography-content-panel__view" data-gosaki-disc-view-mode>
    {
      albums.length === 0 ? (
        <p class="gosaki-admin-content-panel__empty">Discography データがありません。</p>
      ) : (
        <ul class="gosaki-discography-content-panel__album-list" data-gosaki-disc-album-list>
          {albums.map((album) => (
            <li
              class="gosaki-discography-content-panel__album-item"
              data-gosaki-disc-album-summary={album.legacyId}
            >
              <div class="gosaki-discography-content-panel__album-summary">
                {
                  album.coverImageUrl ? (
                    <img
                      class="gosaki-discography-content-panel__thumb"
                      src={album.coverImageUrl}
                      alt=""
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="gosaki-discography-content-panel__thumb gosaki-discography-content-panel__thumb--empty" aria-hidden="true" />
                  )
                }
                <div class="gosaki-discography-content-panel__album-meta">
                  <h2 class="gosaki-discography-content-panel__album-title">{album.title}</h2>
                  <p class="gosaki-admin-content-panel__meta">
                    {display(album.artist)} · {display(album.releaseDate)} · {album.trackCount ?? 0} tracks
                  </p>
                  <p class="gosaki-admin-content-panel__meta">{display(album.label)}</p>
                </div>
                <AdminGosakiStagingEditToolbar mode="view" />
              </div>
            </li>
          ))}
        </ul>
      )
    }
  </div>

  {/* —— Edit mode (single album) —— */}
  <div class="gosaki-discography-content-panel__edit" data-gosaki-disc-edit-mode hidden>
    <div class="gosaki-discography-content-panel__edit-toolbar-row">
      <AdminGosakiStagingEditToolbar mode="edit" showDryRun={true} />
    </div>

    <form
      class="gosaki-discography-content-panel__form"
      data-gosaki-disc-edit-form
      data-album-legacy-id=""
      data-expected-before-updated-at=""
      data-original-snapshot=""
      novalidate
    >
      <input type="hidden" name="legacy_id" data-gosaki-disc-field="legacy_id" value="" />
      <input type="hidden" name="catalog_number" data-gosaki-disc-field="catalog_number" value="" />
      <input type="hidden" name="published" data-gosaki-disc-field="published" value="true" />
      <input type="hidden" name="streaming_url" data-gosaki-disc-field="streaming_url" value="" />
      <input type="hidden" name="cover_image_url" data-gosaki-disc-field="cover_image_url" value="" />

      <section
        class="gosaki-discography-form-section"
        aria-labelledby="gosaki-disc-section-basic"
        data-gosaki-disc-form-section="basic"
      >
        <h3 class="gosaki-discography-form-section__title" id="gosaki-disc-section-basic">基本情報</h3>
        <label class="gosaki-discography-content-panel__field">
          <span class="gosaki-discography-content-panel__label">タイトル</span>
          <input
            class="gosaki-discography-content-panel__control"
            type="text"
            name="title"
            data-gosaki-disc-field="title"
            autocomplete="off"
          />
        </label>
        <label class="gosaki-discography-content-panel__field">
          <span class="gosaki-discography-content-panel__label">アーティスト</span>
          <input
            class="gosaki-discography-content-panel__control"
            type="text"
            name="artist"
            data-gosaki-disc-field="artist"
            autocomplete="off"
          />
        </label>
        <label class="gosaki-discography-content-panel__field">
          <span class="gosaki-discography-content-panel__label">発売日</span>
          <input
            class="gosaki-discography-content-panel__control"
            type="text"
            name="release_date"
            data-gosaki-disc-field="release_date"
            autocomplete="off"
          />
        </label>
        <label class="gosaki-discography-content-panel__field">
          <span class="gosaki-discography-content-panel__label">レーベル</span>
          <input
            class="gosaki-discography-content-panel__control"
            type="text"
            name="label"
            data-gosaki-disc-field="label"
            autocomplete="off"
          />
        </label>
      </section>

      <section
        class="gosaki-discography-form-section"
        aria-labelledby="gosaki-disc-section-links"
        data-gosaki-disc-form-section="links"
      >
        <h3 class="gosaki-discography-form-section__title" id="gosaki-disc-section-links">リンク・説明</h3>
        <label class="gosaki-discography-content-panel__field">
          <span class="gosaki-discography-content-panel__label">購入URL</span>
          <input
            class="gosaki-discography-content-panel__control"
            type="url"
            name="purchase_url"
            data-gosaki-disc-field="purchase_url"
            autocomplete="off"
          />
        </label>
        <label class="gosaki-discography-content-panel__field">
          <span class="gosaki-discography-content-panel__label">説明文</span>
          <textarea
            class="gosaki-discography-content-panel__control gosaki-discography-content-panel__control--textarea"
            name="description"
            data-gosaki-disc-field="description"
            rows="5"
          />
        </label>
      </section>

      <section
        class="gosaki-discography-form-section"
        aria-labelledby="gosaki-disc-section-tracks"
        data-gosaki-disc-form-section="tracks"
      >
        <h3 class="gosaki-discography-form-section__title" id="gosaki-disc-section-tracks">収録曲</h3>
        <label class="gosaki-discography-content-panel__field">
          <span class="gosaki-discography-content-panel__label">曲名（1行 = 1曲）</span>
          <textarea
            class="gosaki-discography-content-panel__control gosaki-discography-content-panel__control--tracks"
            name="tracks"
            data-gosaki-disc-field="tracks"
            data-track-list-textarea="true"
            data-original-track-list=""
            rows="10"
          />
        </label>
        <p class="gosaki-discography-content-panel__hint" role="note">
          固定数の曲入力欄は使いません。行を増減して曲数を調整します。
        </p>
      </section>

      <section
        class="gosaki-discography-form-section gosaki-discography-form-section--cover"
        aria-labelledby="gosaki-disc-section-cover"
        data-gosaki-disc-form-section="cover"
      >
        <h3 class="gosaki-discography-form-section__title" id="gosaki-disc-section-cover">ジャケット画像</h3>
        <div class="gosaki-discography-content-panel__cover" data-gosaki-disc-cover-preview>
          <p class="gosaki-discography-content-panel__hint">画像変更は後続フェーズです。</p>
        </div>
      </section>
    </form>

    <div
      class="gosaki-discography-content-panel__dry-run"
      data-gosaki-disc-dry-run-panel
      data-gosaki-edit-dry-run-result
    >
      <h2 class="gosaki-discography-content-panel__section-title">変更確認（dry-run）</h2>
      <p class="gosaki-discography-content-panel__hint">
        既存 STG Discography dry-run endpoint へ接続します。DB には書き込みません。
      </p>
      <p
        class="gosaki-discography-content-panel__dry-run-ok"
        data-gosaki-disc-dry-run-ok
        hidden
        role="status"
      >
        dry-run 成功 — 内容を確認済み
      </p>
      <pre
        class="gosaki-discography-content-panel__dry-run-result"
        data-disc-endpoint-dry-run-result="album"
        data-gosaki-disc-dry-run-result
        aria-live="polite"
      >（まだ確認していません）</pre>
    </div>

    <div
      class="gosaki-discography-content-panel__save"
      data-gosaki-disc-save-panel="true"
      data-gosaki-save-disabled-note="true"
      role="region"
      aria-label="保存"
    >
      <h2 class="gosaki-discography-content-panel__section-title">保存</h2>
      <p class="gosaki-discography-content-panel__hint" role="note">
        保存機能は現在無効です（既定）。「変更を確認」（dry-run）成功・ログイン・env arm（PUBLIC_GOSAKI_DISCOGRAPHY_SAVE_UI_ARMED）が揃うまで実行できません。
      </p>
      <p
        class="gosaki-discography-content-panel__save-reason"
        data-gosaki-disc-save-disabled-reason
        role="status"
      >
        Save は無効です
      </p>
      <p
        class="gosaki-discography-content-panel__save-in-flight"
        data-gosaki-disc-save-in-flight
        hidden
        role="status"
      >
        保存中…
      </p>
      <p
        class="gosaki-discography-content-panel__save-success"
        data-gosaki-disc-save-success
        hidden
        role="status"
      />
      <p
        class="gosaki-discography-content-panel__save-validation"
        data-gosaki-disc-save-validation
        hidden
        role="alert"
      />
      <p
        class="gosaki-discography-content-panel__save-conflict"
        data-gosaki-disc-save-conflict
        hidden
        role="alert"
      >
        他の場所で更新された可能性があります。再読み込みしてください。
      </p>
      <p class="gosaki-discography-content-panel__save-actions">
        <button
          type="button"
          class="gosaki-discography-content-panel__save-btn"
          disabled
          aria-disabled="true"
          data-gosaki-disc-save
        >
          保存する
        </button>
      </p>
    </div>
  </div>

  {/* Album data for client (JSON) */}
  <script
    type="application/json"
    id="gosaki-disc-albums-json"
    data-gosaki-disc-albums-json
    set:html={JSON.stringify(albums)}
  />

  <details class="gosaki-read-only-admin__dev-details" data-gosaki-admin-dev-details="true">
    <summary>開発者情報</summary>
    <p class="gosaki-admin-content-panel__meta">
      operational edit · dry-run + gated Save wiring · Save default disabled · image edit deferred
    </p>
    <ul class="gosaki-discography-content-panel__dev-list">
      {
        albums.map((album) => (
          <li data-band-image={album.legacyId}>
            <code>{album.legacyId}</code>
            {" · updated_at: "}
            <code>{album.updatedAt ?? "—"}</code>
            {" · cover: "}
            <code>{album.coverImageUrl ?? "—"}</code>
          </li>
        ))
      }
    </ul>
  </details>
</section>

<style>
  .gosaki-discography-content-panel {
    min-width: 0;
    max-width: 100%;
    box-sizing: border-box;
  }

  .gosaki-discography-content-panel__unsaved {
    margin: 0 0 0.85rem;
    padding: 0.55rem 0.75rem;
    border-radius: 6px;
    background: #fff7ed;
    border: 1px solid #fdba74;
    color: #9a3412;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .gosaki-discography-content-panel__album-list {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: grid;
    gap: 0.85rem;
    min-width: 0;
  }

  .gosaki-discography-content-panel__album-item {
    min-width: 0;
    max-width: 100%;
    box-sizing: border-box;
  }

  .gosaki-discography-content-panel__album-summary {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding: 0.85rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: #fff;
    min-width: 0;
    box-sizing: border-box;
  }

  .gosaki-discography-content-panel__thumb {
    width: 72px;
    height: 72px;
    object-fit: cover;
    border-radius: 4px;
    background: #f3f4f6;
    max-width: 100%;
  }

  .gosaki-discography-content-panel__thumb--empty {
    border: 1px dashed #d1d5db;
  }

  .gosaki-discography-content-panel__album-meta {
    min-width: 0;
  }

  .gosaki-discography-content-panel__album-title {
    margin: 0 0 0.25rem;
    font-size: 1.05rem;
    word-break: break-word;
  }

  .gosaki-discography-content-panel__form {
    display: grid;
    gap: 1rem;
    min-width: 0;
    max-width: 100%;
  }

  .gosaki-discography-form-section {
    margin: 0;
    padding: 0.85rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: #f8fafc;
    min-width: 0;
    max-width: 100%;
    box-sizing: border-box;
  }

  .gosaki-discography-form-section__title {
    display: block;
    margin: 0 0 0.75rem;
    padding: 0;
    max-width: 100%;
    box-sizing: border-box;
    color: #111827;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.35;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .gosaki-discography-content-panel__field {
    display: block;
    margin: 0 0 0.75rem;
    min-width: 0;
    max-width: 100%;
  }

  .gosaki-discography-content-panel__field:last-of-type {
    margin-bottom: 0;
  }

  .gosaki-discography-content-panel__label {
    display: block;
    margin: 0 0 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.35;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .gosaki-discography-content-panel__control {
    display: block;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
    padding: 0.55rem 0.7rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    background: #fff;
    font: inherit;
  }

  .gosaki-discography-content-panel__control--textarea,
  .gosaki-discography-content-panel__control--tracks {
    display: block;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    resize: vertical;
    min-height: 6rem;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    word-break: break-word;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.9rem;
  }

  .gosaki-discography-content-panel__hint {
    margin: 0.25rem 0 0;
    color: #6b7280;
    font-size: 0.85rem;
  }

  .gosaki-discography-content-panel__cover img {
    display: block;
    max-width: min(220px, 100%);
    height: auto;
    border-radius: 4px;
    border: 1px solid #e5e7eb;
  }

  .gosaki-discography-content-panel__section-title {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
  }

  .gosaki-discography-content-panel__dry-run {
    margin: 1rem 0;
    padding: 0.85rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: #fff;
    min-width: 0;
    max-width: 100%;
    box-sizing: border-box;
  }

  .gosaki-discography-content-panel__dry-run-result {
    margin: 0.5rem 0 0;
    padding: 0.75rem;
    max-width: 100%;
    overflow-x: auto;
    background: #0f172a;
    color: #e2e8f0;
    border-radius: 6px;
    font-size: 0.75rem;
    white-space: pre-wrap;
    word-break: break-word;
    box-sizing: border-box;
  }

  .gosaki-discography-content-panel__dry-run-ok {
    margin: 0.35rem 0 0;
    padding: 0.45rem 0.65rem;
    border-radius: 6px;
    background: #ecfdf5;
    border: 1px solid #6ee7b7;
    color: #065f46;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .gosaki-discography-content-panel__save {
    margin: 1rem 0 0;
    padding: 0.85rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: #fff;
    min-width: 0;
    max-width: 100%;
    box-sizing: border-box;
  }

  .gosaki-discography-content-panel__save-reason {
    margin: 0.35rem 0 0.65rem;
    color: #6b7280;
    font-size: 0.9rem;
  }

  .gosaki-discography-content-panel__save-in-flight {
    margin: 0 0 0.5rem;
    color: #1d4ed8;
    font-weight: 600;
  }

  .gosaki-discography-content-panel__save-success {
    margin: 0 0 0.5rem;
    padding: 0.45rem 0.65rem;
    border-radius: 6px;
    background: #ecfdf5;
    border: 1px solid #6ee7b7;
    color: #065f46;
    font-weight: 600;
  }

  .gosaki-discography-content-panel__save-validation,
  .gosaki-discography-content-panel__save-conflict {
    margin: 0 0 0.5rem;
    padding: 0.45rem 0.65rem;
    border-radius: 6px;
    font-size: 0.85rem;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .gosaki-discography-content-panel__save-validation {
    background: #fff7ed;
    border: 1px solid #fdba74;
    color: #9a3412;
  }

  .gosaki-discography-content-panel__save-conflict {
    background: #fef2f2;
    border: 1px solid #fca5a5;
    color: #991b1b;
    font-weight: 600;
  }

  .gosaki-discography-content-panel__save-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
    padding: 0.55rem 0.95rem;
    border-radius: 6px;
    border: 1px solid #d1d5db;
    background: #e5e7eb;
    color: #6b7280;
    font: inherit;
    line-height: 1.3;
    box-sizing: border-box;
    cursor: not-allowed;
  }

  .gosaki-discography-content-panel__save-btn:not(:disabled) {
    border-color: #15803d;
    background: #16a34a;
    color: #fff;
    cursor: pointer;
  }

  .gosaki-discography-content-panel__save-actions {
    margin: 0.5rem 0 0;
  }

  .gosaki-discography-content-panel__dev-list {
    margin: 0.5rem 0 0;
    padding-left: 1.1rem;
    font-size: 0.8rem;
    word-break: break-all;
  }

  .gosaki-discography-content-panel__edit-toolbar-row {
    min-width: 0;
    max-width: 100%;
    margin: 0 0 0.85rem;
  }

  .gosaki-admin-edit-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    min-width: 0;
    max-width: 100%;
  }

  .gosaki-admin-edit-toolbar__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
    padding: 0.55rem 0.85rem;
    border-radius: 6px;
    border: 1px solid #d1d5db;
    background: #fff;
    font: inherit;
    line-height: 1.3;
    white-space: normal;
    text-align: center;
    box-sizing: border-box;
    cursor: pointer;
  }

  .gosaki-admin-edit-toolbar__btn--primary {
    border-color: #1d4ed8;
    background: #1d4ed8;
    color: #fff;
  }

  .gosaki-admin-edit-toolbar__btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  @media (max-width: 560px) {
    .gosaki-discography-content-panel__album-summary {
      grid-template-columns: 56px 1fr;
    }

    .gosaki-discography-content-panel__album-summary .gosaki-admin-edit-toolbar {
      grid-column: 1 / -1;
    }
  }
</style>
