---
/**
 * G-5x — Staging runtime shell route (NOT production admin).
 *
 * Route: /__admin-staging-shell/musician-basic/
 * Requires: import.meta.env.DEV && ENABLE_ADMIN_STAGING_SHELL === "true"
 *
 * NOT /admin/. NOT connected to Supabase, DB, Storage, or Publish.
 */
const isDev = import.meta.env.DEV;
const shellFlag = import.meta.env.ENABLE_ADMIN_STAGING_SHELL === "true";
const enabled = isDev && shellFlag;

const routePath = "/__admin-staging-shell/musician-basic/";
const disableReason = !isDev
  ? "Admin staging shell is disabled outside development mode (import.meta.env.DEV is false)."
  : "Admin staging shell is disabled. Set ENABLE_ADMIN_STAGING_SHELL=true in your environment for local dev only.";
---

{
  enabled ? (
    <>
      <html lang="ja">
        <head>
          <meta charset="UTF-8" />
          <meta http-equiv="refresh" content="0;url=/__admin-staging-shell/musician-basic/admin/" />
          <meta name="viewport" content="width=device-width, initial-scale=1.0" />
          <meta name="robots" content="noindex,nofollow,noarchive" />
          <title>Gosaki 管理画面へ移動中…</title>
        </head>
        <body>
          <p>
            <a href="/__admin-staging-shell/musician-basic/admin/">Gosaki 管理画面へ</a>
          </p>
        </body>
      </html>
    </>
  ) : (
    <html lang="ja">
      <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="robots" content="noindex,nofollow,noarchive" />
        <title>Admin staging shell disabled</title>
        <style>
          body {
            font-family: system-ui, sans-serif;
            margin: 2rem;
            line-height: 1.5;
            color: #1e293b;
          }
          .box {
            max-width: 40rem;
            padding: 1.25rem;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: #f8fafc;
          }
          h1 {
            font-size: 1.25rem;
            margin: 0 0 0.75rem;
          }
          p {
            margin: 0 0 0.5rem;
          }
          code {
            background: #e2e8f0;
            padding: 0.1rem 0.35rem;
            border-radius: 4px;
          }
          ul {
            margin: 0.5rem 0 0;
            padding-left: 1.25rem;
          }
        </style>
      </head>
      <body>
        <div class="box" role="alert">
          <h1>Admin staging shell disabled</h1>
          <p>{disableReason}</p>
          <p>
            Enable with: <code>ENABLE_ADMIN_STAGING_SHELL=true npm run dev</code>
          </p>
          <p>
            This route is <strong>shell-only</strong> and <strong>not</strong> the production admin at
            <code>/admin/</code>.
          </p>
          <ul>
            <li>Production disabled</li>
            <li>Not connected to runtime data</li>
            <li>No Supabase Auth, DB, Storage upload, or publish dispatch</li>
          </ul>
          <p>CMS Kit staging runtime shell candidate (G-5x).</p>
        </div>
      </body>
    </html>
  )
}
