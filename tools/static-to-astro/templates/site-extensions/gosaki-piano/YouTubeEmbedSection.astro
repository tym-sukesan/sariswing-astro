---
import embedConfig from "../data/gosaki-youtube-embed.json";
import {
  normalizeGosakiYoutubeConfig,
  resolvePublishedGosakiYoutubeItems,
} from "../lib/gosaki-youtube-embed.ts";

const { sectionTitle } = normalizeGosakiYoutubeConfig(embedConfig);
const items = resolvePublishedGosakiYoutubeItems(embedConfig);
---

{
  items.length > 0 ? (
    <section class="gosaki-youtube-embed" aria-labelledby="gosaki-youtube-heading">
      <div class="gosaki-youtube-embed__inner">
        <h2 id="gosaki-youtube-heading" class="gosaki-youtube-embed__title">
          {sectionTitle}
        </h2>
        <div class="gosaki-youtube-embed__list">
          {
            items.map((item) => (
              <article class="gosaki-youtube-embed__item">
                <div class="gosaki-youtube-embed__media">
                  <iframe
                    class="gosaki-youtube-embed__iframe"
                    src={item.embedUrl}
                    title={item.iframeTitle}
                    loading="lazy"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                  />
                </div>
                <p class="gosaki-youtube-embed__watch">
                  <a href={item.watchUrl} target="_blank" rel="noopener noreferrer">
                    YouTubeで見る
                  </a>
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  ) : null
}

<style>
  .gosaki-youtube-embed {
    width: 100%;
    max-width: 720px;
    margin: 3rem auto 3.5rem;
    padding: 0 1.25rem;
    box-sizing: border-box;
    min-width: 0;
    grid-column: 1 / -1;
    justify-self: center;
  }

  .gosaki-youtube-embed__inner {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    background: #fff;
    border: 1px solid #e8e4dc;
    border-radius: 8px;
    padding: 1.75rem 1.5rem 1.5rem;
    box-sizing: border-box;
  }

  .gosaki-youtube-embed__title {
    margin: 0 0 1rem;
    font-size: clamp(22px, 5vw, 32px);
    font-weight: 700;
    text-align: center;
    color: #2c2416;
    line-height: 1.25;
  }

  .gosaki-youtube-embed__list {
    display: grid;
    gap: 1.5rem;
  }

  .gosaki-youtube-embed__item-title {
    margin: 0 0 0.35rem;
    font-size: 1.05rem;
    font-weight: 600;
    text-align: center;
    color: #3d3428;
  }

  .gosaki-youtube-embed__caption {
    margin: 0 0 0.75rem;
    text-align: center;
    color: #5c5348;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .gosaki-youtube-embed__media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #111;
    border-radius: 6px;
    overflow: hidden;
  }

  .gosaki-youtube-embed__iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .gosaki-youtube-embed__watch {
    margin: 0.75rem 0 0;
    text-align: center;
    font-size: 0.9rem;
  }

  .gosaki-youtube-embed__watch a {
    color: #8b4513;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 768px) {
    .gosaki-youtube-embed {
      width: 100%;
      max-width: 100%;
      margin: 2rem auto 2.5rem;
      padding: 0 1rem;
      overflow-x: clip;
    }

    .gosaki-youtube-embed__inner {
      max-width: 100%;
      padding: 1.25rem 1rem 1rem;
    }

    .gosaki-youtube-embed__media {
      max-width: 100%;
    }
  }
</style>
