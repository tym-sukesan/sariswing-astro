---
/**
 * Gosaki staging read-only CMS admin (G-11b / G-20u28 dashboard polish).
 * Static build-time data + YouTube dry-run endpoint wiring (no Save / JSON write).
 */
import "../styles/gosaki-staging-read-only-admin.css";
import "../styles/gosaki-admin-shell-chrome.css";
import AdminGosakiStagingOperatorHome from "./gosaki-admin/AdminGosakiStagingOperatorHome.astro";
import AdminGosakiStagingNav from "./gosaki-admin/AdminGosakiStagingNav.astro";
import AdminGosakiStagingSafetyChips from "./gosaki-admin/AdminGosakiStagingSafetyChips.astro";
import AdminGosakiStagingScheduleContentPanel from "./gosaki-admin/AdminGosakiStagingScheduleContentPanel.astro";
import AdminGosakiStagingAboutContentPanel from "./gosaki-admin/AdminGosakiStagingAboutContentPanel.astro";
import AdminGosakiStagingDiscographyContentPanel from "./gosaki-admin/AdminGosakiStagingDiscographyContentPanel.astro";
import AdminGosakiStagingCompactAuthBar from "./gosaki-admin/AdminGosakiStagingCompactAuthBar.astro";
import {
  GOSAKI_STAGING_ADMIN_BASE,
  GOSAKI_STAGING_ADMIN_SCHEDULE_PATH,
  GOSAKI_STAGING_PREVIEW_URL as GOSAKI_PACKAGE_PREVIEW_URL,
} from "../lib/gosaki-package-admin-paths";
import youtubeConfig from "../data/gosaki-youtube-embed.json";
import aboutConfig from "../data/gosaki-about-content.json";
import contactConfig from "../data/gosaki-contact-hubspot.json";
import dashboardSnapshot from "../data/gosaki-read-only-admin-dashboard.json";
import discographyEditorSnapshot from "../data/gosaki-read-only-admin-discography-editor.json";
import scheduleEventsSnapshot from "../data/gosaki-read-only-admin-schedule-events.json";
import {
  G11C6A_PHASE,
  G11C4A_STAGING_DRY_RUN_ENDPOINT,
  G11C6A_STAGING_SAVE_ENDPOINT,
  G11C6_APPROVAL_ID,
  G11C6_OPERATION_ID,
  G11C6_SAVE_DISABLED_REASON,
  G11C6_SAVE_ENABLED_DEFAULT,
  G20U28_ADMIN_UI_PHASE,
  G20U29_DISCOGRAPHY_EDITOR_PHASE,
  G20U29_DISCOGRAPHY_EDITOR_SAVE_DISABLED_REASON,
  G20U30_DISCOGRAPHY_DRY_RUN_PHASE,
  G20U30_DISCOGRAPHY_DRY_RUN_NOTE,
  G20U36C_DISCOGRAPHY_DRY_RUN_FETCH_POST_PHASE,
  G20U36C_DISCOGRAPHY_DRY_RUN_NOTE,
  G20U36C_DISCOGRAPHY_DRY_RUN_APPROVAL_ID,
  G20U36C_DISCOGRAPHY_DRY_RUN_OPERATION,
  G20U36E_ADMIN_PROBE_UI_TOOLS_DRAFT_PHASE,
  G20U36E_ADMIN_PROBE_BUTTON_LABEL,
  G20U36E_ADMIN_PROBE_NOTE,
  G20U41_DISCOGRAPHY_OPERATIONAL_SAVE_PHASE,
  G20U41_DISCOGRAPHY_SAVE_OPERATION,
  G20U41_DISCOGRAPHY_SAVE_APPROVAL_ID,
  G20U41_DISCOGRAPHY_CONFLICT_MESSAGE,
  buildDiscographySaveEndpointRequest,
  evaluateDiscographyOperationalSaveGate,
  isDiscographySaveConflictResponse,
  isG20u41DiscographyOperationalSaveArmed,
  resolveG20u41DiscographySaveEndpoint,
  assertG20u41DiscographySaveEndpointSafe,
  GOSAKI_STAGING_PREVIEW_URL,
  buildGosakiReadOnlyAdminViewModel,
  isG11c4aSupabaseAuthConfigured,
  isG11c6aSaveEnabled,
  resolveG11c4aDryRunEndpoint,
  resolveG11c4aSupabaseAnonKey,
  resolveG11c4aSupabaseUrl,
  resolveG11c6aSaveEndpoint,
  resolveG20u36cDiscographyDryRunEndpoint,
  resolveGosakiScheduleDryRunEndpoint,
  assertGosakiScheduleDryRunEndpointSafe,
  assertGosakiScheduleSaveEndpointSafe,
  buildScheduleDryRunEndpointRequest,
  buildScheduleSaveEndpointRequest,
  sanitizeScheduleDryRunEndpointDisplay,
  sanitizeScheduleSaveEndpointDisplay,
  evaluateScheduleOperationalSaveGate,
  isScheduleSaveConflictResponse,
  isG20u45ScheduleOperationalSaveArmed,
  G20U45_SCHEDULE_DRY_RUN_OPERATION,
  G20U45_SCHEDULE_SAVE_OPERATION,
  G20U45_SCHEDULE_SAVE_APPROVAL_ID,
  G20U45_SCHEDULE_CONFLICT_MESSAGE,
  G12A_ABOUT_SAVE_APPROVAL_ID,
  G12A_ABOUT_SAVE_OPERATION_ID,
  G12A_ABOUT_DRY_RUN_APPROVAL_ID,
  G12A_ABOUT_CONFLICT_MESSAGE,
  resolveG12aAboutDryRunEndpoint,
  resolveG12aAboutSaveEndpoint,
  isG12aAboutSaveEnabled,
  assertGosakiAboutDryRunEndpointSafe,
  assertGosakiAboutSaveEndpointSafe,
} from "../lib/gosaki-staging-read-only-admin";

interface Props {
  page?: "portal" | "schedule" | "discography" | "youtube" | "about";
}

const { page = "portal" } = Astro.props as Props;

const dryRunEndpoint = resolveG11c4aDryRunEndpoint(import.meta.env);
const saveEndpoint = resolveG11c6aSaveEndpoint(import.meta.env);
const discographyDryRunEndpoint = resolveG20u36cDiscographyDryRunEndpoint(import.meta.env);
const discographySaveEndpoint = resolveG20u41DiscographySaveEndpoint(import.meta.env);
const discographySaveArmed = isG20u41DiscographyOperationalSaveArmed(import.meta.env);
const scheduleSaveArmed = isG20u45ScheduleOperationalSaveArmed(import.meta.env);
const scheduleDryRunEndpointRaw = resolveGosakiScheduleDryRunEndpoint(import.meta.env);
const scheduleDryRunEndpoint = assertGosakiScheduleDryRunEndpointSafe(scheduleDryRunEndpointRaw)
  ? scheduleDryRunEndpointRaw
  : "";
const aboutDryRunEndpointRaw = resolveG12aAboutDryRunEndpoint(import.meta.env);
const aboutDryRunEndpoint = assertGosakiAboutDryRunEndpointSafe(aboutDryRunEndpointRaw)
  ? aboutDryRunEndpointRaw
  : "";
const aboutSaveEndpointRaw = resolveG12aAboutSaveEndpoint(import.meta.env);
const aboutSaveEndpoint = assertGosakiAboutSaveEndpointSafe(aboutSaveEndpointRaw)
  ? aboutSaveEndpointRaw
  : "";
const aboutSaveArmed = isG12aAboutSaveEnabled(import.meta.env);
const supabaseUrl = resolveG11c4aSupabaseUrl(import.meta.env);
const supabaseAnonKey = resolveG11c4aSupabaseAnonKey(import.meta.env);
const supabaseAuthConfigured = isG11c4aSupabaseAuthConfigured(import.meta.env);
const endpointConfigured = Boolean(dryRunEndpoint);
const saveEndpointConfigured = Boolean(saveEndpoint);
const saveEnabled = isG11c6aSaveEnabled(import.meta.env);
const g11c1OperationId = "G-11c1-gosaki-youtube-url-web-save-dry-run-poc";
const g11c1ApprovalId = "G-11c1-youtube-url-dry-run";

const view = buildGosakiReadOnlyAdminViewModel({
  youtube: youtubeConfig,
  about: aboutConfig,
  contact: contactConfig,
});

const dashboard = dashboardSnapshot;
const discographyEditor = discographyEditorSnapshot;
const scheduleEvents = scheduleEventsSnapshot;
const stagingSiteBase = String(import.meta.env.SITE ?? GOSAKI_STAGING_PREVIEW_URL).replace(/\/?$/, "/");
const pagePathSuffix =
  page === "portal" ? "admin/" : `admin/${page}/`;
const adminCanonical = new URL(pagePathSuffix, stagingSiteBase).href;
const publicHomeUrl = stagingSiteBase;
const publicScheduleUrl = new URL("schedule/", stagingSiteBase).href;
const publicAugustUrl = new URL("schedule/2026-08/", stagingSiteBase).href;
const publicDiscographyUrl = new URL("discography/", stagingSiteBase).href;
const publicContactUrl = new URL("contact/", stagingSiteBase).href;
const publicLinkUrl = new URL("link/", stagingSiteBase).href;
const publicAboutUrl = new URL("about/", stagingSiteBase).href;
const robotsContent = "noindex,nofollow,noarchive";
const pageTitleByRoute = {
  portal: "Gosaki Piano CMS（テスト環境）",
  schedule: "スケジュール管理（テスト環境）",
  discography: "ディスコグラフィ管理（テスト環境）",
  youtube: "YouTube管理（テスト環境）",
  about: "プロフィール管理（テスト環境）",
} as const;
const pageTitle = pageTitleByRoute[page];
const navCurrent = page === "portal" ? "home" : page;
const showAuth = page === "youtube" || page === "discography" || page === "schedule" || page === "about";
const showClientScript = page !== "portal";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={robotsContent} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={adminCanonical} />
    <meta property="og:url" content={adminCanonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:type" content="website" />
  </head>
  <body
    class="gosaki-read-only-admin"
    data-gosaki-read-only-admin="true"
    data-gosaki-admin-page={page}
    data-gosaki-admin-multi-route="true"
    data-phase={G20U28_ADMIN_UI_PHASE}
    data-discography-editor-phase={G20U29_DISCOGRAPHY_EDITOR_PHASE}
    data-discography-dry-run-phase={G20U30_DISCOGRAPHY_DRY_RUN_PHASE}
    data-discography-endpoint-dry-run-phase={G20U36C_DISCOGRAPHY_DRY_RUN_FETCH_POST_PHASE}
    data-g11c6a-phase={G11C6A_PHASE}
    data-gosaki-youtube-dry-run-endpoint={dryRunEndpoint}
    data-gosaki-youtube-save-endpoint={saveEndpoint}
    data-gosaki-discography-dry-run-endpoint={discographyDryRunEndpoint}
    data-gosaki-discography-save-endpoint={discographySaveEndpoint}
    data-gosaki-schedule-dry-run-endpoint={scheduleDryRunEndpoint}
    data-g20u45-schedule-dry-run-operation={G20U45_SCHEDULE_DRY_RUN_OPERATION}
    data-g20u45-schedule-save-operation={G20U45_SCHEDULE_SAVE_OPERATION}
    data-g20u45-schedule-save-approval-id={G20U45_SCHEDULE_SAVE_APPROVAL_ID}
    data-gosaki-schedule-save-armed={scheduleSaveArmed ? "true" : "false"}
    data-g20u41-discography-operational-save-phase={G20U41_DISCOGRAPHY_OPERATIONAL_SAVE_PHASE}
    data-g20u41-discography-save-operation={G20U41_DISCOGRAPHY_SAVE_OPERATION}
    data-g20u41-discography-save-approval-id={G20U41_DISCOGRAPHY_SAVE_APPROVAL_ID}
    data-gosaki-discography-save-armed={discographySaveArmed ? "true" : "false"}
    data-g20u36c-discography-dry-run-operation={G20U36C_DISCOGRAPHY_DRY_RUN_OPERATION}
    data-g20u36c-discography-dry-run-approval-id={G20U36C_DISCOGRAPHY_DRY_RUN_APPROVAL_ID}
    data-gosaki-supabase-url={supabaseUrl}
    data-gosaki-supabase-anon-key={supabaseAnonKey}
    data-gosaki-supabase-auth-configured={supabaseAuthConfigured ? "true" : "false"}
    data-gosaki-youtube-current-embed={view.youtube.sourceUrl}
    data-gosaki-youtube-current-videoid={view.youtube.videoId ?? ""}
    data-g11c1-operation-id={g11c1OperationId}
    data-g11c1-approval-id={g11c1ApprovalId}
    data-g11c6-operation-id={G11C6_OPERATION_ID}
    data-g11c6-approval-id={G11C6_APPROVAL_ID}
    data-g11c6-save-enabled={saveEnabled ? "true" : "false"}
    data-gosaki-youtube-save-armed={saveEnabled ? "true" : "false"}
    data-gosaki-about-dry-run-endpoint={aboutDryRunEndpoint}
    data-gosaki-about-save-endpoint={aboutSaveEndpoint}
    data-gosaki-about-save-armed={aboutSaveArmed ? "true" : "false"}
    data-g12a-about-dry-run-approval-id={G12A_ABOUT_DRY_RUN_APPROVAL_ID}
    data-g12a-about-save-operation-id={G12A_ABOUT_SAVE_OPERATION_ID}
    data-g12a-about-save-approval-id={G12A_ABOUT_SAVE_APPROVAL_ID}
  >
        <div class="gosaki-read-only-admin__shell">
      <header class="gosaki-read-only-admin__header">
        <a class="gosaki-read-only-admin__brand" href={GOSAKI_STAGING_ADMIN_BASE}>Gosaki Piano CMS</a>
        {page !== "portal" ? <AdminGosakiStagingSafetyChips /> : null}
      </header>

      <main class="gosaki-read-only-admin__main" data-gosaki-multi-route-main="true">
        {
          page === "portal" ? (
            <AdminGosakiStagingOperatorHome
              previewUrl={GOSAKI_PACKAGE_PREVIEW_URL || publicHomeUrl}
              schedulePath={GOSAKI_STAGING_ADMIN_SCHEDULE_PATH}
            />
          ) : (
            <>
              <p class="gosaki-read-only-admin__meta">
                <a class="admin-gosaki-back-link" href={GOSAKI_STAGING_ADMIN_BASE}>← 管理トップへ</a>
              </p>
              <AdminGosakiStagingNav current={navCurrent} />
            </>
          )
        }

        {
          page === "portal" ? (
            <details class="gosaki-read-only-admin__dev-details" data-gosaki-admin-dev-details="true">
              <summary>開発者向け詳細（通常は開かないでください）</summary>

          <ul class="gosaki-read-only-admin__safety-list">
            <li>
              <strong>siteSlug:</strong> {view.siteSlug} · build snapshot phase: {dashboard.phase}
            </li>
            <li>本番パッケージには <code>/admin/</code> を含めません（sitemap からも除外）</li>
            <li>staging への反映は手動 FTP のみ（自動 deploy なし）</li>
            <li>本番アップロードは G-20j 承認まで STOP</li>
            <li>FTP: 手動のみ · auto deploy なし · sitemap: /admin/ 非掲載</li>
            <li>
              phases: {G20U28_ADMIN_UI_PHASE} · {G20U29_DISCOGRAPHY_EDITOR_PHASE} ·{" "}
              {G20U30_DISCOGRAPHY_DRY_RUN_PHASE} · {G20U36C_DISCOGRAPHY_DRY_RUN_FETCH_POST_PHASE}
            </li>
          </ul>
          <p class="gosaki-read-only-admin__meta">
            multi-route package admin (G-20u39b4): /admin/ · /admin/schedule/ · /admin/discography/ · /admin/youtube/ · /admin/about/
          </p>

              <section class="gosaki-read-only-admin__section" aria-labelledby="gra-overview">
          <h2 id="gra-overview">サイト概要</h2>
          <p class="gosaki-read-only-admin__meta">
            <strong>staging URL:</strong>{" "}
            <a class="gosaki-read-only-admin__link" href={view.stagingUrl} target="_blank" rel="noopener noreferrer">
              {view.stagingUrl}
            </a>
          </p>
          <p class="gosaki-read-only-admin__meta">
            <strong>公開ページ:</strong>{" "}
            <a class="gosaki-read-only-admin__link" href={publicHomeUrl} target="_blank" rel="noopener noreferrer">トップ</a>
            {" · "}
            <a class="gosaki-read-only-admin__link" href={publicScheduleUrl} target="_blank" rel="noopener noreferrer">Schedule</a>
          </p>
          <p class="gosaki-read-only-admin__meta"><strong>noindex:</strong> {view.noindex ? "yes" : "no"}</p>
          <p class="gosaki-read-only-admin__meta">{view.packageNote}</p>
        </section>


              <section class="gosaki-read-only-admin__section" aria-labelledby="gra-contact">
          <h2 id="gra-contact">Contact（HubSpot）</h2>
          <p class="gosaki-read-only-admin__meta">公開フォームの確認用です。CMS 編集 UI は準備中です。</p>
          <details class="gosaki-read-only-admin__dev-details">
            <summary>開発者向け — HubSpot 識別子</summary>
            <p class="gosaki-read-only-admin__meta"><strong>provider:</strong> {view.contact.provider}</p>
            <p class="gosaki-read-only-admin__meta"><strong>portalId:</strong> {view.contact.portalId}</p>
            <p class="gosaki-read-only-admin__meta"><strong>formId:</strong> {view.contact.formId}</p>
            <p class="gosaki-read-only-admin__meta">enabled: {view.contact.enabled ? "true" : "false"}</p>
          </details>
        </section>


              <p class="gosaki-read-only-admin__meta">
                dashboard events: {dashboard.schedule.totalEvents} · discography: {dashboard.discography.releases}/{dashboard.discography.tracks}
              </p>
            </details>
          ) : null
        }

        {page === "schedule" ? (
          <>
            <AdminGosakiStagingScheduleContentPanel
              events={scheduleEvents.events ?? []}
              dataSource={scheduleEvents.dataSource ?? dashboard.schedule.dataSource}
              publicScheduleUrl={publicScheduleUrl}
              note="公演一覧の確認と編集（閲覧／編集）· Save 無効"
            />
            <AdminGosakiStagingCompactAuthBar
              supabaseAuthConfigured={supabaseAuthConfigured}
              probePhase={G20U36E_ADMIN_PROBE_UI_TOOLS_DRAFT_PHASE}
              probeNote={G20U36E_ADMIN_PROBE_NOTE}
              probeButtonLabel={G20U36E_ADMIN_PROBE_BUTTON_LABEL}
              purposeNote="Schedule 編集の dry-run / 将来 Save 時のみログインが必要です。"
            />
            <details class="gosaki-read-only-admin__dev-details" data-gosaki-admin-dev-details="true">
              <summary>開発者向け — build snapshot</summary>
              <p class="gosaki-read-only-admin__meta">
                build snapshot: {dashboard.schedule.totalEvents} events · {dashboard.schedule.monthCount} months · August 2026: {dashboard.schedule.august2026Events} cards
              </p>
            </details>
            <p class="gosaki-read-only-admin__meta" role="note" data-gosaki-save-disabled-note="true">
              Save は無効です。公開反映は管理者が行います。
            </p>
          </>
        ) : null}

        {page === "discography" ? (
          <>
            <AdminGosakiStagingDiscographyContentPanel
              albums={discographyEditor.albums ?? []}
              dataSource={discographyEditor.dataSource ?? "build-snapshot"}
              releaseCount={discographyEditor.releaseCount ?? 0}
              trackCount={discographyEditor.trackCount ?? 0}
              publicDiscographyUrl={publicDiscographyUrl}
              dryRunEndpointConfigured={Boolean(discographyDryRunEndpoint)}
            />
            <AdminGosakiStagingCompactAuthBar
              supabaseAuthConfigured={supabaseAuthConfigured}
              probePhase={G20U36E_ADMIN_PROBE_UI_TOOLS_DRAFT_PHASE}
              probeNote={G20U36E_ADMIN_PROBE_NOTE}
              probeButtonLabel={G20U36E_ADMIN_PROBE_BUTTON_LABEL}
              purposeNote="Endpoint dry-run 実行時のみログインが必要です。"
            />
          </>
        ) : null}

        {page === "youtube" ? (
          <>
            <section
              class="gosaki-read-only-admin__section"
              aria-labelledby="gra-youtube"
              data-gosaki-youtube-content="true"
              data-gosaki-youtube-operational-edit="true"
              id="gosaki-youtube-content"
            >
              <h2 id="gra-youtube">YouTube Embed</h2>
              <p class="gosaki-read-only-admin__meta" data-gosaki-youtube-status>
                現在値を表示中 · 未保存変更なし
              </p>
              <div class="gosaki-read-only-admin__field">
                <label>現在登録中の YouTube URL</label>
                <p
                  class="gosaki-youtube-url-break gosaki-read-only-admin__current-url"
                  data-gosaki-youtube-current-display
                >
                  {view.youtube.sourceUrl}
                </p>
              </div>
              <div class="gosaki-read-only-admin__field">
                <label for="gra-youtube-videoid">videoId</label>
                <input
                  id="gra-youtube-videoid"
                  type="text"
                  readonly
                  data-gosaki-youtube-current-videoid
                  value={view.youtube.videoId ?? "—"}
                />
              </div>
              <p class="gosaki-read-only-admin__meta">
                published: {view.youtube.published ? "true" : "false"}
              </p>
              {view.youtube.videoId ? (
                <div class="gosaki-youtube-content-preview" data-gosaki-youtube-preview="true">
                  <iframe
                    title="YouTube preview"
                    src={`https://www.youtube-nocookie.com/embed/${view.youtube.videoId}`}
                    loading="lazy"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  />
                </div>
              ) : null}

              <form
                class="gosaki-read-only-admin__dry-run"
                id="gra-youtube-dry-run"
                data-section="youtube-dry-run"
                data-gosaki-youtube-operational-form
              >
                <h3 class="gosaki-read-only-admin__meta">変更を確認 / Save（通常 package では Save 無効）</h3>
                <p
                  class:list={[
                    "gosaki-read-only-admin__meta",
                    endpointConfigured
                      ? "gosaki-read-only-admin__meta--ok"
                      : "gosaki-read-only-admin__meta--warn",
                  ]}
                  id="gra-youtube-endpoint-status"
                >
                  {
                    endpointConfigured
                      ? `dry-run endpoint: configured (${dryRunEndpoint})`
                      : "dry-run endpoint: not configured"
                  }
                </p>
                <div class="gosaki-read-only-admin__field">
                  <label for="gra-youtube-next-url">新しい YouTube URL</label>
                  <input
                    id="gra-youtube-next-url"
                    data-gosaki-youtube-next-url
                    type="url"
                    inputmode="url"
                    autocomplete="off"
                    placeholder="https://www.youtube.com/watch?v=... または https://youtu.be/..."
                  />
                </div>
                <p
                  class="gosaki-read-only-admin__meta"
                  data-gosaki-youtube-local-validation
                  aria-live="polite"
                >
                  URL を入力してください
                </p>
                <div class="gosaki-read-only-admin__actions">
                  <button
                    type="button"
                    id="gra-youtube-dry-run-btn"
                    data-gosaki-youtube-dry-run
                    class="gosaki-read-only-admin__btn gosaki-read-only-admin__btn--primary"
                    disabled
                  >
                    変更を確認
                  </button>
                  <button
                    type="button"
                    data-gosaki-youtube-cancel
                    class="gosaki-read-only-admin__btn"
                  >
                    キャンセル（未保存を破棄）
                  </button>
                </div>
                <div
                  id="gra-youtube-dry-run-result"
                  class="gosaki-read-only-admin__dry-run-result"
                  data-gosaki-youtube-dry-run-result
                  aria-live="polite"
                  hidden
                />

                <div class="gosaki-read-only-admin__save" id="gra-youtube-save" data-section="youtube-save">
                  <h3 class="gosaki-read-only-admin__meta">Save</h3>
                  <p
                    class="gosaki-read-only-admin__meta gosaki-read-only-admin__meta--warn"
                    id="gra-youtube-save-disabled-reason"
                    data-gosaki-youtube-save-reason
                  >
                    {G11C6_SAVE_DISABLED_REASON}
                  </p>
                  <div class="gosaki-read-only-admin__actions">
                    <button
                      type="button"
                      id="gra-youtube-save-btn"
                      data-gosaki-youtube-save
                      class="gosaki-read-only-admin__btn"
                      disabled
                      aria-disabled="true"
                      data-gosaki-save-allowed="false"
                      title={G11C6_SAVE_DISABLED_REASON}
                    >
                      更新する（無効）
                    </button>
                  </div>
                </div>
              </form>
            </section>

            <AdminGosakiStagingCompactAuthBar
              supabaseAuthConfigured={supabaseAuthConfigured}
              probePhase={G20U36E_ADMIN_PROBE_UI_TOOLS_DRAFT_PHASE}
              probeNote={G20U36E_ADMIN_PROBE_NOTE}
              probeButtonLabel={G20U36E_ADMIN_PROBE_BUTTON_LABEL}
              purposeNote="YouTube dry-run / Save 実行時のみログインが必要です。"
            />
          </>
        ) : null}

        {page === "about" ? (
          <>
            <AdminGosakiStagingAboutContentPanel
              profileLabel={view.about.profileLabel}
              bandsLabel={view.about.bandsLabel}
              profileHtml={view.about.profileHtml}
              bandsHtml={view.about.bandsHtml}
              bandImages={view.about.bandImages}
              publicAboutUrl={publicAboutUrl}
            />
            <AdminGosakiStagingCompactAuthBar
              supabaseAuthConfigured={supabaseAuthConfigured}
              probePhase={G20U36E_ADMIN_PROBE_UI_TOOLS_DRAFT_PHASE}
              probeNote={G20U36E_ADMIN_PROBE_NOTE}
              probeButtonLabel={G20U36E_ADMIN_PROBE_BUTTON_LABEL}
              purposeNote="About の「変更を確認」（dry-run）実行時のみログインが必要です。Save は通常無効です。"
