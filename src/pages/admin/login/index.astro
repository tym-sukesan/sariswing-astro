---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="管理ログイン | SARI" admin showDeployBar={false}>
  <main class="admin-page admin-page--auth">
    <div class="admin-page-header">
      <h1>管理ログイン</h1>
    </div>

    <section class="admin-card admin-auth-card">
      <p id="loginResetSuccess" class="admin-message admin-message--success is-hidden" role="status">
        パスワードを変更しました。新しいパスワードでログインしてください。
      </p>

      <form id="adminLoginForm" class="admin-form admin-auth-form" novalidate>
        <label class="admin-form__field">
          <span class="admin-form__label">メールアドレス</span>
          <input id="loginEmail" type="email" name="email" autocomplete="username" required />
        </label>

        <label class="admin-form__field">
          <span class="admin-form__label">パスワード</span>
          <input
            id="loginPassword"
            type="password"
            name="password"
            autocomplete="current-password"
            required
          />
        </label>

        <div class="admin-actions admin-auth-form__actions">
          <button id="loginSubmit" class="admin-button" type="submit">ログイン</button>
        </div>
      </form>

      <p class="admin-auth-links">
        <a href="/admin/forgot-password/">パスワードをお忘れですか？</a>
      </p>

      <p id="loginError" class="admin-message admin-message--error is-hidden" role="alert"></p>
    </section>
  </main>

  <script>
    import "../../../scripts/admin/login.ts";
  </script>
</BaseLayout>
