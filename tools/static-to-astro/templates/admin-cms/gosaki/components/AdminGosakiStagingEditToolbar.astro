---
/**
 * Minimal shared edit toolbar (Discography now · reusable later for Schedule).
 */
interface Props {
  mode?: "view" | "edit";
  editLabel?: string;
  cancelLabel?: string;
  dryRunLabel?: string;
  showDryRun?: boolean;
}

const {
  mode = "view",
  editLabel = "編集する",
  cancelLabel = "編集をやめる",
  dryRunLabel = "変更を確認",
  showDryRun = false,
} = Astro.props as Props;
---

<div
  class="gosaki-admin-edit-toolbar"
  data-gosaki-edit-toolbar="true"
  data-mode={mode}
>
  {
    mode === "view" ? (
      <button
        type="button"
        class="gosaki-admin-edit-toolbar__btn gosaki-admin-edit-toolbar__btn--primary"
        data-gosaki-edit-start
      >
        {editLabel}
      </button>
    ) : (
      <>
        <button
          type="button"
          class="gosaki-admin-edit-toolbar__btn"
          data-gosaki-edit-cancel
        >
          {cancelLabel}
        </button>
        {
          showDryRun ? (
            <button
              type="button"
              class="gosaki-admin-edit-toolbar__btn gosaki-admin-edit-toolbar__btn--primary"
              data-gosaki-edit-dry-run
            >
              {dryRunLabel}
            </button>
          ) : null
        }
      </>
    )
  }
</div>

<style>
  .gosaki-admin-edit-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    min-width: 0;
    max-width: 100%;
    box-sizing: border-box;
  }

  .gosaki-admin-edit-toolbar__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
    padding: 0.55rem 0.85rem;
    border-radius: 6px;
    border: 1px solid #d1d5db;
    background: #fff;
    font: inherit;
    line-height: 1.3;
    white-space: normal;
    text-align: center;
    box-sizing: border-box;
    cursor: pointer;
  }

  .gosaki-admin-edit-toolbar__btn--primary {
    border-color: #1d4ed8;
    background: #1d4ed8;
    color: #fff;
  }

  .gosaki-admin-edit-toolbar__btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }
</style>
