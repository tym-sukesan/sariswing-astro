{
  "name": "static-to-astro-tooling",
  "private": true,
  "type": "module",
  "description": "CLI tooling for static-to-astro (convert, analyze, visual-diff). Not the production Sariswing site.",
  "scripts": {
    "crawl:site": "node scripts/crawl-static-site.mjs",
    "url:staging": "node scripts/url-to-staging-pipeline.mjs",
    "visual-diff": "node scripts/visual-diff.mjs",
    "analyze-visual-diff": "node scripts/analyze-visual-diff.mjs",
    "verify:crawl": "node scripts/verify-crawl-static-site.mjs",
    "verify:url-staging": "node scripts/verify-url-to-staging-pipeline.mjs",
    "verify:gosaki-schedule-seed": "node scripts/verify-gosaki-schedule-seed-extractor.mjs",
    "verify:gosaki-font-safety": "node scripts/verify-gosaki-font-safety.mjs",
    "extract:gosaki-schedule-seed": "node scripts/extract-gosaki-schedule-seed.mjs",
    "generate:gosaki-schedule-seed-sql": "node scripts/generate-gosaki-schedules-seed-sql.mjs --out scripts/supabase/gosaki-schedules-seed.template.sql",
    "verify:ftp-deployer-safety": "node scripts/verify-public-dist-ftp-deployer-safety.mjs",
    "manual-upload:package": "node scripts/create-manual-upload-package.mjs --public-dir output/static-public/gosaki-piano/public-dist --out output/manual-upload/gosaki-piano --target-environment staging --package-profile staging --deploy-base /cms-kit-staging/gosaki-piano/ --staging-url https://yskcreate.weblike.jp/cms-kit-staging/gosaki-piano --intended-remote-path /cms-kit-staging/gosaki-piano/ --include-gosaki-read-only-admin true",
    "verify:manual-upload": "node scripts/verify-manual-upload-package.mjs",
    "build:gosaki-production-package": "node scripts/build-gosaki-production-package.mjs",
    "build:site-package": "node scripts/build-site-package.mjs",
    "manual-upload:package:gosaki-production": "node scripts/create-manual-upload-package.mjs --site-slug gosaki-piano --public-dir output/static-public/gosaki-piano-production/public-dist --deploy-base / --public-base-url https://www.gosaki-piano.com --target-environment production --package-profile production --intended-remote-path TBD_G-20i --out output/manual-upload/gosaki-piano-production --include-gosaki-read-only-admin false",
    "verify:manual-upload:gosaki-production": "node scripts/verify-g20i3-gosaki-production-package-admin-exclusion.mjs",
    "verify:package-upload-safety": "node scripts/verify-g20t3-staging-prod-package-upload-safety-hardening.mjs",
    "verify:g20t4-production-regen": "node scripts/verify-g20t4-gosaki-production-profile-full-regen-dry-run.mjs",
    "verify:g20t5-staging-regen": "node scripts/verify-g20t5-gosaki-staging-profile-current-head-regen-dry-run.mjs",
    "verify:package-freshness:staging": "node scripts/verify-package-upload-freshness.mjs --profile staging",
    "verify:package-freshness:production": "node scripts/verify-package-upload-freshness.mjs --profile production",
    "verify:package-freshness-gate": "node scripts/verify-g20t6-package-freshness-gate.mjs",
    "verify:g20u1-hardcode-audit": "node scripts/verify-g20u1-gosaki-hardcode-generalization-audit.mjs",
    "verify:g20u2-site-registry": "node scripts/verify-g20u2-site-registry-build-profile-foundation.mjs",
    "verify:g20u3-build-site-package": "node scripts/verify-g20u3-build-site-package-generic-cli.mjs"
  },
  "devDependencies": {
    "pixelmatch": "^7.1.0",
    "playwright": "^1.55.0",
    "pngjs": "^7.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "cheerio": "^1.2.0"
  }
}
