      /** G-20u36e admin probe — manual `rpc('is_admin')` only · never logs tokens / user_id / email · never arms Save. */
      (function wireG20u36eAdminProbe() {
        try {
        const probeBtn = document.getElementById("gra-admin-probe-btn");
        const probeResult = document.getElementById("gra-admin-probe-result");
        const body = document.body;
        if (!(probeBtn instanceof HTMLButtonElement) || !probeResult || !body) return;

        const supabaseUrl = (body.dataset.gosakiSupabaseUrl || "").trim();
        const supabaseAnonKey = (body.dataset.gosakiSupabaseAnonKey || "").trim();
        const supabaseAuthConfigured = body.dataset.gosakiSupabaseAuthConfigured === "true";

        function showProbe(display) {
          probeResult.textContent = formatG20u36eAdminProbeDisplay(display);
        }

        showProbe(createG20u36eAdminProbeIdleDisplay());

        function resolveCreateClient() {
          const lib = window.supabase;
          if (!lib) return null;
          if (typeof lib.createClient === "function") return lib.createClient;
          if (lib.default && typeof lib.default.createClient === "function") return lib.default.createClient;
          return null;
        }

        function getProbeClient() {
          if (!supabaseAuthConfigured || !supabaseUrl || !supabaseAnonKey) return null;
          const createClient = resolveCreateClient();
          if (!createClient) return null;
          return createClient(supabaseUrl, supabaseAnonKey, {
            auth: {
              persistSession: true,
              autoRefreshToken: true,
              detectSessionInUrl: false,
            },
          });
        }

        probeBtn.addEventListener("click", () => {
          // Host gate first — production STOP · staging ref required
          if (!assertG20u36eAdminProbeSupabaseHostSafe(supabaseUrl)) {
            showProbe(
              buildG20u36eAdminProbeDisplay({
                supabaseUrl,
                sessionPresent: false,
              }),
            );
            return;
          }

          const client = getProbeClient();
          if (!client) {
            showProbe(
              buildG20u36eAdminProbeDisplay({
                supabaseUrl,
                sessionPresent: false,
              }),
            );
            return;
          }

          probeBtn.disabled = true;
          showProbe(createG20u36eAdminProbeRunningDisplay());

          client.auth
            .getSession()
            .then((sessionRes) => {
              const session = sessionRes?.data?.session;
              // Session object presence only — do not read/display user id, email, or tokens in probe result
              const sessionPresent = Boolean(session);
              if (!sessionPresent) {
                showProbe(
                  buildG20u36eAdminProbeDisplay({
                    supabaseUrl,
                    sessionPresent: false,
                  }),
                );
                return;
              }

              return client.rpc(G20U36E_ADMIN_PROBE_RPC_NAME).then((rpcRes) => {
                showProbe(
                  buildG20u36eAdminProbeDisplay({
                    supabaseUrl,
                    sessionPresent: true,
                    rpcData: rpcRes?.data,
                    rpcFailed: Boolean(rpcRes?.error),
                  }),
                );
              });
            })
            .catch(() => {
              showProbe(
                buildG20u36eAdminProbeDisplay({
                  supabaseUrl,
                  sessionPresent: true,
                  rpcFailed: true,
                }),
              );
            })
            .finally(() => {
              probeBtn.disabled = !supabaseAuthConfigured;
              // Explicit: probe must never enable Save buttons
            });
        });
        } catch (_probeInitError) {
          // Probe init failure must never stop auth / page scripts
        }
      })();

      function findAlbumCard(el) {
        return el instanceof Element ? el.closest("[data-album-legacy-id]") : null;
      }

      function readReleaseFromCard(card) {
        const legacyId = card.getAttribute("data-album-legacy-id") ?? "";
        return {
          legacyId,
          release: {
            title: card.getAttribute("data-release-title") ?? "",
            artist: card.getAttribute("data-release-artist") || null,
            release_date: card.getAttribute("data-release-date") || null,
            label: card.getAttribute("data-release-label") || null,
            catalog_number: card.getAttribute("data-release-catalog-number") || null,
            published: card.getAttribute("data-release-published") === "true",
            cover_image_url: card.getAttribute("data-release-cover-image-url") || null,
            purchase_url: card.getAttribute("data-release-purchase-url") || null,
            streaming_url: card.getAttribute("data-release-streaming-url") || null,
            description: card.getAttribute("data-release-description") || null,
          },
        };
      }

      function runAlbumDryRun(card) {
        if (!card) return;
        const textarea = card.querySelector('[data-track-list-textarea="true"]');
        const resultEl = card.querySelector('[data-disc-dry-run-result="album"]');
        if (!textarea || !resultEl) return;
        const original = textarea.getAttribute("data-original-track-list") ?? "";
        const titleEl = card.querySelector(".gosaki-read-only-admin__album-card-title");
        const result = validateDiscographyTrackListDryRun(original, textarea.value, {
          legacyId: card.getAttribute("data-album-legacy-id") ?? undefined,
          title: titleEl?.textContent?.trim() ?? undefined,
        });
        resultEl.textContent = JSON.stringify(result, null, 2);
      }

      async function runAlbumEndpointDryRun(card, btn) {
        if (!card) return;
        const textarea = card.querySelector('[data-track-list-textarea="true"]');
        const resultEl = card.querySelector('[data-disc-endpoint-dry-run-result="album"]');
        const body = document.body;
        if (!textarea || !resultEl || !body) return;

        const endpoint = (body.dataset.gosakiDiscographyDryRunEndpoint || "").trim();
        const anonKey = (body.dataset.gosakiSupabaseAnonKey || "").trim();

        if (!endpoint || !anonKey) {
          resultEl.textContent = JSON.stringify(
            {
              ok: false,
              errors: ["Endpoint or anon key not configured at build time"],
              didWrite: false,
              dbWrite: false,
              networkWrite: false,
              saveEnabled: false,
            },
            null,
            2,
          );
          return;
        }

        if (
          endpoint.includes(G20U36C_PRODUCTION_PROJECT_REF_STOP) ||
          !assertG20u36cDiscographyDryRunEndpointSafe(endpoint)
        ) {
          resultEl.textContent = JSON.stringify(
            {
              ok: false,
              errors: ["Production endpoint blocked — staging only"],
              didWrite: false,
              dbWrite: false,
              networkWrite: false,
              saveEnabled: false,
            },
            null,
            2,
          );
          return;
        }

        const { legacyId, release } = readReleaseFromCard(card);
        const original = textarea.getAttribute("data-original-track-list") ?? "";
        const titleEl = card.querySelector(".gosaki-read-only-admin__album-card-title");
        const localDryRun = validateDiscographyTrackListDryRun(original, textarea.value, {
          legacyId,
          title: titleEl?.textContent?.trim() ?? undefined,
        });
        const payload = buildDiscographyDryRunEndpointRequest({
          legacyId,
          tracksText: textarea.value,
          release,
          localDryRun: {
            totalBefore: localDryRun.totalBefore,
            totalAfter: localDryRun.totalAfter,
            added: localDryRun.added,
            removed: localDryRun.removed,
            reordered: localDryRun.reordered,
          },
        });

        if (payload.operation !== G20U36C_DISCOGRAPHY_DRY_RUN_OPERATION) {
          resultEl.textContent = JSON.stringify(
            {
              ok: false,
              errors: ["operation must be dryRun only"],
              didWrite: false,
              dbWrite: false,
              networkWrite: false,
              saveEnabled: false,
            },
            null,
            2,
          );
          return;
        }

        if (btn instanceof HTMLButtonElement) btn.disabled = true;
        resultEl.textContent = "Endpoint dry-run 送信中…（Dry-run only · No DB write · Save disabled）";

        try {
          const res = await fetch(endpoint, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Authorization: "Bearer " + anonKey,
              apikey: anonKey,
            },
            body: JSON.stringify(payload),
          });

          let data = {};
          try {
            data = await res.json();
          } catch {
            data = { ok: false, errors: ["non-JSON response"] };
          }

          const display = sanitizeDiscographyDryRunEndpointDisplay(data, res.status);
          resultEl.textContent = JSON.stringify(display, null, 2);
        } catch (err) {
          const message = err instanceof Error ? err.message : String(err);
          resultEl.textContent = JSON.stringify(
            {
              ok: false,
              fetchError: message,
              didWrite: false,
              dbWrite: false,
              networkWrite: false,
              saveEnabled: false,
            },
            null,
            2,
          );
        } finally {
          if (btn instanceof HTMLButtonElement) btn.disabled = false;
        }
      }

      document.querySelectorAll('[data-disc-dry-run-btn="album"]').forEach((btn) => {
        btn.addEventListener("click", () => runAlbumDryRun(findAlbumCard(btn)));
      });

      document.querySelectorAll('[data-disc-endpoint-dry-run-btn="album"]').forEach((btn) => {
        btn.addEventListener("click", () => runAlbumEndpointDryRun(findAlbumCard(btn), btn));
      });

      const allBtn = document.getElementById("gra-disc-dry-run-all-btn");
      const allResult = document.getElementById("gra-disc-dry-run-all-result");
      if (allBtn && allResult) {
        allBtn.addEventListener("click", () => {
          const albums = [];
          document.querySelectorAll("[data-album-legacy-id]").forEach((card) => {
            const textarea = card.querySelector('[data-track-list-textarea="true"]');
            const titleEl = card.querySelector(".gosaki-read-only-admin__album-card-title");
            if (!textarea) return;
            albums.push({
              legacyId: card.getAttribute("data-album-legacy-id") ?? "",
              title: titleEl?.textContent?.trim() ?? "",
              originalText: textarea.getAttribute("data-original-track-list") ?? "",
              nextText: textarea.value,
            });
          });
          const batch = validateDiscographyTrackListDryRunBatch(albums);
          allResult.textContent = JSON.stringify(batch, null, 2);
        });
      }
    </script>
  </body>
</html>
