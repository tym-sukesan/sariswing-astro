---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import NewsList from "../components/NewsList.astro";
import InstagramFeed from "../components/InstagramFeed.astro";
---

<BaseLayout
  title="紗理 / SARI"
  description="ジャズシンガー紗理（SARI）の公式サイト。ライブスケジュール、NEWS、ディスコグラフィー、最新情報をお届けします。"
>
  <Header />

  <main class="top-page">
    <div id="topImages" class="top-hero">
      <img class="top-hero__image" src="/images/top/004.jpg" alt="紗理 / SARI" width="1920" height="1080" />
    </div>

    <div id="to_webshop">
      <a href="/discography/musical-theater-songbook-vol-1/">
        <img src="/images/top/img_websphop.jpg" />
      </a>
    </div>

    <div id="scrollBtn">
      <a href="#sec-instagram">
        <img src="/images/top/scroll.png" />
      </a>
    </div>

    <NewsList />

    <InstagramFeed />

    <section id="otonaJazz">
      <h2>オトナの Jazz Time</h2>

      <p>
        Jazzの魅力を、ジャズシンガー紗理ならではの切り口でお届けする、
        ラジオ日本「オトナのJazz Time」。
      </p>

      <a href="https://otonanojazztime.com/" target="_blank">
        <img src="/images/top/otonajazz.jpg" />
      </a>
    </section>
  </main>

  <Footer />
</BaseLayout>