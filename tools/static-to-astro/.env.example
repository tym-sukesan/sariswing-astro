# Supabase Staging credentials
# Copy this file to .env.local and fill in your staging project values.
# NEVER commit .env.local to Git.
# NEVER use production Supabase credentials here.

# Staging Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://your-staging-project.supabase.co

# Staging Supabase service role key (server-side only, NEVER expose to browser)
# Used only for seed insert via CLI. Not used in frontend Astro build.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: anon key for read-only operations (not used by insert-supabase-seed.mjs)
# SUPABASE_ANON_KEY=your-anon-key-here
