---
import embedConfig from "../data/gosaki-youtube-embed.json";
import { resolveGosakiYoutubeEmbedFromConfig } from "../lib/gosaki-youtube-embed.ts";

const embed = resolveGosakiYoutubeEmbedFromConfig(embedConfig);
---

{
  embed ? (
    <section class="gosaki-youtube-embed" aria-labelledby="gosaki-youtube-heading">
      <div class="gosaki-youtube-embed__inner">
        <h2 id="gosaki-youtube-heading" class="gosaki-youtube-embed__title">
          {embed.title}
        </h2>
        {embed.caption ? (
          <p class="gosaki-youtube-embed__caption">{embed.caption}</p>
        ) : null}
        <div class="gosaki-youtube-embed__media">
          <iframe
            class="gosaki-youtube-embed__iframe"
            src={embed.embedUrl}
            title={embed.iframeTitle}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          />
        </div>
        <p class="gosaki-youtube-embed__watch">
          <a href={embed.watchUrl} target="_blank" rel="noopener noreferrer">
            YouTubeで見る
          </a>
        </p>
      </div>
    </section>
  ) : null
}

<style>
  .gosaki-youtube-embed {
    margin: 2.5rem auto;
    max-width: 960px;
    padding: 0 1.25rem;
  }

  .gosaki-youtube-embed__inner {
    background: #fff;
    border: 1px solid #e8e4dc;
    border-radius: 8px;
    padding: 1.5rem 1.25rem 1.25rem;
  }

  .gosaki-youtube-embed__title {
    margin: 0 0 0.5rem;
    font-size: 1.35rem;
    font-weight: 700;
    text-align: center;
    color: #2c2416;
  }

  .gosaki-youtube-embed__caption {
    margin: 0 0 1rem;
    text-align: center;
    color: #5c5348;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .gosaki-youtube-embed__media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #111;
    border-radius: 6px;
    overflow: hidden;
  }

  .gosaki-youtube-embed__iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .gosaki-youtube-embed__watch {
    margin: 0.85rem 0 0;
    text-align: center;
    font-size: 0.9rem;
  }

  .gosaki-youtube-embed__watch a {
    color: #8b4513;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 768px) {
    .gosaki-youtube-embed {
      margin: 1.75rem auto;
      padding: 0 1rem;
    }

    .gosaki-youtube-embed__inner {
      padding: 1.25rem 1rem 1rem;
    }

    .gosaki-youtube-embed__title {
      font-size: 1.15rem;
    }
  }
</style>
