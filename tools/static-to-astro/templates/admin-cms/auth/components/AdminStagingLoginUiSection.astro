---
/**
 * G-5y-c / G-5y-d / G-5y-e-a — Staging login + role/allowlist section.
 */
import { getStagingAuthConfig } from "../../../../../../src/lib/admin/staging-auth/staging-auth-config";
import AdminLoginShell from "./AdminLoginShell.astro";
import AdminStagingPasswordResetCallback from "./AdminStagingPasswordResetCallback.astro";
import AdminAuthGuardPlannedNotice from "./AdminAuthGuardPlannedNotice.astro";
import AdminRoleAllowlistStatusPanel from "./AdminRoleAllowlistStatusPanel.astro";

interface Props {
  routePath?: string;
  phase?: string;
  operatorMode?: boolean;
}

const {
  routePath = "/__admin-staging-shell/musician-basic/",
  phase = "G-5y-e-a",
  operatorMode = false,
} = Astro.props;

const authConfig = getStagingAuthConfig();
---

<div
  id="admin-staging-auth-root"
  class="admin-staging-login-ui"
  data-scaffold="true"
  data-phase={phase}
  data-approval-id={authConfig.approvalId}
  data-auth-mode={authConfig.authMode}
>
  {operatorMode ? null : <AdminRoleAllowlistStatusPanel phase={phase} />}
  <AdminLoginShell phase={phase} authConfig={authConfig} operatorMode={operatorMode} />
  {
    operatorMode ? null : (
      <>
        <AdminStagingPasswordResetCallback phase="G-6-d-staging-password-reset-callback" />
        <AdminAuthGuardPlannedNotice currentRoute={routePath} phase={phase} />
      </>
    )
  }
</div>

<script>
  import "../../../../../../src/lib/admin/staging-auth/staging-auth-ui.ts";
</script>

<style>
  .admin-staging-login-ui {
    margin: 0 0 1.5rem;
  }
</style>
